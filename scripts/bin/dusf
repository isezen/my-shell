#!/bin/bash
# scripts/bin/dusf
# File-based disk usage analysis
# Analyze disk usage by file type and extension
# Usage: dusf [OPTIONS] [DIRECTORY]
# sezenismail@gmail.com
# 2014-11-24
# Disk Usage Info Sorted Only Regular Files

search_dir="${1:-.}"
regfiles=$(find "$search_dir" -maxdepth 1 -type f -a ! -iname ".*" | sed -r "s:\./::")

du_res=$(printf '%s\n' "$regfiles" | tr "\n" "\0" | xargs -0 du -achld 1) # Calculate du for files
du_total=$(printf '%s\n' "$regfiles" | tr "\n" "\0" | xargs -0 du -achld 1 | tail -n 1) # get total size
du_res=$(echo "$du_res" | head -n -1) # get sizes
du_file_list=$(echo "$du_res" | cut --complement -f 1) # Get file list form du result
du_sizes=$(echo "$du_res" | cut -f 1) # Only sizes column
ls_res=$(printf '%s\n' "$du_file_list" | tr "\n" "\0" | xargs -0 ls -AUF1 --color) # get list of files consistent with du result


# du_file_list=$(echo "$du_res" | cut --complement -f 1 | sed -e 's/$/\|/' | tr -d '\n' |  sed '$s/.$//')
# du_file_list=$(echo "$du_file_list" | sed -e 's/[]\/$*.^|[]/\\&/g')
# echo "$regfiles" | xargs \ls -AUF1 | grep -w "$du_file_list"

res=$(paste <(printf '%s\n' "$du_sizes") <(printf '%s\n' "$ls_res")) # combine size and file names

# sed -e 's/$/string after each line/'
# echo "$regfiles" | xargs \du -ach | cut --complement -f 1 | sed -e 's/$/\|/' | tr -d '\n' |  sed '$s/.$//'

# Colorize Sizes
res=$(echo "$res" | GREP_COLORS='mt=00;35' grep -E --color=always '^[0-9]*\.?[0-9][K]|$')
res=$(echo "$res" | GREP_COLORS='mt=00;32' grep -E --color=always '^[0-9]*\.?[0-9][M]|$')
res=$(echo "$res" | GREP_COLORS='mt=01;31' grep -E --color=always '^[0-9]*\.?[0-9]+[G]|$')

echo "$res" # Print result
echo "------------"
echo -e "\033[41m$du_total\033[0m" # Print Total
file_count=$(printf '%s\n' "$res" | wc -l | tr -d ' ')
echo "Number of files: $file_count"
