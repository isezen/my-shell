#!/usr/bin/env bash
# scripts/bin/ll
# Colorful long listing utility
# Enhanced ls replacement with colors, formatting, and cross-platform support
# Usage: ll [OPTIONS] [FILES...]
# Wrapper that dispatches to the platform-specific implementation.
#
# - Default: select by OS (Darwin -> ll_macos, otherwise -> ll_linux)
# - Overrides:
#     LL_IMPL=macos|linux        (force implementation)
#     LL_IMPL_PATH=/path/to/impl (force exact executable; preferred)
#     LL_SCRIPT=/path/to/impl    (legacy alias; ignored if it points to this wrapper)
#
# Notes:
# - This wrapper does not interpret/modify user args.
# - Any env (LL_CHATGPT_*, LL_NOW_EPOCH, etc.) is forwarded as-is.

set -euo pipefail

_self_dir="$(CDPATH='' cd -- "$(dirname -- "$0")" && pwd)"
_self_path="${_self_dir}/$(basename -- "$0")"

_impl_linux="${_self_dir}/ll_linux"
_impl_macos="${_self_dir}/ll_macos"

# 1) Explicit path override wins.
# Prefer LL_IMPL_PATH; keep LL_SCRIPT as a legacy alias.
  if [ -n "${LL_IMPL_PATH:-}" ]; then
    if [ ! -x "${LL_IMPL_PATH}" ] || [ ! -f "${LL_IMPL_PATH}" ]; then
    echo "selector=LL_IMPL_PATH LL_IMPL_PATH is set but not executable: ${LL_IMPL_PATH}" >&2
      exit 1
    fi
  exec "${LL_IMPL_PATH}" "$@"
fi

if [ -n "${LL_SCRIPT:-}" ]; then
  # Avoid accidental recursion when callers export LL_SCRIPT to the wrapper path.
  if [ "${LL_SCRIPT}" != "${_self_path}" ]; then
    if [ ! -x "${LL_SCRIPT}" ] || [ ! -f "${LL_SCRIPT}" ]; then
      echo "selector=LL_SCRIPT LL_SCRIPT is set but not executable: ${LL_SCRIPT}" >&2
      exit 1
    fi
    exec "${LL_SCRIPT}" "$@"
  fi
fi

# 2) Optional implementation selector.
case "${LL_IMPL:-}" in
  "") : ;;
  linux)
    if [ ! -x "${_impl_linux}" ] || [ ! -f "${_impl_linux}" ]; then
      echo "selector=LL_IMPL target not executable: ${_impl_linux}" >&2
      exit 1
    fi
    exec "${_impl_linux}" "$@"
    ;;
  macos)
    if [ ! -x "${_impl_macos}" ] || [ ! -f "${_impl_macos}" ]; then
      echo "selector=LL_IMPL target not executable: ${_impl_macos}" >&2
      exit 1
    fi
    exec "${_impl_macos}" "$@"
    ;;
  *)
    echo "Invalid LL_IMPL value: ${LL_IMPL} (expected: linux|macos)" >&2
    exit 2
    ;;
esac

# 3) Default OS-based dispatch.
_os="$(uname -s 2>/dev/null || echo unknown)"
case "${_os}" in
  Darwin)
    if [ ! -x "${_impl_macos}" ] || [ ! -f "${_impl_macos}" ]; then
      echo "selector=uname(Darwin) target not executable: ${_impl_macos}" >&2
      exit 1
    fi
    exec "${_impl_macos}" "$@"
    exit 1
    ;;
  *)
    if [ ! -x "${_impl_linux}" ] || [ ! -f "${_impl_linux}" ]; then
      echo "selector=uname(non-Darwin) target not executable: ${_impl_linux}" >&2
      exit 1
    fi
    exec "${_impl_linux}" "$@"
    exit 1
    ;;
esac
