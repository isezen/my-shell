#!/usr/bin/env bash
# scripts/bin/ll2
# eza-based ll replacement with ll-style relative time, coloring, and alignment.
# Requires: eza (https://github.com/eza-community/eza)
# Usage: ll2 [OPTIONS] [FILES...]

set -euo pipefail

if ! command -v eza >/dev/null 2>&1; then
  echo "ll2: eza is required but not installed." >&2
  echo "  Install: brew install eza (macOS) or cargo install eza (any)" >&2
  exit 1
fi

_username="$(id -un 2>/dev/null || printf '%s' "${USER:-}")"
_now="$(date +%s)"

NO_COLOR="${LL_NO_COLOR:-0}"

_eza_args=(
  -l
  "--time-style=+%s"
  --group-directories-first
  --icons=never
)

if [ "$NO_COLOR" = "1" ]; then
  _eza_args+=(--color=never)
else
  _eza_args+=(--color=always)
fi

# Single eza call with epoch timestamps → awk replaces epoch with
# ll-style compact relative time (colored, right-aligned numbers).
eza "${_eza_args[@]}" "$@" | awk \
    -v NOW="$_now" \
    -v USERNAME="$_username" \
    -v NO_COLOR="$NO_COLOR" \
'
BEGIN {
  # ll time bucket thresholds (from ll_common.awk)
  T_2MIN   = 120
  T_HOUR   = 3600
  T_2DAYS  = 172800
  T_45DAYS = 3888000
  T_YEAR   = 31536000
  T_MIN    = 60
  T_DAY    = 86400
  T_30DAYS = 2592000

  esc = "\033"
  creset = esc "[0m"
  # ll time bucket colors
  csec = esc "[38;5;124m"
  cmin = esc "[38;5;215m"
  chrs = esc "[38;5;196m"
  cday = esc "[38;5;230m"
  cmon = esc "[38;5;151m"
  cyr  = esc "[38;5;241m"
  cfut = esc "[38;5;39m"

  n = 0
}

{
  n++
  lines[n] = $0

  # Extract epoch: find 9-11 digit number (with or without ANSI wrapping)
  ep = 0
  s = $0
  # Strip ANSI to find the epoch in clean text
  clean = s
  gsub(/\033\[[0-9;]*m/, "", clean)
  if (match(clean, /[0-9]{9,11}/)) {
    ep = substr(clean, RSTART, RLENGTH) + 0
  }
  epochs[n] = ep

  # Compute relative time
  dt = NOW - ep
  is_future = 0
  if (dt < 0) { dt = -dt; is_future = 1 }

  if      (dt < T_2MIN)   { v = dt;                   lbl = "sec" }
  else if (dt < T_HOUR)   { v = int(dt / T_MIN);      lbl = "min" }
  else if (dt < T_2DAYS)  { v = int(dt / T_HOUR);     lbl = "hrs" }
  else if (dt < T_45DAYS) { v = int(dt / T_DAY);      lbl = "day" }
  else if (dt < T_YEAR)   { v = int(dt / T_30DAYS);   lbl = "mon" }
  else                    { v = int(dt / T_YEAR);     lbl = "yr"  }

  pre = ""
  if (is_future) pre = "in "

  time_v[n]   = v
  time_lbl[n] = lbl
  time_pre[n] = pre
  time_fut[n] = is_future

  # Track max number width for right-alignment (number and unit aligned separately)
  vlen = length(pre v)
  if (vlen > max_vlen) max_vlen = vlen
}

END {
  for (i = 1; i <= n; i++) {
    line = lines[i]

    # "you" substitution — only first occurrence (the owner field).
    # gsub would also clobber paths like /Users/<username>/...
    sub(USERNAME, "you", line)

    # Build formatted time string
    v   = time_v[i]
    lbl = time_lbl[i]
    pre = time_pre[i]

    # ll-style: number right-aligned (max_vlen wide), unit left-aligned (3 chars)
    numpart = pre v
    npad = ""
    need = max_vlen - length(numpart)
    for (p = 0; p < need; p++) npad = npad " "

    # Pad unit to 3 chars so "yr" aligns with "day"/"mon"/"min"/"hrs"/"sec"
    ulbl = lbl
    while (length(ulbl) < 3) ulbl = ulbl " "

    raw = npad numpart " " ulbl

    if (NO_COLOR == "1") {
      time_str = raw
    } else {
      if (time_fut[i])       c = cfut
      else if (lbl == "sec") c = csec
      else if (lbl == "min") c = cmin
      else if (lbl == "hrs") c = chrs
      else if (lbl == "day") c = cday
      else if (lbl == "mon") c = cmon
      else if (lbl == "yr")  c = cyr
      else c = ""
      time_str = c raw creset
    }

    # Replace epoch in line with formatted time.
    # Epoch in colored output: \033[34m<epoch>\033[0m
    # Epoch in plain output:   <epoch>
    ep = epochs[i]
    if (NO_COLOR == "1") {
      sub(ep, time_str, line)
    } else {
      # Match the ANSI-wrapped epoch: \033[34m<epoch>\033[0m
      # Build a regex-safe epoch pattern
      ansi_epoch = esc "\\[34m" ep esc "\\[0m"
      if (match(line, ansi_epoch)) {
        before = substr(line, 1, RSTART - 1)
        after  = substr(line, RSTART + RLENGTH)
        line = before time_str after
      } else {
        sub(ep, time_str, line)
      }
    }

    print line
  }
}
'
