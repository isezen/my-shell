#!/usr/bin/env bash
# scripts/bin/ll-chatgpt
# sezenismail@gmail.com
# 2014-11-24 (optimized 2026-01-05)
# Colorful Long Listing (fast)
# Passes arguments to 'ls -l' and post-processes in a single awk pass (2-pass inside awk).

set -euo pipefail

# Compatibility mode
# Default behavior is to match `ll` output exactly by delegating.
# Set LL_CHATGPT_FAST=1 to enable the optimized awk implementation below.
if [ "${LL_CHATGPT_FAST:-0}" != "1" ]; then
  _self_dir="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
  exec "${_self_dir}/ll" "$@"
fi

# Flags we care about (others are passed through to ls as-is)
ASIZE=0
HUMANREADABLE=0
NUMERICUIDGID=0
OWNER=1
GROUPNAME=1
LISTDIRECTORY=0

# Robust flag scan (supports options placed after operands; ls accepts that, getopts doesn't)
# We only detect flags that affect our parsing/formatting; everything is still passed through to ls.
for arg in "$@"; do
  case "$arg" in
    --) break ;;

    # long options we care about
    --directory) LISTDIRECTORY=1 ;;
    --human-readable|--si) HUMANREADABLE=1 ;;
    --numeric-uid-gid) NUMERICUIDGID=1 ;;
    --size) ASIZE=1 ;;
    --no-group) GROUPNAME=0 ;;

    # short options (possibly combined)
    -*)
      # Skip a lone '-' (stdin sentinel)
      [ "$arg" = "-" ] && continue
      # Iterate over each flag character after '-'
      _flags=${arg#-}
      for ((i=0; i<${#_flags}; i++)); do
        case "${_flags:i:1}" in
          d) LISTDIRECTORY=1 ;;
          h) HUMANREADABLE=1 ;;
          n) NUMERICUIDGID=1 ;;
          g) OWNER=0 ;;
          G) GROUPNAME=0 ;;
          o) GROUPNAME=0 ;;
          s) ASIZE=1 ;;
          *) ;;
        esac
      done
      ;;

    *) ;;
  esac
done


# Always force --time-style=+%s for fast relative time formatting in awk.
# Keep user's args intact; we only read flags above and still pass "$@" through.
# Match ll behavior: use --color (auto), so piping/ll-compare doesn't force ANSI.
ll_res=$(\ls --color "$@" -l --time-style=+"%s")

# Extract total line if present (same as ll script)
ll_total=""
if [ "$LISTDIRECTORY" -eq 0 ]; then
  _first_line="$(printf '%s\n' "$ll_res" | head -n 1)"
  if printf '%s\n' "$_first_line" | grep -Eq '^(total|toplam)[[:space:]]+'; then
    ll_total="$_first_line"
    ll_res="$(printf '%s\n' "$ll_res" | tail -n +2)"
  fi
fi

# If ll_res is empty, only print a total line if present.
if [ -z "$ll_res" ] && [ -n "$ll_total" ]; then
  printf '%s\n' "$ll_total"
  exit 0
fi

# If ll_res is empty (single file case), simulate what ll script does:
# ll script processes empty ll_res and produces a line with just dates
if [ -z "$ll_res" ]; then
  # Calculate date from ll_total (single file listing)
  _epoch=$(echo "$ll_total" | awk '{for(i=1;i<=NF;i++) if(match($i, /^[0-9]+$/)) {print $i; exit}}')
  if [ -n "$_epoch" ]; then
    _dt=$(awk -v epoch="$_epoch" -v now_epoch="${LL_NOW_EPOCH:-}" 'BEGIN {
      now = systime()
    if (now_epoch ~ /^[0-9]+$/) now = now_epoch
    dt = now - epoch
    print dt
    }')
    _prefix=""
    _abs="$_dt"
    if [ "$_dt" -lt 0 ]; then
      _prefix="in"
      _abs=$((-_dt))
    fi
    _prefix_sep="$_prefix"
    _num_w=2
    _unit_w=3
    _formatted=""
    if [ "$_abs" -lt 120 ]; then
      printf -v _num '%*d' "$_num_w" "$_abs"
      printf -v _unit '%-*s' "$_unit_w" "sec"
      if [ -n "$_prefix" ]; then
        if [ "${_num:0:1}" != " " ]; then
          _num=" $_num"
        else
          while [ "${_num:0:2}" = "  " ]; do
            _num="${_num:1}"
          done
        fi
      fi
      _formatted="${_prefix_sep}${_num} ${_unit}"
      _csec=$'\x1b[38;5;124m'
      _creset=$'\x1b[0m'
      _formatted="$_csec$_formatted$_creset"
    elif [ "$_abs" -lt 3600 ]; then
      printf -v _num '%*d' "$_num_w" $((_abs / 60))
      printf -v _unit '%-*s' "$_unit_w" "min"
      if [ -n "$_prefix" ]; then
        if [ "${_num:0:1}" != " " ]; then
          _num=" $_num"
        else
          while [ "${_num:0:2}" = "  " ]; do
            _num="${_num:1}"
          done
        fi
      fi
      _formatted="${_prefix_sep}${_num} ${_unit}"
      _cmin=$'\x1b[38;5;215m'
      _creset=$'\x1b[0m'
      _formatted="$_cmin$_formatted$_creset"
    elif [ "$_abs" -lt 172800 ]; then
      printf -v _num '%*d' "$_num_w" $((_abs / 3600))
      printf -v _unit '%-*s' "$_unit_w" "hrs"
      if [ -n "$_prefix" ]; then
        if [ "${_num:0:1}" != " " ]; then
          _num=" $_num"
        else
          while [ "${_num:0:2}" = "  " ]; do
            _num="${_num:1}"
          done
        fi
      fi
      _formatted="${_prefix_sep}${_num} ${_unit}"
      _chrs=$'\x1b[38;5;196m'
      _creset=$'\x1b[0m'
      _formatted="$_chrs$_formatted$_creset"
    elif [ "$_abs" -lt 3888000 ]; then
      printf -v _num '%*d' "$_num_w" $((_abs / 86400))
      printf -v _unit '%-*s' "$_unit_w" "day"
      if [ -n "$_prefix" ]; then
        if [ "${_num:0:1}" != " " ]; then
          _num=" $_num"
        else
          while [ "${_num:0:2}" = "  " ]; do
            _num="${_num:1}"
          done
        fi
      fi
      _formatted="${_prefix_sep}${_num} ${_unit}"
      _cday=$'\x1b[38;5;230m'
      _creset=$'\x1b[0m'
      _formatted="$_cday$_formatted$_creset"
    elif [ "$_abs" -lt 31536000 ]; then
      printf -v _num '%*d' "$_num_w" $((_abs / 2592000))
      printf -v _unit '%-*s' "$_unit_w" "mon"
      if [ -n "$_prefix" ]; then
        if [ "${_num:0:1}" != " " ]; then
          _num=" $_num"
        else
          while [ "${_num:0:2}" = "  " ]; do
            _num="${_num:1}"
          done
        fi
      fi
      _formatted="${_prefix_sep}${_num} ${_unit}"
      _cmon=$'\x1b[38;5;151m'
      _creset=$'\x1b[0m'
      _formatted="$_cmon$_formatted$_creset"
    else
      printf -v _num '%*d' "$_num_w" $((_abs / 31536000))
      printf -v _unit '%-*s' "$_unit_w" "yr"
      if [ -n "$_prefix" ]; then
        if [ "${_num:0:1}" != " " ]; then
          _num=" $_num"
        else
          while [ "${_num:0:2}" = "  " ]; do
            _num="${_num:1}"
          done
        fi
      fi
      _formatted="${_prefix_sep}${_num} ${_unit}"
      _cyr=$'\x1b[38;5;241m'
      _creset=$'\x1b[0m'
      _formatted="$_cyr$_formatted$_creset"
    fi
    if [ "$ASIZE" -eq 1 ]; then
      # With -s, ll prints a leading blocks column (use 0 for single-file fast path)
      _cb=$'\x1b[38;5;240m'
      printf "%s%s%s %s \n" "$_cb" "0" "$_creset" "$_formatted"
    else
      # Without -s, ll prints only the relative time line
      printf "%s \n" "$_formatted"
    fi
  else
    echo ""
  fi
  echo "$ll_total"
  exit 0
fi

# Resolve user name for "you" substitution in awk.
USERNAME="$(id -un 2>/dev/null || printf '%s' "${USER:-}")"

# Print using a single awk program (stores lines once; computes widths; prints).
awk -v ASIZE="$ASIZE" \
    -v HUMANREADABLE="$HUMANREADABLE" \
    -v NOW_EPOCH="${LL_NOW_EPOCH:-}" \
    -v NUMERICUIDGID="$NUMERICUIDGID" \
    -v OWNER="$OWNER" \
    -v GROUPNAME="$GROUPNAME" \
    -v LISTDIRECTORY="$LISTDIRECTORY" \
    -v USERNAME="$USERNAME" '
BEGIN {
  # ANSI reset
  creset = sprintf("%c[0m", 27)

  # Permission colors
  cd    = sprintf("%c[38;5;122m", 27)
  cl    = sprintf("%c[38;5;190m", 27)
  cr    = sprintf("%c[38;5;119m", 27)
  cw    = sprintf("%c[38;5;216m", 27)
  cx    = sprintf("%c[38;5;124m", 27)
  cplus = sprintf("%c[38;5;129m", 27)

  # User colors
  cusr  = sprintf("%c[38;5;66m", 27)
  croot = sprintf("%c[38;5;160m", 27)

  # Size colors
  cb = sprintf("%c[38;5;240m", 27)
  ck = sprintf("%c[38;5;250m", 27)
  cm = sprintf("%c[38;5;117m", 27)
  cg = sprintf("%c[38;5;208m", 27)
  ct = sprintf("%c[38;5;160m", 27)

  # Size label colors (bold)
  clT = sprintf("%c[1;38;5;167m", 27)
  clG = sprintf("%c[1;38;5;220m", 27)
  clM = sprintf("%c[1;38;5;123m", 27)
  clK = sprintf("%c[1;38;5;107m", 27)
  clB = sprintf("%c[1;38;5;248m", 27)

  # Time colors
  csec = sprintf("%c[38;5;124m", 27)
  cmin = sprintf("%c[38;5;215m", 27)
  chrs = sprintf("%c[38;5;196m", 27)
  cday = sprintf("%c[38;5;230m", 27)
  cmon = sprintf("%c[38;5;151m", 27)
  cyr  = sprintf("%c[38;5;241m", 27)

  # Constants
  SIZE_KB = 1024
  SIZE_MB = 1048576
  SIZE_GB = 1073741824
  SIZE_TB = 1099511627776

  TIME_MIN   = 60
  TIME_2MIN  = 120
  TIME_HOUR  = 3600
  TIME_DAY   = 86400
  TIME_2DAYS = 172800
  TIME_30DAYS= 2592000
  TIME_45DAYS= 3888000
  TIME_YEAR  = 31536000

  lsec="sec"; lmin="min"; lhrs="hrs"; lday="day"; lmon="mon"; lyr="yr"
  time_unit_w = 3
}

# Remove ANSI color codes for length calculation
function strip_colors(s) {
  gsub(/\033\[[0-9;]*m/, "", s)
  return s
}

function lpad(s, w,   n, out, raw_len) {
  raw_len = length(strip_colors(s))
  n = w - raw_len
  if (n <= 0) return s
  out = ""
  while (n--) out = out " "
  return out s
}
function rpad(s, w,   n, out, raw_len) {
  raw_len = length(strip_colors(s))
  n = w - raw_len
  if (n <= 0) return s
  out = ""
  while (n--) out = out " "
  return s out
}

function color_perm(p,   i,ch,out) {
  out=""
  for (i=1; i<=length(p); i++) {
    ch = substr(p,i,1)
    if      (ch=="d") out = out cd ch creset
    else if (ch=="l") out = out cl ch creset
    else if (ch=="r") out = out cr ch creset
    else if (ch=="w") out = out cw ch creset
    else if (ch=="x") out = out cx ch creset
    else if (ch=="+") out = out cplus ch creset
    else              out = out ch
  }
  return out
}

function size_color_numeric(x,   c) {
  if (x < SIZE_KB) return cb
  if (x < SIZE_MB) return ck
  if (x < SIZE_GB) return cm
  if (x < SIZE_TB) return cg
  return ct
}

function color_size_human(s,   num, suf, out, prgx) {
  # Expect things like: 123, 1.2K, 234M, 5G, 1T, maybe no suffix.
  # Also allow trailing "B" (we add it if missing and it is pure number).
  prgx="^[0-9]+(\\.[0-9]+)?"
  if (s ~ /^[0-9]+$/) s = s "B"
  num = s
  suf = ""
  if (match(s, /^[0-9]+(\.[0-9]+)?/, m)) {
    num = m[0]
    suf = substr(s, length(num)+1, 1)
  }

  if      (suf=="T") out = ct num creset clT suf creset
  else if (suf=="G") out = cg num creset clG suf creset
  else if (suf=="M") out = cm num creset clM suf creset
  else if (suf=="K") out = ck num creset clK suf creset
  else if (suf=="B") out = cb num creset clB suf creset
  else               out = cb s creset

  return out
}

function time_calc(epoch,   dt, v, lbl, now, prefix) {
  now = systime()
  if (NOW_EPOCH ~ /^[0-9]+$/) now = NOW_EPOCH
  dt = now - epoch
  if (dt < 0) { prefix = "in"; dt = -dt } else { prefix = "" }
  if      (dt < TIME_2MIN)   { v=dt;                 lbl=lsec }
  else if (dt < TIME_HOUR)   { v=int(dt/TIME_MIN);   lbl=lmin }
  else if (dt < TIME_2DAYS)  { v=int(dt/TIME_HOUR);  lbl=lhrs }
  else if (dt < TIME_45DAYS) { v=int(dt/TIME_DAY);   lbl=lday }
  else if (dt < TIME_YEAR)   { v=int(dt/TIME_30DAYS);lbl=lmon }
  else                       { v=int(dt/TIME_YEAR);  lbl=lyr  }
  time_prefix = prefix
  time_num = v
  time_unit = lbl
}
function color_reltime_by_lbl(s, lbl,   out) {
  if      (lbl==lsec) out = csec s creset
  else if (lbl==lmin) out = cmin s creset
  else if (lbl==lhrs) out = chrs s creset
  else if (lbl==lday) out = cday s creset
  else if (lbl==lmon) out = cmon s creset
  else if (lbl==lyr ) out = cyr  s creset
  else                out = s
  return out
}

# New parse_line(): non-regex, position-based parser using epoch position
function _is_epoch(tok) {
  # We force --time-style=+%s, so epoch is a 9+ digit integer.
  return (tok ~ /^[0-9]{9,}$/)
}

# Find the last occurrence of: <space><9+digits><space>
# Returns 1 on success and sets globals: epoch, epoch_start, epoch_end (inclusive)
function _find_epoch_span(line,   tmp, off, best_s, best_e, s, e, digits) {
  tmp = line
  off = 0
  best_s = 0
  best_e = 0

  while (match(tmp, /[[:space:]][0-9]{9,}[[:space:]]/)) {
    s = off + RSTART
    e = off + RSTART + RLENGTH - 1
    best_s = s
    best_e = e

    off = off + RSTART + RLENGTH - 1
    tmp = substr(line, off + 1)
  }

  if (best_s == 0) return 0

  # Extract digits inside the matched span
  digits = substr(line, best_s, best_e - best_s + 1)
  gsub(/^[[:space:]]+/, "", digits)
  gsub(/[[:space:]]+$/, "", digits)

  if (!_is_epoch(digits)) return 0

  epoch = digits
  epoch_start = best_s
  epoch_end = best_e
  return 1
}

# Parse ls -l line in a way that is robust to spaces in filenames and leading spaces.
# Works across OWNER/GROUPNAME/ASIZE combinations because size+epoch are always adjacent
# when using --time-style=+%s.
function parse_line(line,   left, right, nlt, i, t, toks, tail_start) {
  # Skip total/toplam lines
  if (line ~ /^(total|toplam)[[:space:]]+/) return 0

  if (!_find_epoch_span(line)) return 0

  # Extract tail (filename + symlink target if any) safely:
  # CRITICAL: Use "tail" approach - never tokenize the filename part.
  # 
  # Pattern: ^(PREFIX)(EPOCH)(TAIL)$
  # where TAIL = everything after epoch (including any leading whitespace, tabs, unicode, symlink arrows)
  #
  # IMPORTANT: We preserve:
  # - Leading spaces in filenames (e.g., " file-leading-space.txt")
  # - Tabs in filenames (e.g., "a\tb.txt")  
  # - Spaces in filenames (e.g., "a b.txt")
  # - Unicode characters (e.g., "İçerik-ğüşöç.txt")
  # - Symlink arrows (" -> target")
  #
  # Strategy: epoch_end points to the last character of the epoch.
  # Everything from (epoch_end + 1) onwards is the tail, which we preserve RAW.
  # We do NOT skip any whitespace - the first character after epoch might be:
  # - A separator space (normal case)
  # - Part of the filename (if filename starts with space)
  # Both cases are handled correctly by taking everything as-is.
  
  # Extract tail: everything after epoch_end (inclusive of epoch_end+1)
  # This preserves ALL whitespace, tabs, and content exactly as-is
  name = substr(line, epoch_end + 1)

  # left part: everything before the epoch span
  left = substr(line, 1, epoch_start - 1)
  gsub(/^[[:space:]]+/, "", left)

  # Tokenize left by whitespace; this is safe because we only need fixed fields
  # that do not contain spaces.
  nlt = split(left, toks, /[[:space:]]+/)
  if (nlt < 3) return 0

  # If ASIZE, first token is blocks
  if (ASIZE) {
    blocks = toks[1]
    perms  = toks[2]
    links  = toks[3]

    # Remaining tokens after perms+links depend on OWNER/GROUPNAME.
    if (OWNER && GROUPNAME) {
      if (nlt < 6) return 0
      owner = toks[4]
      group = toks[5]
      size  = toks[nlt]
    } else if (!OWNER && GROUPNAME) {
      if (nlt < 5) return 0
      owner = ""
      group = toks[4]
      size  = toks[nlt]
    } else if (OWNER && !GROUPNAME) {
      if (nlt < 5) return 0
      owner = toks[4]
      group = ""
      size  = toks[nlt]
    } else {
      # !OWNER && !GROUPNAME
      if (nlt < 3) return 0
      owner = ""
      group = ""
      size  = toks[nlt]
    }
  } else {
    blocks = ""
    perms  = toks[1]
    links  = toks[2]

    if (OWNER && GROUPNAME) {
      # Format: perms links owner group size
      # So we need at least 5 tokens: toks[1]=perms, toks[2]=links, toks[3]=owner, toks[4]=group, toks[5]=size
      if (nlt < 5) return 0
      owner = toks[3]
      group = toks[4]
      size  = toks[nlt]
    } else if (!OWNER && GROUPNAME) {
      if (nlt < 4) return 0
      owner = ""
      group = toks[3]
      size  = toks[nlt]
    } else if (OWNER && !GROUPNAME) {
      if (nlt < 4) return 0
      owner = toks[3]
      group = ""
      size  = toks[nlt]
    } else {
      # !OWNER && !GROUPNAME
      if (nlt < 2) return 0
      owner = ""
      group = ""
      size  = toks[nlt]
    }
  }

  return 1
}

{
  if (!parse_line($0)) next

  n++
  a_blocks[n] = blocks
  a_perms[n]  = perms
  a_links[n]  = links
  a_owner[n]  = owner
  a_group[n]  = group
  a_size[n]   = size
  a_epoch[n]  = epoch
  a_name[n]   = name
  time_calc(epoch + 0)
  a_tprefix[n] = time_prefix
  a_tnum[n] = time_num
  a_tunit[n] = time_unit

  # widths (raw, without color) - use strip_colors for accurate width calculation
  if (ASIZE) {
    bcalc = blocks
    if (HUMANREADABLE && bcalc ~ /^[0-9]+$/) bcalc = bcalc "B"
    if (length(bcalc) > w_blocks) w_blocks = length(bcalc)
  }
  if (length(perms) > w_perms) w_perms = length(perms)
  if (length(links) > w_links) w_links = length(links)

  if (OWNER) {
    # replace $USER with "you" only for width calc if we will do it
    o = owner
    if (!NUMERICUIDGID && USERNAME != "" && o == USERNAME) o = "you"
    if (length(o) > w_owner) w_owner = length(o)
  }
  if (GROUPNAME && length(group) > w_group) w_group = length(group)
  # For size, we need to calculate width without color codes (same as ll script uses wc -L)
  size_raw = strip_colors(size)
  if (HUMANREADABLE && size_raw ~ /^[0-9]+$/) size_raw = size_raw "B"
  if (length(size_raw) > w_size) w_size = length(size_raw)
  tnum_s = sprintf("%d", time_num)
  if (length(tnum_s) > w_tnum) w_tnum = length(tnum_s)
}

END {
  if (w_tnum < 2) w_tnum = 2
  for (i=1; i<=n; i++) {
    out = ""

    if (ASIZE) {
      b = a_blocks[i]
      if (HUMANREADABLE) {
        b_colored = color_size_human(b)
        out = out lpad(b_colored, w_blocks) " "
      } else {
        # Numeric blocks: keep it dim (byte color) and right-aligned
        out = out cb lpad(b, w_blocks) creset " "
      }
    }

    p = a_perms[i]
    out = out rpad(color_perm(p), w_perms) " "

    out = out lpad(a_links[i], w_links) " "

    if (OWNER) {
      o = a_owner[i]
      if (!NUMERICUIDGID && USERNAME != "" && o == USERNAME) o = "you"
      # colorize owner
      if (o == "you") o = cusr o creset
      else if (o == "root") o = croot o creset
      out = out rpad(o, w_owner) " "
    }

    if (GROUPNAME) {
      g = a_group[i]
      out = out rpad(g, w_group) " "
    }

    s = a_size[i]
    if (HUMANREADABLE) {
      s_colored = color_size_human(s)
      out = out lpad(s_colored, w_size) " "
    } else {
      # numeric bytes: color by tier; right align
      c = size_color_numeric(s + 0)
      s_colored = c s creset
      out = out lpad(s_colored, w_size) " "
    }

    num_s = sprintf("%d", a_tnum[i])
    num_s = lpad(num_s, w_tnum)
    unit_s = rpad(a_tunit[i], time_unit_w)
    if (a_tprefix[i] != "") {
      if (substr(num_s, 1, 1) != " ") {
        num_s = " " num_s
      } else {
        while (substr(num_s, 1, 2) == "  ") num_s = substr(num_s, 2)
      }
      t_raw = a_tprefix[i] num_s " " unit_s
    } else {
      t_raw = num_s " " unit_s
    }
    t_colored = color_reltime_by_lbl(t_raw, a_tunit[i])
    out = out t_colored " "

    out = out a_name[i]

    print out
  }
}
' <<<"$ll_res"

# Print total line if present (same as ll script)
[ -n "$ll_total" ] && echo "$ll_total"
