#!/bin/bash
# scripts/bin/dus
# Disk usage utility
# Display disk usage with sorting and coloring options
# Usage: dus [OPTIONS] [DIRECTORY]
# sezenismail@gmail.com
# 2014-11-24
# Disk Usage Info Sorted and Colored
# Disk usage Informatin for everyhing in CURRENT directory
#
# dus (f|d|h|a)v

# ----------------------------------------------------------------------
# GNU coreutils preflight
# ----------------------------------------------------------------------
# Feature-frozen legacy utility. This script uses GNU-specific flags
# that BSD userland does not support:
#   - ls --color                  (BSD uses -G)
#   - du -d N / du -ahcd          (BSD -d has different semantics)
#   - head -n -N                  (BSD head has no negative count)
#   - GNU grep GREP_COLORS env    (BSD grep has no equivalent)
# Probing `ls --version` is a reliable GNU/BSD discriminator since BSD ls
# treats it as an unknown flag and fails. If GNU coreutils is missing,
# print an actionable error and exit 2 (usage/requirement error) rather
# than letting the script fall through into cryptic BSD usage noise.
#
# Modern alternatives worth considering instead of this legacy script:
#   ncdu   — fast interactive disk usage explorer
#   dust   — Rust-based, tree view (`brew install dust` / `port install dust`)
#   duf    — cross-platform disk-free overview
if ! command ls --version >/dev/null 2>&1; then
  cat >&2 <<'MISSING_GNU'
dus: GNU coreutils required (this is a feature-frozen legacy utility).

This script uses GNU-specific flags (ls --color, du -d, head -n -N,
GNU grep GREP_COLORS) that BSD userland does not support.

On macOS, install GNU coreutils via one of:
  MacPorts: sudo port install coreutils
  Homebrew: brew install coreutils

Then put the GNU binaries ahead of the system ones in PATH, e.g.:
  export PATH="/opt/local/libexec/gnubin:$PATH"                     # MacPorts
  export PATH="/opt/homebrew/opt/coreutils/libexec/gnubin:$PATH"    # Homebrew

Or consider modern replacements: ncdu / dust / duf.
MISSING_GNU
  exit 2
fi

  # Display usage information
_usage() {
  echo "Disk Usage Script 2014 Ismail SEZEN"
  echo "Usage: $0 -(f|d|h|a)v *.pdf"
  echo "-f : Only Regular files"
  echo "-d : Only Directories"
  echo "-a : Everything"
  echo "-p : Search pattern"
  echo "-v : Verbose output."
  echo "-h : Shows this message."
  exit 1
}

OPTIND=1 # Reset in case getopts has been used previously in the shell.

VERBOSE=0 # v
FILES=0   # f
DIRS=0    # d
ALL=0     # a
PATTERN="" # p

while getopts "h?vfdap:" opt; do
  case "$opt" in
    h|\?)
    _usage
    exit 0
    ;;
    v)  VERBOSE=1
    ;;
    f)  FILES=1
    ;;
    d)  DIRS=1
    ;;
    a)  ALL=1
    ;;
    p)  PATTERN="$OPTARG"
    ;;
  esac
done
shift $((OPTIND-1))

: "$VERBOSE" "$FILES" "$DIRS" "$ALL" "$PATTERN"

# echo "$ls_res" |  tr " " ","

ls_res=$(ls -AUF1 --color) # get only file/directory names
du_res=$(du -ahcd 1 | sed -E "s:./::") # get sizes
du_total=$(echo "$du_res" | tail -n 1)
du_res=$(echo "$du_res" | head -n -2) # get sizes
du_sizes=$(echo "$du_res" | cut -f 1) # Only sizes column

res=$(paste <(echo "$du_sizes") <(echo "$ls_res")) # combine size and file names
res=$(echo "$res" | sort -h -k 1) # Sort

# Colorize Sizes
res=$(echo "$res" | GREP_COLORS='mt=00;35' grep -E --color=always '^[0-9]*\.?[0-9][K]|$')
res=$(echo "$res" | GREP_COLORS='mt=00;32' grep -E --color=always '^[0-9]*\.?[0-9][M]|$')
res=$(echo "$res" | GREP_COLORS='mt=01;31' grep -E --color=always '^[0-9]*\.?[0-9]+[G]|$')

echo "$res" # Print result
echo "------------"
echo -e "\033[41m$du_total\033[0m" # Print Total
