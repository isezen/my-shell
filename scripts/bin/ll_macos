#!/usr/bin/env bash
# scripts/bin/ll_macos
# macOS-specific implementation of ll command
# Uses BSD utilities (ls, awk, stat) for macOS compatibility
# Usage: ll_macos [OPTIONS] [FILES...]
# macOS/BSD userland implementation for `ll`.
#
# Goals:
# - Provide a `ll_linux`-compatible *presentation* (colors, relative time buckets, quoting rules)
# - Use only macOS-default tools (BSD stat/ls/awk), no GNU coreutils required
# - Best-effort parity for the subset of flags used by the test-suite

set -euo pipefail

# ------------------------------
# Flag scan (subset)
# ------------------------------
ASIZE=0
HUMANREADABLE=0
SI=0
NUMERICUIDGID=0
OWNER=1
GROUPNAME=1
LISTDIRECTORY=0

# Robust scan: consider only options before `--`.
for arg in "$@"; do
  case "$arg" in
    --)
      break
      ;;

    --directory)
      LISTDIRECTORY=1
      ;;
    --human-readable)
      HUMANREADABLE=1
      ;;
    --si)
      HUMANREADABLE=1
      SI=1
      ;;
    --numeric-uid-gid)
      NUMERICUIDGID=1
      ;;
    --size)
      ASIZE=1
      ;;
    --no-group)
      GROUPNAME=0
      ;;

    -*)
      [ "$arg" = "-" ] && continue
      _flags=${arg#-}
      for ((i=0; i<${#_flags}; i++)); do
        case "${_flags:i:1}" in
          d) LISTDIRECTORY=1 ;;
          h) HUMANREADABLE=1 ;;
          n) NUMERICUIDGID=1 ;;
          g) OWNER=0 ;;
          G) GROUPNAME=0 ;;
          o) GROUPNAME=0 ;;
          s) ASIZE=1 ;;
          *) ;;
        esac
      done
      ;;
    *)
      ;;
  esac
done

NOW_EPOCH="${LL_NOW_EPOCH:-}"
if [[ ! "$NOW_EPOCH" =~ ^[0-9]+$ ]]; then
  NOW_EPOCH="$(date +%s)"
fi

USERNAME="$(id -un 2>/dev/null || printf '%s' "${USER:-}")"
DELIM=$'\037'
TAB_CHAR=$'\011'
# NOTE: Filenames with literal newlines are out-of-scope (line-based records).

# ------------------------------
# Helpers
# ------------------------------
  # quote_if_needed function
quote_if_needed() {
  # Quote if contains space or tab (matches ll_linux behavior).
  # Keeps content verbatim otherwise.
  local s="$1"
  if [[ "$s" == *"$TAB_CHAR"* ]] || [[ "$s" == *" "* ]]; then
    printf '"%s"' "$s"
  else
  # Format output
    printf '%s' "$s"
  fi
}

format_name() {
  # If symlink, format as: <quoted name> -> <quoted target>
  # Otherwise: <quoted name>
  local name="$1"
  local perms="$2"
  local path="$3"

  if [[ "$perms" == l* ]]; then
    local target
    target="$(readlink "${path}" 2>/dev/null || true)"
    if [ -n "$target" ]; then
      printf '%s -> %s' "$(quote_if_needed "$name")" "$(quote_if_needed "$target")"
      return 0
    fi
  fi

  quote_if_needed "$name"
}

strip_ansi() {
  /usr/bin/perl -pe '
    s/\e\[[0-9;?]*[ -\/]*[@-~]//g;
    s/\e\][^\a]*(\a|\e\\)//g;
    s/\e[P^_].*?(\e\\)//gs;
    s/\e[()#][0-9A-Za-z]//g;
    s/\e[\x40-\x5F]//g;
    s/\x1b\[[0-9;]*K//g;
    s/\r//g;
  '
}

visible_len() {
  local raw
  raw="$(printf '%s' "$1" | strip_ansi)"
  printf '%s' "${#raw}"
}

# Convert bytes to human label (base-2), close to GNU ls -h.
# Output examples: 512B, 2.0K, 12K, 2.0M, 1.0G, 1.0T
human_size() {
  local bytes="$1"
  if [[ ! "$bytes" =~ ^[0-9]+$ ]]; then
    printf '%s' "$bytes"
    return 0
  fi

  local unit="B"
  local scaled="$bytes"

  # Use awk for floating formatting.
  if [ "$bytes" -lt 1024 ]; then
    printf '%sB' "$bytes"
    return 0
  fi

  # Decide unit.
  if [ "$bytes" -lt $((1024 * 1024)) ]; then
    unit="K"
    scaled="$(/usr/bin/awk -v b="$bytes" 'BEGIN{printf "%.1f", b/1024.0}')"
  elif [ "$bytes" -lt $((1024 * 1024 * 1024)) ]; then
    unit="M"
    scaled="$(/usr/bin/awk -v b="$bytes" 'BEGIN{printf "%.1f", b/1048576.0}')"
  elif [ "$bytes" -lt $((1024 * 1024 * 1024 * 1024)) ]; then
    unit="G"
    scaled="$(/usr/bin/awk -v b="$bytes" 'BEGIN{printf "%.1f", b/1073741824.0}')"
  else
    unit="T"
    scaled="$(/usr/bin/awk -v b="$bytes" 'BEGIN{printf "%.1f", b/1099511627776.0}')"
  fi

  # Trim trailing .0 for readability (GNU-ish).
  scaled="$(printf '%s' "$scaled" | sed -E 's/\.0$//')"
  printf '%s%s' "$scaled" "$unit"
}

# Relative time parts: sets globals: TNUM, TUNIT, TFUT(0/1)
time_parts() {
  local epoch="$1"
  local dt
  dt=$((NOW_EPOCH - epoch))

  local prefix=""
  local abs="$dt"
  if [ "$dt" -lt 0 ]; then
    prefix="in"
    abs=$(( -dt ))
  fi

  local num unit
  if [ "$abs" -lt 120 ]; then
    num="$abs"; unit="sec"
  elif [ "$abs" -lt 3600 ]; then
    num=$(( abs / 60 )); unit="min"
  elif [ "$abs" -lt 172800 ]; then
    num=$(( abs / 3600 )); unit="hrs"
  elif [ "$abs" -lt 3888000 ]; then
    num=$(( abs / 86400 )); unit="day"
  elif [ "$abs" -lt 31536000 ]; then
    num=$(( abs / 2592000 )); unit="mon"
  else
    num=$(( abs / 31536000 )); unit="yr"
  fi

  TNUM="$num"
  TUNIT="$unit"
  TFUT=0
  if [ -n "$prefix" ]; then
    TFUT=1
  fi
  return 0
}

# ANSI colors (match ll_linux palette)
esc=$'\033'
creset="${esc}[0m"

cd="${esc}[38;5;122m"
cl="${esc}[38;5;190m"
cr="${esc}[38;5;119m"
cw="${esc}[38;5;216m"
cx="${esc}[38;5;124m"
cplus="${esc}[38;5;129m"

cusr="${esc}[38;5;66m"
croot="${esc}[38;5;160m"

cb="${esc}[38;5;240m"
ck="${esc}[38;5;250m"
cm="${esc}[38;5;117m"
cg="${esc}[38;5;208m"
ct="${esc}[38;5;160m"

clT="${esc}[1;38;5;167m"
clG="${esc}[1;38;5;220m"
clM="${esc}[1;38;5;123m"
clK="${esc}[1;38;5;107m"
clB="${esc}[1;38;5;248m"

csec="${esc}[38;5;124m"
cmin="${esc}[38;5;215m"
chrs="${esc}[38;5;196m"
cday="${esc}[38;5;230m"
cmon="${esc}[38;5;151m"
  # Apply color formatting
cyr="${esc}[38;5;241m"
cfut="${esc}[38;5;39m"

color_perm() {
  local p="$1"
  local out=""
  local ch
  local i

  for ((i=0; i<${#p}; i++)); do
    ch="${p:i:1}"
    case "$ch" in
      d) out+="${cd}${ch}${creset}" ;;
      l) out+="${cl}${ch}${creset}" ;;
      r) out+="${cr}${ch}${creset}" ;;
      w) out+="${cw}${ch}${creset}" ;;
      x) out+="${cx}${ch}${creset}" ;;
  # Apply color formatting
      +) out+="${cplus}${ch}${creset}" ;;
      *) out+="$ch" ;;
    esac
  done

  printf '%s' "$out"
}

size_color_numeric() {
  local x="$1"
  if [ "$x" -lt 1024 ]; then printf '%s' "$cb"; return; fi
  if [ "$x" -lt 1048576 ]; then printf '%s' "$ck"; return; fi
  # Apply color formatting
  if [ "$x" -lt 1073741824 ]; then printf '%s' "$cm"; return; fi
  if [ "$x" -lt 1099511627776 ]; then printf '%s' "$cg"; return; fi
  printf '%s' "$ct"
}

color_size_human() {
  # Input: <label> (e.g. 12K, 4,1k, 2.5M, 512B). Apply tier color to number and bold to suffix.
  # Supports uppercase K/M/G/T (IEC) and lowercase k (SI kilo).
  local s="$1"
  local num suf

  # Support dot or comma decimal separator, and lowercase k (SI) or uppercase K/M/G/T (IEC).
  if [[ "$s" =~ ^([0-9]+([\.,][0-9]+)?)(k|K|M|G|T|B)$ ]]; then
    num="${BASH_REMATCH[1]}"
    suf="${BASH_REMATCH[3]}"
  elif [[ "$s" =~ ^([0-9]+)$ ]]; then
    num="${BASH_REMATCH[1]}"
    suf="B"
  else
    printf '%s%s%s' "$cb" "$s" "$creset"
    return 0
  fi

  case "$suf" in
    T) printf '%s%s%s%s%s%s' "$ct" "$num" "$creset" "$clT" "$suf" "$creset" ;;
    G) printf '%s%s%s%s%s%s' "$cg" "$num" "$creset" "$clG" "$suf" "$creset" ;;
    M) printf '%s%s%s%s%s%s' "$cm" "$num" "$creset" "$clM" "$suf" "$creset" ;;
    K) printf '%s%s%s%s%s%s' "$ck" "$num" "$creset" "$clK" "$suf" "$creset" ;;
    k) printf '%s%s%s%s%s%s' "$ck" "$num" "$creset" "$clK" "$suf" "$creset" ;;
    B) printf '%s%s%s%s%s%s' "$cb" "$num" "$creset" "$clB" "$suf" "$creset" ;;
    *) printf '%s%s%s' "$cb" "$s" "$creset" ;;
  esac
}

# Format blocks (1K units) into human label like GNU ls -s -h or -s --si
# - For -h (si_mode=0): base-1024 with uppercase K/M/G/T, one decimal
# - For --si (si_mode=1): base-1000 with lowercase k/M/G/T, one decimal per-row; trim .0 for totals
# - 0 blocks -> 0B
blocks_human_label() {
  local blocks="$1"
  local si_mode="${2:-0}"
  if [[ ! "$blocks" =~ ^[0-9]+$ ]]; then
    printf '%s' "$blocks"
    return 0
  fi

  local bytes base unit val out
  bytes=$(( blocks * 1024 ))
  base=$(( si_mode ? 1000 : 1024 ))

  if [ "$bytes" -lt "$base" ]; then
    printf '0B'
    return 0
  fi

  # Choose unit and format
  if [ "$bytes" -lt $((base * base)) ]; then
    if [ "$si_mode" -eq 1 ]; then
      unit="k"  # SI: lowercase k
      val="$(/usr/bin/awk -v b="$bytes" 'BEGIN{printf "%.1f", b/1000.0}')"
    else
      unit="K"  # IEC: uppercase K
      val="$(/usr/bin/awk -v b="$bytes" 'BEGIN{printf "%.1f", b/1024.0}')"
    fi
  elif [ "$bytes" -lt $((base * base * base)) ]; then
    unit="M"
    divisor=$((base * base))
    val="$(/usr/bin/awk -v b="$bytes" -v div="$divisor" 'BEGIN{printf "%.1f", b/div}')"
  elif [ "$bytes" -lt $((base * base * base * base)) ]; then
    unit="G"
    divisor=$((base * base * base))
    val="$(/usr/bin/awk -v b="$bytes" -v div="$divisor" 'BEGIN{printf "%.1f", b/div}')"
  else
    unit="T"
    divisor=$((base * base * base * base))
    val="$(/usr/bin/awk -v b="$bytes" -v div="$divisor" 'BEGIN{printf "%.1f", b/div}')"
  fi

  # Apply locale decimal separator
  if [ "$DEC_SEP" != "." ]; then
    out="$(printf '%s' "$val" | sed 's/\./,/')${unit}"
  else
    out="${val}${unit}"
  fi
  printf '%s' "$out"
}

# Format blocks for total line: GNU ls rounds to nearest integer (no decimals)
# For SI mode, GNU ls appears to use ceiling division
blocks_total_label() {
  local blocks="$1"
  local si_mode="${2:-0}"
  
  if [[ ! "$blocks" =~ ^[0-9]+$ ]]; then
    printf '%s' "$blocks"
    return 0
  fi

  local bytes base unit val_float val_int out
  bytes=$(( blocks * 1024 ))
  base=$(( si_mode ? 1000 : 1024 ))

  if [ "$bytes" -lt "$base" ]; then
    printf '0'
    return 0
  fi

  # Determine unit and compute value
  if [ "$bytes" -lt $((base * base)) ]; then
    if [ "$si_mode" -eq 1 ]; then
      unit="k"
      # SI mode: use ceiling division
      val_int=$(( (bytes + base - 1) / base ))
    else
      unit="K"
      # -h mode: round to nearest
      val_float="$(/usr/bin/awk -v b="$bytes" -v base="$base" 'BEGIN{printf "%.0f", b/base}')"
      val_int="$val_float"
    fi
  elif [ "$bytes" -lt $((base * base * base)) ]; then
    unit="M"
    divisor=$((base * base))
    if [ "$si_mode" -eq 1 ]; then
      val_int=$(( (bytes + divisor - 1) / divisor ))
    else
      val_float="$(/usr/bin/awk -v b="$bytes" -v div="$divisor" 'BEGIN{printf "%.0f", b/div}')"
      val_int="$val_float"
    fi
  elif [ "$bytes" -lt $((base * base * base * base)) ]; then
    unit="G"
    divisor=$((base * base * base))
    if [ "$si_mode" -eq 1 ]; then
      val_int=$(( (bytes + divisor - 1) / divisor ))
    else
      val_float="$(/usr/bin/awk -v b="$bytes" -v div="$divisor" 'BEGIN{printf "%.0f", b/div}')"
      val_int="$val_float"
    fi
  else
    unit="T"
    divisor=$((base * base * base * base))
    if [ "$si_mode" -eq 1 ]; then
      val_int=$(( (bytes + divisor - 1) / divisor ))
    else
      val_float="$(/usr/bin/awk -v b="$bytes" -v div="$divisor" 'BEGIN{printf "%.0f", b/div}')"
      val_int="$val_float"
    fi
  fi

  printf '%s%s' "$val_int" "$unit"
}

color_reltime() {
  local raw="$1"
  local unit="$2"
  local is_future="$3"

  if [ "$is_future" -eq 1 ]; then
    printf '%s%s%s' "$cfut" "$raw" "$creset"
    return 0
  fi

  case "$unit" in
    sec) printf '%s%s%s' "$csec" "$raw" "$creset" ;;
    min) printf '%s%s%s' "$cmin" "$raw" "$creset" ;;
    hrs) printf '%s%s%s' "$chrs" "$raw" "$creset" ;;
    day) printf '%s%s%s' "$cday" "$raw" "$creset" ;;
    mon) printf '%s%s%s' "$cmon" "$raw" "$creset" ;;
    yr)  printf '%s%s%s' "$cyr"  "$raw" "$creset" ;;
    *)   printf '%s' "$raw" ;;
  esac
}

# ------------------------------
# Collect operands (respect `--`)
# ------------------------------
opts=()
ops=()
seen_sep=0
for arg in "$@"; do
  if [ "$seen_sep" -eq 0 ] && [ "$arg" = "--" ]; then
    seen_sep=1
    continue
  fi
  if [ "$seen_sep" -eq 0 ] && [[ "$arg" == -* ]] && [ "$arg" != "-" ]; then
    opts+=("$arg")
  else
    ops+=("$arg")
  fi
done

# Default operand is "." like ls.
if [ "${#ops[@]}" -eq 0 ]; then
  ops=(".")
fi

# Determine if we have multiple operands (for directory headers).
multiple=0
if [ "${#ops[@]}" -gt 1 ]; then
  multiple=1
fi

total_label="total"
locale_hint="${LC_ALL:-${LANG:-}}"
if printf '%s' "$locale_hint" | grep -qi '^tr'; then
  total_label="toplam"
fi

# Decimal separator (locale-aware best-effort)
DEC_SEP="."
if printf '%s' "$locale_hint" | grep -qi '^tr'; then
  DEC_SEP=","  # Turkish uses comma decimal
fi

total_applicable=0
if [ "$LISTDIRECTORY" -eq 0 ] && [ "$multiple" -eq 0 ] && [ "${#ops[@]}" -eq 1 ]; then
  if [ -d "${ops[0]}" ] && [ ! -L "${ops[0]}" ]; then
    total_applicable=1
  fi
fi

# ------------------------------
# Build listing: expand directories (unless -d)
# ------------------------------
# Rows stored as US-separated fields to preserve names safely.
# Fields: blocks perms links owner group size epoch name path is_child
rows=()

a_push_row() {
  local path="$1"
  local display_name="${2:-}"
  local is_child="${3:-0}"

  # stat format notes:
  # %b 512-byte blocks, %Sp permissions string, %l links, %Su/%Sg names, %u/%g ids, %z size bytes, %m mtime epoch, %N filename
  local st
  local stat_path="$path"
  if [[ "$stat_path" == -* ]]; then
    stat_path="./$stat_path"
  fi
  local stat_fmt
  stat_fmt="%b${DELIM}%Sp${DELIM}%l${DELIM}%Su${DELIM}%Sg${DELIM}%u${DELIM}%g${DELIM}%z${DELIM}%m${DELIM}%N"
  st="$(/usr/bin/stat -f "$stat_fmt" "$stat_path" 2>/dev/null || true)"
  if [ -z "$st" ]; then
    return 0
  fi

  local b512 perms links su sg uid gid size epoch name
  IFS="$DELIM" read -r b512 perms links su sg uid gid size epoch name <<<"$st"

  # BSD stat %N may include "name -> target" for symlinks; keep only the name part for display.
  if [[ "$perms" == l* ]] && [[ "$name" == *" -> "* ]]; then
    name="${name%% -> *}"
  fi
  if [[ "$name" == ./* ]]; then
    name="${name#./}"
  fi

  # If display_name is provided, use it; otherwise use the name from stat.
  # For directory children (is_child=1), display_name should be the bare entry name.
  local final_name="$name"
  if [ -n "$display_name" ]; then
    final_name="$display_name"
  fi

  # blocks column: approximate GNU 1K blocks from BSD 512-blocks.
  local blocks1k
  blocks1k=$(( (b512 + 1) / 2 ))

  local owner group
  if [ "$NUMERICUIDGID" -eq 1 ]; then
    owner="$uid"
    group="$gid"
  else
    owner="$su"
    group="$sg"
  fi

  # Store raw name (for display), path (for stat/readlink), and is_child flag.
  rows+=("${blocks1k}${DELIM}${perms}${DELIM}${links}${DELIM}${owner}${DELIM}${group}${DELIM}${size}${DELIM}${epoch}${DELIM}${final_name}${DELIM}${path}${DELIM}${is_child}")
}

list_dir_contents() {
  local d="$1"

  # Best-effort: mimic ls default (no dotfiles).
  # Use /bin/ls for enumeration; do not rely on GNU extensions.
  local ls_dir="$d"
  if [[ "$ls_dir" == -* ]]; then
    ls_dir="./$ls_dir"
  fi
  local entry
  while IFS= read -r entry; do
    # entry is a bare name, may include spaces/tabs; preserve as-is.
    # Pass the full path for stat/readlink, but use bare entry name for display.
    a_push_row "${d%/}/$entry" "$entry" 1
  done < <(/bin/ls -1A "$ls_dir" 2>/dev/null | sed -E '/^\./d')
}

# Grouped output order: files first, then directories (like many ls builds). Keep simple: keep operand order.
# If operand is a directory and not -d, list its contents.
# If multiple directories are listed, print a header "dir:" between groups.

groups=()  # stores: "HDR<US><dir>" or "ROW<US><path>" markers

for op in "${ops[@]}"; do
  if [ "$LISTDIRECTORY" -eq 1 ]; then
    groups+=("ROW${DELIM}$op")
    continue
  fi

  if [ -d "$op" ] && [ ! -L "$op" ]; then
    groups+=("HDR${DELIM}$op")
  else
    groups+=("ROW${DELIM}$op")
  fi
done

# Collect rows in group-order.
# For HDR groups, optionally print headers later; collect rows for that directory.
# For ROW groups, collect that single path.

dir_markers=() # each marker: "<dir><US><start_index><US><end_index>"

for g in "${groups[@]}"; do
  kind="${g%%"${DELIM}"*}"
  val="${g#*"${DELIM}"}"

  if [ "$kind" = "ROW" ]; then
    a_push_row "$val"
  else
    # Directory expansion
    start_idx=${#rows[@]}
    list_dir_contents "$val"
    end_idx=${#rows[@]}
    dir_markers+=("${val}${DELIM}${start_idx}${DELIM}${end_idx}")
  fi
done

# If nothing collected, exit cleanly (but keep total for empty dirs).
if [ "${#rows[@]}" -eq 0 ]; then
  if [ "$total_applicable" -eq 1 ]; then
    printf '%s 0\n' "$total_label"
  fi
  exit 0
fi

# ------------------------------
# Compute widths
# ------------------------------
# Use awk to compute widths from the US-separated rows (safe w.r.t. names).
widths="$(
  printf '%s\n' "${rows[@]}" \
  | /usr/bin/awk -v FS="$DELIM" -v DELIM="$DELIM" -v ASIZE="$ASIZE" -v OWNER="$OWNER" -v GROUPNAME="$GROUPNAME" -v HUMAN="$HUMANREADABLE" -v SI="$SI" -v USERNAME="$USERNAME" -v NUMERIC="$NUMERICUIDGID" -v NOW_EPOCH="$NOW_EPOCH" -v DEC_SEP="$DEC_SEP" '
    function max(a,b){return (a>b)?a:b}
    BEGIN{w_blocks=0;w_perms=0;w_links=0;w_owner=0;w_group=0;w_size=0;w_tnum=0;w_tunit=0;any_fut=0}
    {
      blocks=$1; perms=$2; links=$3; owner=$4; group=$5; size=$6; epoch=$7

      if (ASIZE) {
        # Human-readable blocks width: mimic GNU ls -s -h (base-1024, K) or -s --si (base-1000, k)
        if (HUMAN && blocks ~ /^[0-9]+$/) {
          label=""
          bytes = blocks * 1024
          base = SI ? 1000 : 1024
          if (bytes < base) {
            label = "0B"
          } else if (bytes < base*base) {
            unit_str = SI ? "k" : "K"
            val = bytes / base
            label = sprintf("%.1f%s", val, unit_str)
          } else if (bytes < base*base*base) {
            val = bytes / (base*base)
            label = sprintf("%.1fM", val)
          } else if (bytes < base*base*base*base) {
            val = bytes / (base*base*base)
            label = sprintf("%.1fG", val)
          } else {
            val = bytes / (base*base*base*base)
            label = sprintf("%.1fT", val)
          }
          if (DEC_SEP != ".") {
            gsub(/\./, DEC_SEP, label)
          }
          w_blocks = max(w_blocks, length(label))
        } else {
          w_blocks = max(w_blocks, length(blocks))
        }
      }
      w_perms=max(w_perms, length(perms))
      w_links=max(w_links, length(links))

      if (OWNER) {
        o=owner
        if (!NUMERIC && USERNAME!="" && o==USERNAME) o="you"
        w_owner=max(w_owner, length(o))
      }
      if (GROUPNAME) w_group=max(w_group, length(group))

      if (HUMAN && size ~ /^[0-9]+$/) size=size"B"
      w_size=max(w_size, length(size))

      # time widths: prefix may be "in"
      # We keep conservative widths based on computed buckets.
      now = NOW_EPOCH
      if (now !~ /^[0-9]+$/) now = systime()
      dt = now - epoch
      abs=dt
      if (dt<0){abs=-dt; any_fut=1}
      if (abs<120){num=abs; unit="sec"}
      else if (abs<3600){num=int(abs/60); unit="min"}
      else if (abs<172800){num=int(abs/3600); unit="hrs"}
      else if (abs<3888000){num=int(abs/86400); unit="day"}
      else if (abs<31536000){num=int(abs/2592000); unit="mon"}
      else {num=int(abs/31536000); unit="yr"}

      w_tnum=max(w_tnum, length(num ""))
      w_tunit=max(w_tunit, length(unit))
    }
    END{printf "%d%s%d%s%d%s%d%s%d%s%d%s%d%s%d%s%d\n", w_blocks,DELIM,w_perms,DELIM,w_links,DELIM,w_owner,DELIM,w_group,DELIM,w_size,DELIM,any_fut,DELIM,w_tnum,DELIM,w_tunit}
  '
)"

IFS="$DELIM" read -r W_BLOCKS W_PERMS W_LINKS W_OWNER W_GROUP W_SIZE ANY_FUT W_TNUM W_TUNIT <<<"$widths"

lpad() {
  local s="$1" w="$2" len pad
  len="$(visible_len "$s")"
  if [ "$len" -ge "$w" ]; then
    printf '%s' "$s"
    return 0
  fi
  pad=$((w - len))
  printf '%*s%s' "$pad" "" "$s"
}

rpad() {
  local s="$1" w="$2" len pad
  len="$(visible_len "$s")"
  if [ "$len" -ge "$w" ]; then
    printf '%s' "$s"
    return 0
  fi
  pad=$((w - len))
  printf '%s%*s' "$s" "$pad" ""
}

# ------------------------------
# Print groups in requested order
# ------------------------------
print_row_by_index() {
  local idx="$1"

  local rec="${rows[$idx]}"
  local blocks perms links owner group size epoch name path is_child
  IFS="$DELIM" read -r blocks perms links owner group size epoch name path is_child <<<"$rec"

  # Owner substitution
  if [ "$NUMERICUIDGID" -eq 0 ] && [ -n "$USERNAME" ] && [ "$owner" = "$USERNAME" ]; then
    owner="you"
  fi

  # Colorize owner
  local owner_colored="$owner"
  if [ "$owner" = "you" ]; then
    owner_colored="${cusr}${owner}${creset}"
  elif [ "$owner" = "root" ]; then
    owner_colored="${croot}${owner}${creset}"
  fi

  # Size formatting/coloring
  local size_disp="$size"
  local size_colored
  if [ "$HUMANREADABLE" -eq 1 ]; then
    size_disp="$(human_size "$size")"
    size_colored="$(color_size_human "$size_disp")"
  else
    local c
    c="$(size_color_numeric "$size")"
    size_colored="${c}${size}${creset}"
  fi

  # Blocks formatting/coloring
  local blocks_colored=""
  if [ "$ASIZE" -eq 1 ]; then
    if [ "$HUMANREADABLE" -eq 1 ]; then
      local b_label b_colored
      b_label="$(blocks_human_label "$blocks" "$SI")"
      b_colored="$(color_size_human "$b_label")"
      blocks_colored="$(lpad "$b_colored" "$W_BLOCKS") "
    else
      blocks_colored="${cb}$(lpad "$blocks" "$W_BLOCKS")${creset} "
    fi
  fi

  # Time
  time_parts "$epoch"
  local num_s unit_s t_raw t_col value_width value_core value_field
  num_s="$TNUM"
  unit_s="$(rpad "$TUNIT" "$W_TUNIT")"
  if [ "$ANY_FUT" -eq 1 ]; then
    value_width=$((W_TNUM + 3))
  else
    value_width=$W_TNUM
  fi
  if [ "$TFUT" -eq 1 ]; then
    value_core="in $num_s"
  else
    value_core="$num_s"
  fi
  value_field="$(lpad "$value_core" "$value_width")"
  t_raw="${value_field} ${unit_s}"
  t_col="$(color_reltime "$t_raw" "$TUNIT" "$TFUT")"

  # Permissions
  local perms_col
  perms_col="$(color_perm "$perms")"

  # Name
  local name_out
  local name_suffix
  name_out="$(format_name "$name" "$perms" "$path")"
  name_suffix=""
  if [ "$(visible_len "$name_out")" -ge 200 ]; then
    name_suffix=$'\033[K'
  fi

  # Emit
  out=""
  if [ "$ASIZE" -eq 1 ]; then
    out+="$blocks_colored"
  fi
  out+="$(rpad "$perms_col" "$W_PERMS") "
  out+="$(lpad "$links" "$W_LINKS") "

  if [ "$OWNER" -eq 1 ]; then
    out+="$(rpad "$owner_colored" "$W_OWNER") "
  fi
  if [ "$GROUPNAME" -eq 1 ]; then
    out+="$(rpad "$group" "$W_GROUP") "
  fi

  out+="$(lpad "$size_colored" "$W_SIZE") "
  out+="${t_col} "
  out+="$name_out${name_suffix}"

  printf '%s\n' "$out"
}

# If multiple operands and we have directory groups, print headers like ls.
# We use dir_markers to identify which slices came from which dir.
printed_any=0

# First, print standalone ROW operands in operand order.
# Then, for directories, print header + slice.
# This is a simplified grouping that stays deterministic.

# Print ROW ops in order (including -d directories).
for g in "${groups[@]}"; do
  kind="${g%%"${DELIM}"*}"
  val="${g#*"${DELIM}"}"

  if [ "$kind" = "ROW" ]; then
    # Find matching row indices by path (we appended in the same order, so linear scan is ok).
    # Row format: blocks perms links owner group size epoch name path is_child
    for i in "${!rows[@]}"; do
      rec="${rows[$i]}"
      # Extract path (9th field, before is_child)
      row_path=""
      IFS="$DELIM" read -r _ _ _ _ _ _ _ _ row_path _ <<<"$rec" || true
      if [ "$row_path" = "$val" ]; then
        print_row_by_index "$i"
        printed_any=1
        break
      fi
    done
  fi
done

# Print directories (if any) in operand order.
for m in "${dir_markers[@]}"; do
  IFS="$DELIM" read -r d start end <<<"$m"
  if [ "$multiple" -eq 1 ]; then
    if [ "$printed_any" -eq 1 ]; then
      printf '\n'
    fi
    printf '%s:\n' "$d"
  fi

  for ((i=start; i<end; i++)); do
    print_row_by_index "$i"
  done

  if [ "$total_applicable" -eq 1 ]; then
    total_blocks=0
    for ((i=start; i<end; i++)); do
      rec="${rows[$i]}"
      IFS="$DELIM" read -r blocks _ <<<"$rec"
      total_blocks=$((total_blocks + blocks))
    done
    if [ "$ASIZE" -eq 1 ] && [ "$HUMANREADABLE" -eq 1 ]; then
      printf '%s %s\n' "$total_label" "$(blocks_total_label "$total_blocks" "$SI")"
    else
      printf '%s %s\n' "$total_label" "$total_blocks"
    fi
  fi

  printed_any=1

done

exit 0
