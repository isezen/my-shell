#!/usr/bin/env bash
# scripts/bin/ll_macos
# macOS-specific implementation of ll command
# Uses BSD utilities (ls, awk, stat) for macOS compatibility
# Usage: ll_macos [OPTIONS] [FILES...]
# macOS/BSD userland implementation for `ll`.
#
# Goals:
# - Provide a `ll_linux`-compatible *presentation* (colors, relative time buckets, quoting rules)
# - Use only macOS-default tools (BSD stat/ls/awk), no GNU coreutils required
# - Best-effort parity for the subset of flags used by the test-suite

set -euo pipefail

# ------------------------------
# Flag scan (subset)
# ------------------------------
ASIZE=0
HUMANREADABLE=0
SI=0
NUMERICUIDGID=0
OWNER=1
GROUPNAME=1
LISTDIRECTORY=0

# Robust scan: consider only options before `--`.
for arg in "$@"; do
  case "$arg" in
    --)
      break
      ;;

    --directory)
      LISTDIRECTORY=1
      ;;
    --human-readable)
      HUMANREADABLE=1
      ;;
    --si)
      HUMANREADABLE=1
      SI=1
      ;;
    --numeric-uid-gid)
      NUMERICUIDGID=1
      ;;
    --size)
      ASIZE=1
      ;;
    --no-group)
      GROUPNAME=0
      ;;

    -*)
      [ "$arg" = "-" ] && continue
      _flags=${arg#-}
      for ((i=0; i<${#_flags}; i++)); do
        case "${_flags:i:1}" in
          d) LISTDIRECTORY=1 ;;
          h) HUMANREADABLE=1 ;;
          n) NUMERICUIDGID=1 ;;
          g) OWNER=0 ;;
          G) GROUPNAME=0 ;;
          o) GROUPNAME=0 ;;
          s) ASIZE=1 ;;
          *) ;;
        esac
      done
      ;;
    *)
      ;;
  esac
done

NOW_EPOCH="${LL_NOW_EPOCH:-}"
if [[ ! "$NOW_EPOCH" =~ ^[0-9]+$ ]]; then
  NOW_EPOCH="$(date +%s)"
fi

USERNAME="$(id -un 2>/dev/null || printf '%s' "${USER:-}")"
DELIM=$'\037'
# NOTE: Filenames with literal newlines are out-of-scope (line-based records).

batch_push_rows() {
  # Batch stat call for multiple paths
  local paths=("$@")
  [ "${#paths[@]}" -eq 0 ] && return 0
  
  # Prepare paths for stat (escape leading dashes)
  local stat_paths=()
  for p in "${paths[@]}"; do
    if [[ "$p" == -* ]]; then
      stat_paths+=("./$p")
    else
      stat_paths+=("$p")
    fi
  done
  
  local stat_fmt="%b${DELIM}%Sp${DELIM}%l${DELIM}%Su${DELIM}%Sg${DELIM}%u${DELIM}%g${DELIM}%z${DELIM}%m${DELIM}%N${DELIM}%Y"
  local idx=0
  while IFS= read -r st; do
    [ "$idx" -ge "${#paths[@]}" ] && break
    if [ -z "$st" ]; then
      ((idx++))
      continue
    fi
    
    local b512 perms links su sg uid gid size epoch name linktgt target
    IFS="$DELIM" read -r b512 perms links su sg uid gid size epoch name linktgt <<<"$st"
    
    # Prefer %Y as link target (works for broken symlinks too).
    target="${linktgt:-}"

    # Backward-compat: if %Y is empty but %N contains "name -> target", split it.
    if [[ -z "$target" ]] && [[ "$perms" == l* ]] && [[ "$name" == *" -> "* ]]; then
      target="${name#* -> }"
      name="${name%% -> *}"
    fi
    if [[ "$name" == ./* ]]; then
      name="${name#./}"
    fi
    
    local blocks1k=$(( (b512 + 1) / 2 ))
    
    local owner group
    if [ "$NUMERICUIDGID" -eq 1 ]; then
      owner="$uid"
      group="$gid"
    else
      owner="$su"
      group="$sg"
    fi
    
    local path="${paths[$idx]}"
    local row_idx=${#rows[@]}
    # Fields: blocks perms links owner group size epoch name target path is_child
    rows+=("${blocks1k}${DELIM}${perms}${DELIM}${links}${DELIM}${owner}${DELIM}${group}${DELIM}${size}${DELIM}${epoch}${DELIM}${name}${DELIM}${target}${DELIM}${path}${DELIM}0")
    # Store mapping from path to row index for O(1) lookup
    row_index_map["$path"]=$row_idx
    ((idx++)) || true
  done < <(/usr/bin/stat -f "$stat_fmt" -- "${stat_paths[@]}" 2>/dev/null)
}

# ------------------------------
# FAST PATH (single directory operand)
# ------------------------------
# ll-perf scenario: one operand, directory, not -d. This is the hot path.
# Goal: minimize bash work + processes:
# - no /bin/ls
# - no readlink
# - no second awk input (names|paths)
# - one stat, one awk
# - parse symlink target from stat %N ("name -> target") when available
try_fastpath_single_dir() {
  # Preconditions:
  # - not --directory / -d
  # - single operand
  # - operand is a directory and not a symlink
  # - no multi-headers complexity
  if [ "$LISTDIRECTORY" -ne 0 ]; then
    return 1
  fi
  if [ "${#ops[@]}" -ne 1 ]; then
    return 1
  fi
  if [ ! -d "${ops[0]}" ] || [ -L "${ops[0]}" ]; then
    return 1
  fi

  # Locale knobs for labels/decimal
  local locale_hint="${LC_ALL:-${LANG:-}}"
  local total_label="total"
  local DEC_SEP="."
  case "$locale_hint" in
    tr*|TR*)
      total_label="toplam"
      DEC_SEP=","  # Turkish uses comma decimal
      ;;
  esac
  local total_applicable=1

  local d="${ops[0]}"

  # Move into directory so that:
  # - globbing excludes dotfiles by default (matches current behavior)
  # - stat %N prints just the entry name (not full path), which is what we want to display
  # - we avoid /bin/ls entirely
  (
    cd "$d" 2>/dev/null || exit 0
    shopt -s nullglob
    entries=( * )

    if [ "${#entries[@]}" -eq 0 ]; then
      if [ "$total_applicable" -eq 1 ]; then
        printf '%s 0\n' "$total_label"
      fi
      exit 0
    fi

    local stat_fmt="%b${DELIM}%Sp${DELIM}%l${DELIM}%Su${DELIM}%Sg${DELIM}%u${DELIM}%g${DELIM}%z${DELIM}%m${DELIM}%N${DELIM}%Y"

    # One stat + one awk (awk holds rows in arrays, computes widths, renders in END)
    # Force C locale for speed (stat+awk string handling is noticeably faster on macOS).
    LC_ALL=C /usr/bin/stat -f "$stat_fmt" -- "${entries[@]}" 2>/dev/null \
    | LC_ALL=C /usr/bin/awk \
    -v FS="$DELIM" \
    -v DELIM="$DELIM" \
    -v ASIZE="$ASIZE" -v OWNER="$OWNER" -v GROUPNAME="$GROUPNAME" -v HUMAN="$HUMANREADABLE" -v SI="$SI" \
    -v USERNAME="$USERNAME" -v NUMERIC="$NUMERICUIDGID" -v NOW_EPOCH="$NOW_EPOCH" -v DEC_SEP="$DEC_SEP" \
    -v TOTAL_LABEL="$total_label" -v TOTAL_APPLICABLE="$total_applicable" \
    '
    BEGIN {
      esc = sprintf("%c", 27)
      creset = esc "[0m"

      # ------------------------------------------
      # LS_COLORS (GNU ls compatible subset)
      # ------------------------------------------
      COL_DI = "01;34"
      COL_LN = "01;36"
      COL_EX = "01;32"
      COL_FI = "0"
      n_ext = 0
      # ext_re[i] = regex-escaped suffix pattern for ext_pat[i]

      if (ENVIRON["LS_COLORS"] != "") {
        n = split(ENVIRON["LS_COLORS"], parts, ":")
        for (i = 1; i <= n; i++) {
          split(parts[i], kv, "=")
          k = kv[1]; v = kv[2]
          if (k == "di") COL_DI = v
          else if (k == "ln") COL_LN = v
          else if (k == "ex") COL_EX = v
          else if (k == "fi") COL_FI = v
          else if (k ~ /^\*/) {
            ext_pat[++n_ext] = substr(k, 2)
            ext_re[n_ext] = re_escape(ext_pat[n_ext])
            ext_col[n_ext] = v
          }
        }
      }

      cd    = esc "[38;5;122m"
      cl    = esc "[38;5;190m"
      cr    = esc "[38;5;119m"
      cw    = esc "[38;5;216m"
      cx    = esc "[38;5;124m"
      cplus = esc "[38;5;129m"

      cusr  = esc "[38;5;66m"
      croot = esc "[38;5;160m"

      cb = esc "[38;5;240m"
      ck = esc "[38;5;250m"
      cm = esc "[38;5;117m"
      cg = esc "[38;5;208m"
      ct = esc "[38;5;160m"

      clT = esc "[1;38;5;167m"
      clG = esc "[1;38;5;220m"
      clM = esc "[1;38;5;123m"
      clK = esc "[1;38;5;107m"
      clB = esc "[1;38;5;248m"

      csec = esc "[38;5;124m"
      cmin = esc "[38;5;215m"
      chrs = esc "[38;5;196m"
      cday = esc "[38;5;230m"
      cmon = esc "[38;5;151m"
      cyr  = esc "[38;5;241m"
      cfut = esc "[38;5;39m"
    }
    function max(a,b){return (a>b)?a:b}
    function sp(n){ if (n<=0) return ""; return sprintf("%*s", n, "") }

    # Escape regex metacharacters so LS_COLORS "*.<ext>" rules
    # behave like suffix match (not regex wildcard match).
    function re_escape(s,   i,c,out) {
      out=""
      for (i=1; i<=length(s); i++) {
        c=substr(s,i,1)
        if (c ~ /[.[\]{}()*+?^$\\|]/) out = out "\\" c
        else out = out c
      }
      return out
    }

    # GNU-ls-ish priority:
    # - type class first (di/ln/ex/fi)
    # - extension rules apply only to regular, non-executable files
    # - if multiple extension rules match, LAST match wins
    function color_for_name(name, perms,   base, col, i) {
      # type first
      if (perms ~ /^d/)      base = COL_DI
      else if (perms ~ /^l/) base = COL_LN
      else if (perms ~ /x/)  base = COL_EX
      else                   base = COL_FI

      # extension only for regular non-exec (match linux behavior for *.sh vs ex)
      col = ""
      if (base == COL_FI) {
        for (i = 1; i <= n_ext; i++) {
          if (name ~ ext_re[i] "$") col = ext_col[i]
        }
      }
      if (col != "") return esc "[" col "m"
      return esc "[" base "m"
    }

    function quote_if_needed(s) {
      if (index(s, " ")>0 || index(s, "\t")>0) return "\"" s "\""
      return s
    }

    function color_perm(p,   i,ch,out) {
      out=""
      for (i=1;i<=length(p);i++) {
        ch=substr(p,i,1)
        if (ch=="d") out=out cd ch creset
        else if (ch=="l") out=out cl ch creset
        else if (ch=="r") out=out cr ch creset
        else if (ch=="w") out=out cw ch creset
        else if (ch=="x") out=out cx ch creset
        else if (ch=="+") out=out cplus ch creset
        else out=out ch
      }
      return out
    }

    function size_color_numeric(x) {
      if (x < 1024) return cb
      if (x < 1048576) return ck
      if (x < 1073741824) return cm
      if (x < 1099511627776) return cg
      return ct
    }

    function color_size_human(s,   num,suf,len) {
      if (s ~ /^[0-9]+$/) s = s "B"
      if (s ~ /^[0-9]+(\.[0-9]+)?[kKMGTTB]$/) {
        len = length(s)
        suf = substr(s, len, 1)
        num = substr(s, 1, len-1)
        if (suf=="T") return ct num creset clT suf creset
        if (suf=="G") return cg num creset clG suf creset
        if (suf=="M") return cm num creset clM suf creset
        if (suf=="K" || suf=="k") return ck num creset clK suf creset
        if (suf=="B") return cb num creset clB suf creset
      }
      return cb s creset
    }

    function human_size(bytes,   scaled) {
      if (bytes !~ /^[0-9]+$/) return bytes
      if (bytes < 1024) return bytes "B"
      if (bytes < 1048576) { scaled=sprintf("%.1f", bytes/1024.0); sub(/\.0$/,"",scaled); return scaled "K" }
      if (bytes < 1073741824) { scaled=sprintf("%.1f", bytes/1048576.0); sub(/\.0$/,"",scaled); return scaled "M" }
      if (bytes < 1099511627776) { scaled=sprintf("%.1f", bytes/1073741824.0); sub(/\.0$/,"",scaled); return scaled "G" }
      scaled=sprintf("%.1f", bytes/1099511627776.0); sub(/\.0$/,"",scaled); return scaled "T"
    }

    function blocks_human_label(blocks, si_mode,   bytes,base,unit,val) {
      if (blocks !~ /^[0-9]+$/) return blocks
      bytes = blocks * 1024
      base = si_mode ? 1000 : 1024
      if (bytes < base) return "0B"
      if (bytes < base*base) {
        unit = si_mode ? "k" : "K"
        val = sprintf("%.1f", bytes/base)
        if (DEC_SEP != ".") gsub(/\./, DEC_SEP, val)
        return val unit
      }
      if (bytes < base*base*base) { val=sprintf("%.1f", bytes/(base*base)); if (DEC_SEP!=".") gsub(/\./,DEC_SEP,val); return val "M" }
      if (bytes < base*base*base*base) { val=sprintf("%.1f", bytes/(base*base*base)); if (DEC_SEP!=".") gsub(/\./,DEC_SEP,val); return val "G" }
      val=sprintf("%.1f", bytes/(base*base*base*base)); if (DEC_SEP!=".") gsub(/\./,DEC_SEP,val); return val "T"
    }

    function time_calc(epoch,   dt,abs,v,lbl) {
      dt = int((NOW_EPOCH+0) - epoch)
      if (dt < 0) { abs = -dt; time_future=1 } else { abs=dt; time_future=0 }
      if (abs < 120) { v=abs; lbl="sec" }
      else if (abs < 3600) { v=int(abs/60); lbl="min" }
      else if (abs < 172800) { v=int(abs/3600); lbl="hrs" }
      else if (abs < 3888000) { v=int(abs/86400); lbl="day" }
      else if (abs < 31536000) { v=int(abs/2592000); lbl="mon" }
      else { v=int(abs/31536000); lbl="yr" }
      time_num=v; time_unit=lbl
    }

    function color_reltime(s, unit, is_future) {
      if (is_future) return cfut s creset
      if (unit=="sec") return csec s creset
      if (unit=="min") return cmin s creset
      if (unit=="hrs") return chrs s creset
      if (unit=="day") return cday s creset
      if (unit=="mon") return cmon s creset
      if (unit=="yr") return cyr s creset
      return s
    }

    {
      # stat fields
      b512=$1; perms=$2; links=$3; su=$4; sg=$5; uid=$6; gid=$7; size=$8; epoch=$9; nraw=$10; ltarget=$11

      # blocks in 1K
      blocks1k = int((b512 + 1) / 2)

      # owner/group selection
      owner = (NUMERIC ? uid : su)
      group = (NUMERIC ? gid : sg)

      if (!NUMERIC && USERNAME!="" && owner==USERNAME) owner="you"

      # Display name + optional symlink target.
      n_rows++
      display = nraw
      if (substr(display,1,2)=="./") display = substr(display,3)
      target = ltarget
      rows_blocks[n_rows]=blocks1k
      rows_perms[n_rows]=perms
      rows_links[n_rows]=links
      rows_owner[n_rows]=owner
      rows_group[n_rows]=group
      rows_size[n_rows]=size
      rows_epoch[n_rows]=epoch
      rows_name[n_rows]=display
      rows_target[n_rows]=target

      # Precompute expensive derived fields once (reuse in END).
      # time
      time_calc(epoch+0)
      rows_tnum[n_rows]=time_num
      rows_tunit[n_rows]=time_unit
      rows_tfut[n_rows]=time_future
      if (time_future) any_fut=1

      # size label (human)
      rows_szlab[n_rows]=""
      if (HUMAN && size ~ /^[0-9]+$/) rows_szlab[n_rows]=human_size(size)

      # widths pass
      w_perms = max(w_perms, length(perms))
      w_links = max(w_links, length(links))
      if (OWNER) w_owner = max(w_owner, length(owner))
      if (GROUPNAME) w_group = max(w_group, length(group))

      # size label width
      szlab = rows_szlab[n_rows]
      if (szlab != "") w_size = max(w_size, length(szlab))
      else w_size = max(w_size, length(size))

      # blocks label width (only if ASIZE)
      if (ASIZE) {
        if (HUMAN && blocks1k ~ /^[0-9]+$/) {
          blab = blocks_human_label(blocks1k, SI)
          rows_blab[n_rows]=blab
          w_blocks = max(w_blocks, length(blab))
        } else {
          rows_blab[n_rows]=""
          w_blocks = max(w_blocks, length(blocks1k ""))
        }
      }

      # time widths (use precomputed)
      w_tnum = max(w_tnum, length(rows_tnum[n_rows] ""))
      w_tunit = max(w_tunit, length(rows_tunit[n_rows]))

      # totals
      total_blocks += blocks1k
    }

    END {
      # render
      for (i=1;i<=n_rows;i++) {
        blocks=rows_blocks[i]
        perms=rows_perms[i]
        links=rows_links[i]
        owner=rows_owner[i]
        group=rows_group[i]
        size=rows_size[i]
        epoch=rows_epoch[i]
        name=rows_name[i]
        target=rows_target[i]

        # perms field
        perms_col = color_perm(perms)
        perms_field = perms_col sp(w_perms - length(perms))

        # links field
        links_field = sp(w_links - length(links)) links

        # owner field
        owner_field=""
        if (OWNER) {
          if (owner=="you") owner_col=cusr owner creset
          else if (owner=="root") owner_col=croot owner creset
          else owner_col=owner
          owner_field = owner_col sp(w_owner - length(owner)) " "
        }

        # group field
        group_field=""
        if (GROUPNAME) {
          group_field = group sp(w_group - length(group)) " "
        }

        # size field
        if (HUMAN && size ~ /^[0-9]+$/) {
          szlab = rows_szlab[i]
          szcol = color_size_human(szlab)
          size_field = sp(w_size - length(szlab)) szcol
        } else {
          c = size_color_numeric(size+0)
          szcol = c size creset
          size_field = sp(w_size - length(size)) szcol
        }

        # blocks field
        blocks_field=""
        if (ASIZE) {
          if (HUMAN && blocks ~ /^[0-9]+$/) {
            blab = rows_blab[i]
            if (blab == "") blab = blocks_human_label(blocks, SI)
            bcol = color_size_human(blab)
            blocks_field = sp(w_blocks - length(blab)) bcol " "
          } else {
            blocks_field = cb sp(w_blocks - length(blocks "")) (blocks "") creset " "
          }
        }

        # time field
        tnum = rows_tnum[i]
        tunit = rows_tunit[i]
        tfut = rows_tfut[i]
        num_s = sprintf("%d", tnum)
        value_width = any_fut ? (w_tnum + 3) : w_tnum
        value_core = tfut ? ("in " num_s) : num_s
        value_field = sp(value_width - length(value_core)) value_core
        unit_field = tunit sp(w_tunit - length(tunit))
        t_raw = value_field " " unit_field
        t_col = color_reltime(t_raw, tunit, tfut)

        # name field
        # Match ll_linux behavior: reset before starting filename color
        cname = color_for_name(name, perms)
        nout = cname quote_if_needed(name) creset
        if (perms ~ /^l/ && target != "") nout = nout " -> " quote_if_needed(target)

        name_suffix=""
        if (length(nout) >= 200) name_suffix = sprintf("%c[K", 27)

        out = ""
        if (ASIZE) out = out blocks_field
        out = out perms_field " " links_field " " owner_field group_field size_field " " t_col " " nout name_suffix
        print out
      }

      if (TOTAL_APPLICABLE+0 == 1) {
        # totals are printed by existing code only when directory listing, single operand, not -d
        # Keep behavior: print total even for empty already handled above.
        if (ASIZE+0==1 && HUMAN+0==1) {
          # reuse blocks_total_label logic roughly (keep simple; matches previous behavior closely)
          # For -h: rounded; for --si: ceiling; but totals are less performance critical.
          # We implement minimal, deterministic:
          #  -h: base=1024, unit K/M/G/T, rounded
          # --si: base=1000, unit k/M/G/T, ceiling
          bytes = total_blocks * 1024
          base = (SI+0) ? 1000 : 1024
          if (bytes < base) {
            tlabel = "0"
          } else if (bytes < base*base) {
            unit = (SI+0) ? "k" : "K"
            if (SI+0) val = int((bytes + base - 1)/base)
            else val = int((bytes/base) + 0.5)
            tlabel = val unit
          } else if (bytes < base*base*base) {
            div = base*base
            if (SI+0) val = int((bytes + div - 1)/div)
            else val = int((bytes/div) + 0.5)
            tlabel = val "M"
          } else if (bytes < base*base*base*base) {
            div = base*base*base
            if (SI+0) val = int((bytes + div - 1)/div)
            else val = int((bytes/div) + 0.5)
            tlabel = val "G"
          } else {
            div = base*base*base*base
            if (SI+0) val = int((bytes + div - 1)/div)
            else val = int((bytes/div) + 0.5)
            tlabel = val "T"
          }
          print TOTAL_LABEL " " tlabel
        } else {
          print TOTAL_LABEL " " total_blocks
        }
      }
    }
    '
  )

  return 0
}

# ------------------------------
# Collect operands (respect `--`)
# ------------------------------
opts=()
ops=()
seen_sep=0
for arg in "$@"; do
  if [ "$seen_sep" -eq 0 ] && [ "$arg" = "--" ]; then
    seen_sep=1
    continue
  fi
  if [ "$seen_sep" -eq 0 ] && [[ "$arg" == -* ]] && [ "$arg" != "-" ]; then
    opts+=("$arg")
  else
    ops+=("$arg")
  fi
done

# Default operand is "." like ls.
if [ "${#ops[@]}" -eq 0 ]; then
  ops=(".")
fi

# Try hot-path first (ll-perf case).
try_fastpath_single_dir && exit 0

# Determine if we have multiple operands (for directory headers).
multiple=0
if [ "${#ops[@]}" -gt 1 ]; then
  multiple=1
fi

total_label="total"
locale_hint="${LC_ALL:-${LANG:-}}"
DEC_SEP="."
case "$locale_hint" in
  tr*|TR*)
    total_label="toplam"
    DEC_SEP=","  # Turkish uses comma decimal
    ;;
esac

total_applicable=0
if [ "$LISTDIRECTORY" -eq 0 ] && [ "$multiple" -eq 0 ] && [ "${#ops[@]}" -eq 1 ]; then
  if [ -d "${ops[0]}" ] && [ ! -L "${ops[0]}" ]; then
    total_applicable=1
  fi
fi

# ------------------------------
# Build listing: expand directories (unless -d)
# ------------------------------
# Rows stored as US-separated fields to preserve names safely.
# Fields: blocks perms links owner group size epoch name target path is_child
rows=()
# Map from path to row index for O(1) lookup when printing ROW operands
declare -A row_index_map

list_dir_contents() {
  local d="$1"

  # Best-effort: mimic ls default (no dotfiles).
  # Use /bin/ls for enumeration; do not rely on GNU extensions.
  local ls_dir="$d"
  if [[ "$ls_dir" == -* ]]; then
    ls_dir="./$ls_dir"
  fi
  
  # Collect entries first, then batch stat
  local entries=()
  local entry
  while IFS= read -r entry; do
    entries+=("$entry")
  done < <(/bin/ls -1 "$ls_dir" 2>/dev/null)
  
  [ "${#entries[@]}" -eq 0 ] && return 0
  
  # Batch stat all entries
  local paths=()
  local display_names=()
  for entry in "${entries[@]}"; do
    paths+=("${d%/}/$entry")
    display_names+=("$entry")
  done
  
  local stat_fmt="%b${DELIM}%Sp${DELIM}%l${DELIM}%Su${DELIM}%Sg${DELIM}%u${DELIM}%g${DELIM}%z${DELIM}%m${DELIM}%N${DELIM}%Y"
  local idx=0
  while IFS= read -r st; do
    [ "$idx" -ge "${#paths[@]}" ] && break
    if [ -z "$st" ]; then
      ((idx++))
      continue
    fi
    
    local b512 perms links su sg uid gid size epoch name linktgt target
    IFS="$DELIM" read -r b512 perms links su sg uid gid size epoch name linktgt <<<"$st"
    
    target="${linktgt:-}"

    # Backward-compat fallback if %Y is empty but %N contains arrow.
    if [[ -z "$target" ]] && [[ "$perms" == l* ]] && [[ "$name" == *" -> "* ]]; then
      target="${name#* -> }"
      name="${name%% -> *}"
    fi
    if [[ "$name" == ./* ]]; then
      name="${name#./}"
    fi
    
    local blocks1k=$(( (b512 + 1) / 2 ))
    
    local owner group
    if [ "$NUMERICUIDGID" -eq 1 ]; then
      owner="$uid"
      group="$gid"
    else
      owner="$su"
      group="$sg"
    fi
    
    local display_name="${display_names[$idx]}"
    local path="${paths[$idx]}"
    rows+=("${blocks1k}${DELIM}${perms}${DELIM}${links}${DELIM}${owner}${DELIM}${group}${DELIM}${size}${DELIM}${epoch}${DELIM}${display_name}${DELIM}${target}${DELIM}${path}${DELIM}1")
    ((idx++)) || true
  done < <(/usr/bin/stat -f "$stat_fmt" -- "${paths[@]}" 2>/dev/null)
}

# Grouped output order: files first, then directories (like many ls builds). Keep simple: keep operand order.
# If operand is a directory and not -d, list its contents.
# If multiple directories are listed, print a header "dir:" between groups.

groups=()  # stores: "HDR<US><dir>" or "ROW<US><path>" markers

for op in "${ops[@]}"; do
  if [ "$LISTDIRECTORY" -eq 1 ]; then
    groups+=("ROW${DELIM}$op")
    continue
  fi

  if [ -d "$op" ] && [ ! -L "$op" ]; then
    groups+=("HDR${DELIM}$op")
  else
    groups+=("ROW${DELIM}$op")
  fi
done

# Collect rows in group-order.
# For HDR groups, optionally print headers later; collect rows for that directory.
# For ROW groups, collect that single path.

dir_markers=() # each marker: "<dir><US><start_index><US><end_index>"

# Batch stat calls for ROW operands
row_paths=()
for g in "${groups[@]}"; do
  kind="${g%%"${DELIM}"*}"
  val="${g#*"${DELIM}"}"
  if [ "$kind" = "ROW" ]; then
    row_paths+=("$val")
  fi
done

if [ "${#row_paths[@]}" -gt 0 ]; then
  batch_push_rows "${row_paths[@]}"
fi

# Process directory groups
for g in "${groups[@]}"; do
  kind="${g%%"${DELIM}"*}"
  val="${g#*"${DELIM}"}"

  if [ "$kind" = "HDR" ]; then
    # Directory expansion
    start_idx=${#rows[@]}
    list_dir_contents "$val"
    end_idx=${#rows[@]}
    dir_markers+=("${val}${DELIM}${start_idx}${DELIM}${end_idx}")
  fi
done

# If nothing collected, exit cleanly (but keep total for empty dirs).
if [ "${#rows[@]}" -eq 0 ]; then
  if [ "$total_applicable" -eq 1 ]; then
    printf '%s 0\n' "$total_label"
  fi
  exit 0
fi

# ------------------------------
# Compute widths
# ------------------------------
# Use awk to compute widths from the US-separated rows (safe w.r.t. names).
widths="$(
  printf '%s\n' "${rows[@]}" \
  | /usr/bin/awk -v FS="$DELIM" -v DELIM="$DELIM" -v ASIZE="$ASIZE" -v OWNER="$OWNER" -v GROUPNAME="$GROUPNAME" -v HUMAN="$HUMANREADABLE" -v SI="$SI" -v USERNAME="$USERNAME" -v NUMERIC="$NUMERICUIDGID" -v NOW_EPOCH="$NOW_EPOCH" -v DEC_SEP="$DEC_SEP" '
    function max(a,b){return (a>b)?a:b}
    BEGIN{w_blocks=0;w_perms=0;w_links=0;w_owner=0;w_group=0;w_size=0;w_tnum=0;w_tunit=0;any_fut=0}
    {
      blocks=$1; perms=$2; links=$3; owner=$4; group=$5; size=$6; epoch=$7

      if (ASIZE) {
        # Human-readable blocks width: mimic GNU ls -s -h (base-1024, K) or -s --si (base-1000, k)
        if (HUMAN && blocks ~ /^[0-9]+$/) {
          label=""
          bytes = blocks * 1024
          base = SI ? 1000 : 1024
          if (bytes < base) {
            label = "0B"
          } else if (bytes < base*base) {
            unit_str = SI ? "k" : "K"
            val = bytes / base
            label = sprintf("%.1f%s", val, unit_str)
          } else if (bytes < base*base*base) {
            val = bytes / (base*base)
            label = sprintf("%.1fM", val)
          } else if (bytes < base*base*base*base) {
            val = bytes / (base*base*base)
            label = sprintf("%.1fG", val)
          } else {
            val = bytes / (base*base*base*base)
            label = sprintf("%.1fT", val)
          }
          if (DEC_SEP != ".") {
            gsub(/\./, DEC_SEP, label)
          }
          w_blocks = max(w_blocks, length(label))
        } else {
          w_blocks = max(w_blocks, length(blocks))
        }
      }
      w_perms=max(w_perms, length(perms))
      w_links=max(w_links, length(links))

      if (OWNER) {
        o=owner
        if (!NUMERIC && USERNAME!="" && o==USERNAME) o="you"
        w_owner=max(w_owner, length(o))
      }
      if (GROUPNAME) w_group=max(w_group, length(group))

      if (HUMAN && size ~ /^[0-9]+$/) size=size"B"
      w_size=max(w_size, length(size))

      # time widths: prefix may be "in"
      # We keep conservative widths based on computed buckets.
      now = NOW_EPOCH + 0
      dt = now - epoch
      abs=dt
      if (dt<0){abs=-dt; any_fut=1}
      if (abs<120){num=abs; unit="sec"}
      else if (abs<3600){num=int(abs/60); unit="min"}
      else if (abs<172800){num=int(abs/3600); unit="hrs"}
      else if (abs<3888000){num=int(abs/86400); unit="day"}
      else if (abs<31536000){num=int(abs/2592000); unit="mon"}
      else {num=int(abs/31536000); unit="yr"}

      w_tnum=max(w_tnum, length(num ""))
      w_tunit=max(w_tunit, length(unit))
    }
    END{printf "%d%s%d%s%d%s%d%s%d%s%d%s%d%s%d%s%d\n", w_blocks,DELIM,w_perms,DELIM,w_links,DELIM,w_owner,DELIM,w_group,DELIM,w_size,DELIM,any_fut,DELIM,w_tnum,DELIM,w_tunit}
  '
)"

IFS="$DELIM" read -r W_BLOCKS W_PERMS W_LINKS W_OWNER W_GROUP W_SIZE ANY_FUT W_TNUM W_TUNIT <<<"$widths"


# ------------------------------
# Print groups in requested order (OPTIMIZED: single awk render pass)
# ------------------------------
# Render rows using single awk pass (OPTIMIZED - stream processing)
render_rows_awk() {
  local start_idx="$1"
  local end_idx="$2"
  local slice_len=$((end_idx - start_idx))
  
  # Render using awk (stream processing - no need to store all rows)
  printf '%s\n' "${rows[@]:start_idx:slice_len}" | /usr/bin/awk \
    -v FS="$DELIM" \
    -v DELIM="$DELIM" \
    -v ASIZE="$ASIZE" \
    -v OWNER="$OWNER" \
    -v GROUPNAME="$GROUPNAME" \
    -v HUMAN="$HUMANREADABLE" \
    -v SI="$SI" \
    -v USERNAME="$USERNAME" \
    -v NUMERIC="$NUMERICUIDGID" \
    -v NOW_EPOCH="$NOW_EPOCH" \
    -v DEC_SEP="$DEC_SEP" \
    -v W_BLOCKS="$W_BLOCKS" \
    -v W_PERMS="$W_PERMS" \
    -v W_LINKS="$W_LINKS" \
    -v W_OWNER="$W_OWNER" \
    -v W_GROUP="$W_GROUP" \
    -v W_SIZE="$W_SIZE" \
    -v ANY_FUT="$ANY_FUT" \
    -v W_TNUM="$W_TNUM" \
    -v W_TUNIT="$W_TUNIT" \
    '
    function sp(n,   s) { if (n <= 0) return ""; return sprintf("%*s", n, "") }
    # Escape regex metacharacters for LS_COLORS suffix rules
    function re_escape(s,   i,c,out) {
      out=""
      for (i=1; i<=length(s); i++) {
        c=substr(s,i,1)
        if (c ~ /[.[\]{}()*+?^$\\|]/) out = out "\\" c
        else out = out c
      }
      return out
    }
    BEGIN {
      esc = sprintf("%c", 27)
      creset = esc "[0m"

      # --------------------------------------------------
      # LS_COLORS support (GNU ls compatible subset)
      # --------------------------------------------------
      COL_DI = "01;34"
      COL_LN = "01;36"
      COL_EX = "01;32"
      COL_FI = "0"
      n_ext = 0
      # ext_re[i] = regex-escaped suffix pattern for ext_pat[i]

      if (ENVIRON["LS_COLORS"] != "") {
        n = split(ENVIRON["LS_COLORS"], parts, ":")
        for (i = 1; i <= n; i++) {
          split(parts[i], kv, "=")
          k = kv[1]
          v = kv[2]

          if (k == "di") COL_DI = v
          else if (k == "ln") COL_LN = v
          else if (k == "ex") COL_EX = v
          else if (k == "fi") COL_FI = v
          else if (k ~ /^\*/) {
            ext_pat[++n_ext] = substr(k, 2)
            ext_re[n_ext] = re_escape(ext_pat[n_ext])
            ext_col[n_ext] = v
          }
        }
      }

      cd    = esc "[38;5;122m"
      cl    = esc "[38;5;190m"
      cr    = esc "[38;5;119m"
      cw    = esc "[38;5;216m"
      cx    = esc "[38;5;124m"
      cplus = esc "[38;5;129m"

      cusr  = esc "[38;5;66m"
      croot = esc "[38;5;160m"

      cb = esc "[38;5;240m"
      ck = esc "[38;5;250m"
      cm = esc "[38;5;117m"
      cg = esc "[38;5;208m"
      ct = esc "[38;5;160m"

      clT = esc "[1;38;5;167m"
      clG = esc "[1;38;5;220m"
      clM = esc "[1;38;5;123m"
      clK = esc "[1;38;5;107m"
      clB = esc "[1;38;5;248m"

      csec = esc "[38;5;124m"
      cmin = esc "[38;5;215m"
      chrs = esc "[38;5;196m"
      cday = esc "[38;5;230m"
      cmon = esc "[38;5;151m"
      cyr  = esc "[38;5;241m"
      cfut = esc "[38;5;39m"
    }
    # STREAM RENDER: each input row is already in the right slice
    {
      # Fields: blocks perms links owner group size epoch name target path is_child
      blocks=$1; perms=$2; links=$3; owner=$4; group=$5; size=$6; epoch=$7; name=$8; target=$9; path=$10;
      
      # Owner substitution
      if (!NUMERIC && USERNAME != "" && owner == USERNAME) owner = "you"
      
      # Colorize owner
      if (owner == "you") owner_colored = cusr owner creset
      else if (owner == "root") owner_colored = croot owner creset
      else owner_colored = owner
      
      # Size formatting/coloring
      if (HUMAN && size ~ /^[0-9]+$/) {
        size_disp = human_size(size)
        size_colored = color_size_human(size_disp)
      } else {
        c = size_color_numeric(size + 0)
        size_colored = c size creset
      }
      
      # Blocks formatting/coloring
      blocks_colored = ""
      if (ASIZE) {
        if (HUMAN && blocks ~ /^[0-9]+$/) {
          b_label = blocks_human_label(blocks, SI)
          b_colored = color_size_human(b_label)
          b_pad = W_BLOCKS - length(b_label)
          blocks_colored = sp(b_pad) b_colored " "
        } else {
          b_pad = W_BLOCKS - length(blocks)
          blocks_colored = cb sp(b_pad) blocks creset " "
        }
      }
      
      # Time formatting
      time_calc(epoch + 0)
      num_s = sprintf("%d", time_num)
      unit_pad = W_TUNIT - length(time_unit)
      unit_s = time_unit sp(unit_pad)
      value_width = ANY_FUT ? (W_TNUM + 3) : W_TNUM
      value_core = time_future ? ("in " num_s) : num_s
      value_pad = value_width - length(value_core)
      value_field = sp(value_pad) value_core
      t_raw = value_field " " unit_s
      t_colored = color_reltime(t_raw, time_unit, time_future)
      
      # Permissions coloring
      perms_colored = color_perm(perms)
      perms_pad = W_PERMS - length(perms)
      perms_field = perms_colored sp(perms_pad)
      
      # Name formatting (symlink target comes from stat %N; no readlink spawns)
      name_out = format_name(name, perms, target)
      name_suffix = ""
      name_len = length(name_out)
      if (name_len >= 200) name_suffix = sprintf("%c[K", 27)
      
      # Links: left-pad using raw length
      links_pad = W_LINKS - length(links)
      links_field = sp(links_pad) links
      
      # Owner/group: right-pad using raw length (after "you" substitution)
      owner_field = ""
      if (OWNER) {
        owner_pad = W_OWNER - length(owner)
        owner_field = owner_colored sp(owner_pad) " "
      }
      group_field = ""
      if (GROUPNAME) {
        group_pad = W_GROUP - length(group)
        group_field = group sp(group_pad) " "
      }
      
      # Size: left-pad using display label length (human vs numeric)
      size_label = (HUMAN && size ~ /^[0-9]+$/) ? size_disp : size
      size_pad = W_SIZE - length(size_label)
      size_field = sp(size_pad) size_colored
      
      out = ""
      if (ASIZE) out = out blocks_colored
      out = out perms_field " "
      out = out links_field " "
      out = out owner_field
      out = out group_field
      out = out size_field " "
      out = out t_colored " "
      out = out name_out name_suffix
      print out
    }
    
    # GNU-ls-ish priority:
    # - type class first (di/ln/ex/fi)
    # - extension rules apply only to regular, non-executable files
    # - if multiple extension rules match, LAST match wins
    function color_for_name(name, perms,   base, col, i) {
      # type first
      if (perms ~ /^d/)      base = COL_DI
      else if (perms ~ /^l/) base = COL_LN
      else if (perms ~ /x/)  base = COL_EX
      else                   base = COL_FI

      # extension only for regular non-exec (match linux behavior for *.sh vs ex)
      col = ""
      if (base == COL_FI) {
        for (i = 1; i <= n_ext; i++) {
          if (name ~ ext_re[i] "$") col = ext_col[i]
        }
      }
      if (col != "") return esc "[" col "m"
      return esc "[" base "m"
    }

    function quote_if_needed(s) {
      if (index(s, " ") > 0 || index(s, "\t") > 0) return "\"" s "\""
      return s
    }

    function format_name(name, perms, target) {
      cname = color_for_name(name, perms)
      if (perms ~ /^l/ && target != "") {
        # Match ll_linux behavior: reset before starting filename color
        return cname quote_if_needed(name) creset \
              " -> " quote_if_needed(target)
      }
      return cname quote_if_needed(name) creset
    }
    
    function color_perm(p,   i, ch, out) {
      out = ""
      for (i=1; i<=length(p); i++) {
        ch = substr(p, i, 1)
        if (ch == "d") out = out cd ch creset
        else if (ch == "l") out = out cl ch creset
        else if (ch == "r") out = out cr ch creset
        else if (ch == "w") out = out cw ch creset
        else if (ch == "x") out = out cx ch creset
        else if (ch == "+") out = out cplus ch creset
        else out = out ch
      }
      return out
    }
    
    function size_color_numeric(x) {
      if (x < 1024) return cb
      if (x < 1048576) return ck
      if (x < 1073741824) return cm
      if (x < 1099511627776) return cg
      return ct
    }
    
    function color_size_human(s,   num, suf, pos, len) {
      if (s ~ /^[0-9]+$/) s = s "B"
      # BSD awk compatible: extract number and suffix manually
      if (s ~ /^[0-9]+(\.[0-9]+)?[kKMGTTB]$/) {
        # Find the suffix (last character)
        len = length(s)
        suf = substr(s, len, 1)
        # Extract number part (everything except suffix)
        num = substr(s, 1, len - 1)
        if (suf == "T") return ct num creset clT suf creset
        if (suf == "G") return cg num creset clG suf creset
        if (suf == "M") return cm num creset clM suf creset
        if (suf == "K" || suf == "k") return ck num creset clK suf creset
        if (suf == "B") return cb num creset clB suf creset
      }
      return cb s creset
    }
    
    function human_size(bytes,   unit, scaled) {
      if (bytes !~ /^[0-9]+$/) return bytes
      if (bytes < 1024) return bytes "B"
      if (bytes < 1048576) {
        scaled = sprintf("%.1f", bytes / 1024.0)
        gsub(/\.0$/, "", scaled)
        return scaled "K"
      }
      if (bytes < 1073741824) {
        scaled = sprintf("%.1f", bytes / 1048576.0)
        gsub(/\.0$/, "", scaled)
        return scaled "M"
      }
      if (bytes < 1099511627776) {
        scaled = sprintf("%.1f", bytes / 1073741824.0)
        gsub(/\.0$/, "", scaled)
        return scaled "G"
      }
      scaled = sprintf("%.1f", bytes / 1099511627776.0)
      gsub(/\.0$/, "", scaled)
      return scaled "T"
    }
    
    function blocks_human_label(blocks, si_mode,   bytes, base, unit, val, out) {
      if (blocks !~ /^[0-9]+$/) return blocks
      bytes = blocks * 1024
      base = si_mode ? 1000 : 1024
      if (bytes < base) return "0B"
      if (bytes < base*base) {
        unit = si_mode ? "k" : "K"
        val = sprintf("%.1f", bytes / base)
        if (DEC_SEP != ".") gsub(/\./, DEC_SEP, val)
        return val unit
      }
      if (bytes < base*base*base) {
        val = sprintf("%.1f", bytes / (base*base))
        if (DEC_SEP != ".") gsub(/\./, DEC_SEP, val)
        return val "M"
      }
      if (bytes < base*base*base*base) {
        val = sprintf("%.1f", bytes / (base*base*base))
        if (DEC_SEP != ".") gsub(/\./, DEC_SEP, val)
        return val "G"
      }
      val = sprintf("%.1f", bytes / (base*base*base*base))
      if (DEC_SEP != ".") gsub(/\./, DEC_SEP, val)
      return val "T"
    }
    
    function time_calc(epoch,   dt, now, prefix, abs, v, lbl) {
      now = NOW_EPOCH + 0
      dt = int(now - epoch)
      if (dt < 0) { prefix = "in"; abs = -dt } else { prefix = ""; abs = dt }
      if (abs < 120) { v = abs; lbl = "sec" }
      else if (abs < 3600) { v = int(abs/60); lbl = "min" }
      else if (abs < 172800) { v = int(abs/3600); lbl = "hrs" }
      else if (abs < 3888000) { v = int(abs/86400); lbl = "day" }
      else if (abs < 31536000) { v = int(abs/2592000); lbl = "mon" }
      else { v = int(abs/31536000); lbl = "yr" }
      time_prefix = prefix
      time_num = v
      time_unit = lbl
      time_future = (prefix != "")
    }
    
    function color_reltime(s, unit, is_future) {
      if (is_future) return cfut s creset
      if (unit == "sec") return csec s creset
      if (unit == "min") return cmin s creset
      if (unit == "hrs") return chrs s creset
      if (unit == "day") return cday s creset
      if (unit == "mon") return cmon s creset
      if (unit == "yr") return cyr s creset
      return s
    }
    '
}

# If multiple operands and we have directory groups, print headers like ls.
# We use dir_markers to identify which slices came from which dir.
printed_any=0

# First, print standalone ROW operands in operand order.
# Then, for directories, print header + slice.
# This is a simplified grouping that stays deterministic.

# Print ROW ops in order (including -d directories).
for g in "${groups[@]}"; do
  kind="${g%%"${DELIM}"*}"
  val="${g#*"${DELIM}"}"

  if [ "$kind" = "ROW" ]; then
    # Use stored index mapping for O(1) lookup instead of O(n) scan
    if [ -n "${row_index_map["$val"]:-}" ]; then
      idx="${row_index_map["$val"]}"
      render_rows_awk "$idx" "$((idx + 1))"
      printed_any=1
    fi
  fi
done

# Print directories (if any) in operand order.
for m in "${dir_markers[@]}"; do
  IFS="$DELIM" read -r d start end <<<"$m"
  if [ "$multiple" -eq 1 ]; then
    if [ "$printed_any" -eq 1 ]; then
      printf '\n'
    fi
    printf '%s:\n' "$d"
  fi

  render_rows_awk "$start" "$end"

  if [ "$total_applicable" -eq 1 ]; then
    total_blocks=0
    for ((i=start; i<end; i++)); do
      rec="${rows[$i]}"
      IFS="$DELIM" read -r blocks _ <<<"$rec"
      total_blocks=$((total_blocks + blocks))
    done
    if [ "$ASIZE" -eq 1 ] && [ "$HUMANREADABLE" -eq 1 ]; then
      printf '%s %s\n' "$total_label" "$(blocks_total_label "$total_blocks" "$SI")"
    else
      printf '%s %s\n' "$total_label" "$total_blocks"
    fi
  fi

  printed_any=1

done

exit 0
