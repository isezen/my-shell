#!/bin/bash
# scripts/dev/ll-compare
# Test script to compare ll script outputs
# Tests various parameter combinations
# Usage: test-ll-compare.sh <script1> <script2> [script3 ...]

# ============================================================================
# NOTE: Additional content/fixture tests to add later (not implemented here)
# ============================================================================
# - Filenames:
#   - Spaces: "a b.txt"
#   - Leading space: " file"
#   - Tab: $'a\tb'
#   - Unicode: "İçerik-ğüşöç.txt"
#   - Very long name (200+ chars)
#   - Newline in name (will break line-based parsing): $'a\nb'
# - File types:
#   - Symlink and broken symlink ("name -> target")
#   - FIFO, socket, block/char device (permission type chars p,s,b,c)
# - Permissions:
#   - setuid/setgid/sticky (s,S,t,T)
#   - ACL indicator '+' in perms
# - Timestamps:
#   - Very recent (sec/min), hours, days, months, years
#   - Future mtime (negative relative delta)
# - Scale/perf:
#   - Large dir (10k+ entries)
#   - Slow FS (NFS/SMB)
# - Environment:
#   - TTY vs pipe, different TERM/LANG
#   - GNU ls vs BSD ls compatibility checks

PROJECT_ROOT="$(cd "$(dirname "$0")/../.." && pwd)"
BIN_DIR="$PROJECT_ROOT/scripts/bin"

export LC_ALL=C
export TZ=UTC

# ============================================================================
# PARSE COMMAND LINE ARGUMENTS
# ============================================================================

# Optional flags:
#   --show-ansi : make ANSI/control chars visible in side-by-side diff output.
#   --fail-only : only print failing tests (still prints final summary).
#   --keep-dir  : do not delete test directory after tests complete.
#   --side-by-side : display outputs side-by-side (default: vertical/stacked format).
#   --help      : show help message and exit.
# Flags can be provided in any order, and can be combined.
ONLY_TESTS=()
ONLY_MODE=0
SHOW_ANSI=0
FAIL_ONLY=0
KEEP_DIR=0
SIDE_BY_SIDE=0
while [ $# -gt 0 ]; do
  case "${1:-}" in
    --help|-h)
      cat <<EOF
Usage: $0 [OPTIONS] <script1> <script2> [script3 ...]

Compare ll script outputs. At least two scripts are required for comparison.

OPTIONS:
  --help, -h              Show this help message and exit
  
  --show-ansi             Make ANSI/control characters visible in side-by-side
                          diff output (useful for debugging color/formatting issues)
  
  --fail-only             Only print failing tests (still prints final summary)
  
  --keep-dir              Do not delete test directory after tests complete
                          (useful for debugging - test directory path is shown at start)
  
  --side-by-side          Display outputs side-by-side format
                          (default: vertical/stacked format where each output is
                          shown below the previous one)
  
  --only <TEST>           Run only specific test case(s). Can be specified multiple times.
                          Value can be either:
                          - Test case name (must match exactly)
                          - Test number (e.g., 22 for Test #22)
                          Example: --only "default" --only "-s -h" --only 22
  
  --only=<TEST>           Same as --only but using equals syntax.
                          Example: --only="-s -h" --only="default" --only=22

EXAMPLES:
  # Compare two scripts
  $0 ll ll-chatgpt
  
  # Compare multiple scripts
  $0 ll ll-chatgpt ll2
  
  # Show only failing tests in side-by-side format
  $0 --fail-only --side-by-side ll ll-chatgpt
  
  # Run only specific test cases (by name or number)
  $0 --only "default" --only "-s -h" --only 22 ll ll-chatgpt
  
  # Keep test directory for inspection
  $0 --keep-dir ll ll-chatgpt

OUTPUT FORMATS:
  Default (vertical/stacked):
    Test #1: default
    ----------------------------------
      ll:
      [script output]
      
      ll-chatgpt:
      [script output]
  
  With --side-by-side:
    Test #1: default
    ----------------------------------
      Side-by-side comparison:
      [script1 output] | [script2 output]

EOF
      exit 0
      ;;
    --show-ansi)
      SHOW_ANSI=1
      shift
      ;;
    --fail-only)
      FAIL_ONLY=1
      shift
      ;;
    --keep-dir)
      KEEP_DIR=1
      shift
      ;;
    --side-by-side)
      SIDE_BY_SIDE=1
      shift
      ;;
    --only)
      # Filter to only run specific test cases. Value must match the test_case string.
      if [ $# -lt 2 ] || [ -z "${2:-}" ]; then
        echo "Error: --only requires a value" >&2
        exit 2
      fi
      ONLY_MODE=1
      ONLY_TESTS+=("$2")
      shift 2
      ;;
    --only=*)
      # Support --only="-s -h" style.
      ONLY_MODE=1
      ONLY_TESTS+=("${1#--only=}")
      shift
      ;;
    *)
      break
      ;;
  esac
done

if [ $# -lt 2 ]; then
  echo "Usage: $0 [OPTIONS] <script1> <script2> [script3 ...]" >&2
  echo "At least two scripts are required for comparison." >&2
  echo "Use --help for more information." >&2
  exit 1
fi

# Store script names and validate they exist
script_names=()
script_paths=()
for script_name in "$@"; do
  script_path="$BIN_DIR/$script_name"
  if [ ! -f "$script_path" ] || [ ! -x "$script_path" ]; then
    echo "Error: Script '$script_name' not found or not executable in $BIN_DIR" >&2
    exit 1
  fi
  script_names+=("$script_name")
  script_paths+=("$script_path")
done

# ============================================================================
# SETUP TEST ENVIRONMENT
# ============================================================================
TEST_DIR="/tmp/ll-compare-test-$$"
mkdir -p "$TEST_DIR"
echo "Test directory: $TEST_DIR"
cd "$TEST_DIR" || exit 1

# Create test files (baseline)
touch file1.txt file2.txt
mkdir dir1
chmod 755 file1.txt
chmod 644 file2.txt

# Additional filename fixtures
# NOTE: These are intentionally tricky for whitespace-based parsers.
# We disable normalization for tests that use these.
touch "a b.txt"
touch " file-leading-space.txt"
# Tab in filename
printf '' > $'a\tb.txt'
# Unicode filename
printf '' > $'İçerik-ğüşöç.txt'
# Very long name (210 chars + .txt)
_long_name="$(printf 'a%.0s' {1..210}).txt"
printf '' > "$_long_name"

# Symlink fixtures
ln -s file1.txt symlink-to-file1
ln -s does-not-exist broken-symlink

# FIFO fixture (may fail on some restricted FS; ignore errors)
mkfifo fifo1 2>/dev/null || true

# Permission edge cases
printf '' > setuid-file
chmod 755 setuid-file
chmod u+s setuid-file 2>/dev/null || true
printf '' > setgid-file
chmod 755 setgid-file
chmod 2755 setgid-file 2>/dev/null || true

mkdir -p setgid-dir sticky-dir
chmod 2755 setgid-dir 2>/dev/null || true
chmod 1777 sticky-dir 2>/dev/null || true

# Timestamp fixtures: deterministic + boundary coverage
# We freeze "now" via LL_NOW_EPOCH below, then set file mtimes relative to it.

# Make baseline mtimes deterministic (Jan 1, 2020 00:00:00 local time).
touch -t 202001010000.00 file1.txt file2.txt dir1 \
  "a b.txt" " file-leading-space.txt" $'a\tb.txt' $'İçerik-ğüşöç.txt' \
  "$_long_name" symlink-to-file1 broken-symlink \
  fifo1 setuid-file setgid-file setgid-dir sticky-dir || true

# Symlink target with space.
mkdir -p "case-symlink-target-space"
printf "space" > "case-symlink-target-space/target file.txt"
ln -s "target file.txt" "case-symlink-target-space/link name.txt" 2>/dev/null || true
touch -t 202001010000.00 "case-symlink-target-space/target file.txt" 2>/dev/null || true
touch -h -t 202001010000.00 "case-symlink-target-space/link name.txt" 2>/dev/null || true

# Symlink target with tab.
mkdir -p "case-symlink-target-tab"
_tab_target=$'t\ta'
_tab_link=$'l\ti'
printf "tab" > "case-symlink-target-tab/$_tab_target"
ln -s "$_tab_target" "case-symlink-target-tab/$_tab_link" 2>/dev/null || true
touch -t 202001010000.00 "case-symlink-target-tab/$_tab_target" 2>/dev/null || true
touch -h -t 202001010000.00 "case-symlink-target-tab/$_tab_link" 2>/dev/null || true

# Make relative-time computations deterministic between scripts by freezing “now”.
# If the caller already set LL_NOW_EPOCH, respect it.
_ORIG_LL_NOW_EPOCH_SET=0
_ORIG_LL_NOW_EPOCH_VALUE=""
if [ "${LL_NOW_EPOCH+x}" = "x" ]; then
  _ORIG_LL_NOW_EPOCH_SET=1
  _ORIG_LL_NOW_EPOCH_VALUE="$LL_NOW_EPOCH"
else
  export LL_NOW_EPOCH
  LL_NOW_EPOCH=1577836800
fi

# Helper: convert an epoch (seconds) into a touch -t timestamp (local time).
# macOS: date -r <epoch>
# GNU:   date -d @<epoch>
epoch_to_touch_ts() {
  local epoch="${1:?epoch required}"
  if date -r "$epoch" +%Y%m%d%H%M.%S >/dev/null 2>&1; then
    date -r "$epoch" +%Y%m%d%H%M.%S
    return 0
  fi
  if date -d "@${epoch}" +%Y%m%d%H%M.%S >/dev/null 2>&1; then
    date -d "@${epoch}" +%Y%m%d%H%M.%S
    return 0
  fi
  return 1
}

# Create timestamp boundary fixtures relative to LL_NOW_EPOCH.
# These are used to validate bucket transitions (sec/min/hour/day) deterministically.
create_mtime_fixture() {
  local name="${1:?name required}"
  local delta="${2:?delta seconds required}"
  local target_epoch=$((LL_NOW_EPOCH - delta))
  local ts
  ts=$(epoch_to_touch_ts "$target_epoch") || return 0
  printf '' > "$name"
  touch -t "$ts" "$name" 2>/dev/null || true
}

create_future_mtime_fixture() {
  local name="${1:?name required}"
  local delta="${2:?delta seconds required}"
  local target_epoch=$((LL_NOW_EPOCH + delta))
  local ts
  ts=$(epoch_to_touch_ts "$target_epoch") || return 0
  printf '' > "$name"
  touch -t "$ts" "$name" 2>/dev/null || true
}

create_mtime_fixture "mtime-now-1s" 1
create_mtime_fixture "mtime-now-119s" 119
create_mtime_fixture "mtime-now-120s" 120
create_mtime_fixture "mtime-now-3599s" 3599
create_mtime_fixture "mtime-now-3600s" 3600
create_mtime_fixture "mtime-now-2days" 172800
create_future_mtime_fixture "mtime-now-3yr" $((3 * 31536000))
create_future_mtime_fixture "mtime-now-35yr" $((35 * 31536000))
create_future_mtime_fixture "mtime-now-125yr" $((125 * 31536000))

# Additional edge-case directories (ls-compare parity).
_now_epoch="${LL_NOW_EPOCH:-$(date +%s)}"

# Future-only listing.
mkdir -p "case-future-only"
printf '' > "case-future-only/f1.txt"
printf '' > "case-future-only/f2.txt"
_f1_epoch=$((_now_epoch + 2 * 24 * 3600))
_f2_epoch=$((_now_epoch + 12 * 24 * 3600))
_f1_ts=$(epoch_to_touch_ts "$_f1_epoch") || _f1_ts=""
_f2_ts=$(epoch_to_touch_ts "$_f2_epoch") || _f2_ts=""
if [ -n "$_f1_ts" ]; then
  touch -t "$_f1_ts" "case-future-only/f1.txt" 2>/dev/null || true
fi
if [ -n "$_f2_ts" ]; then
  touch -t "$_f2_ts" "case-future-only/f2.txt" 2>/dev/null || true
fi

# Mixed units and time widths.
mkdir -p "case-mixed-time-width"
printf '' > "case-mixed-time-width/sec.txt"
printf '' > "case-mixed-time-width/hrs.txt"
printf '' > "case-mixed-time-width/day.txt"
printf '' > "case-mixed-time-width/mon.txt"
printf '' > "case-mixed-time-width/future-3yr.txt"
printf '' > "case-mixed-time-width/future-35yr.txt"
printf '' > "case-mixed-time-width/future-125yr.txt"
printf '' > "case-mixed-time-width/future-1000yr.txt"
_sec_epoch=$((_now_epoch - 5))
_hrs_epoch=$((_now_epoch - 3 * 3600))
_day_epoch=$((_now_epoch - 12 * 24 * 3600))
_mon_epoch=$((_now_epoch - 120 * 24 * 3600))
_yr3_epoch=$((_now_epoch + 3 * 31536000))
_yr35_epoch=$((_now_epoch + 35 * 31536000))
_yr125_epoch=$((_now_epoch + 125 * 31536000))
_yr1000_epoch=$((_now_epoch + 1000 * 31536000))
_sec_ts=$(epoch_to_touch_ts "$_sec_epoch") || _sec_ts=""
_hrs_ts=$(epoch_to_touch_ts "$_hrs_epoch") || _hrs_ts=""
_day_ts=$(epoch_to_touch_ts "$_day_epoch") || _day_ts=""
_mon_ts=$(epoch_to_touch_ts "$_mon_epoch") || _mon_ts=""
_yr3_ts=$(epoch_to_touch_ts "$_yr3_epoch") || _yr3_ts=""
_yr35_ts=$(epoch_to_touch_ts "$_yr35_epoch") || _yr35_ts=""
_yr125_ts=$(epoch_to_touch_ts "$_yr125_epoch") || _yr125_ts=""
_yr1000_ts=$(epoch_to_touch_ts "$_yr1000_epoch") || _yr1000_ts=""
if [ -n "$_sec_ts" ]; then
  touch -t "$_sec_ts" "case-mixed-time-width/sec.txt" 2>/dev/null || true
fi
if [ -n "$_hrs_ts" ]; then
  touch -t "$_hrs_ts" "case-mixed-time-width/hrs.txt" 2>/dev/null || true
fi
if [ -n "$_day_ts" ]; then
  touch -t "$_day_ts" "case-mixed-time-width/day.txt" 2>/dev/null || true
fi
if [ -n "$_mon_ts" ]; then
  touch -t "$_mon_ts" "case-mixed-time-width/mon.txt" 2>/dev/null || true
fi
if [ -n "$_yr3_ts" ]; then
  touch -t "$_yr3_ts" "case-mixed-time-width/future-3yr.txt" 2>/dev/null || true
fi
if [ -n "$_yr35_ts" ]; then
  touch -t "$_yr35_ts" "case-mixed-time-width/future-35yr.txt" 2>/dev/null || true
fi
if [ -n "$_yr125_ts" ]; then
  touch -t "$_yr125_ts" "case-mixed-time-width/future-125yr.txt" 2>/dev/null || true
fi
if [ -n "$_yr1000_ts" ]; then
  touch -t "$_yr1000_ts" "case-mixed-time-width/future-1000yr.txt" 2>/dev/null || true
fi

# ============================================================================
# TEST CASES
# ============================================================================
# Format: NAME|||ARGV|||NO_NORMALIZE
# - NAME: label shown in output.
# - ARGV: a shell-quoted argv string. It is expanded with: eval "tc_argv=(...)".
# - NO_NORMALIZE: "1" to disable normalization for this test (useful for filenames with
#   spaces/tabs where whitespace squeezing would be destructive).

test_cases=(
  "default||| |||0"

  # Directory listing behavior
  "-d||| -d |||0"
  "--directory||| --directory |||0"
  "-d .||| -d . |||0"

  # Owner/group toggles
  "-g||| -g |||0"
  "-G||| -G |||0"
  "-o||| -o |||0"
  "--no-group||| --no-group |||0"
  "-g -G||| -g -G |||0"

  # Size column (allocated blocks)
  "-s||| -s |||0"
  "--size||| --size |||0"

  # Human readable size variants
  "-h||| -h |||0"
  "--human-readable||| --human-readable |||0"
  "--si||| --si |||0"

  # Numeric uid/gid
  "-n||| -n |||0"
  "--numeric-uid-gid||| --numeric-uid-gid |||0"

  # Cross-combinations (core)
  "-s -h||| -s -h |||0"
  "-s --si||| -s --si |||0"
  "-n -h||| -n -h |||0"
  "-n --si||| -n --si |||0"
  "-s -g||| -s -g |||0"
  "-s -h -g -G||| -s -h -g -G |||0"

  # Option ordering: flags after operands (your ll-chatgpt scanner is supposed to support this)
  "file then --no-group||| file1.txt --no-group |||0"
  "file then -G||| file1.txt -G |||0"
  "--no-group then file||| --no-group file1.txt |||0"

  # Targeted path arguments
  "-h file1.txt||| -h file1.txt |||0"
  "--no-group file2.txt||| --no-group file2.txt |||0"

  # Filenames with spaces/tabs/unicode (normalization disabled)
  "space filename||| $'a b.txt' |||1"
  "leading-space filename||| $' file-leading-space.txt' |||1"
  "tab filename||| $'a\tb.txt' |||1"
  "unicode filename||| $'İçerik-ğüşöç.txt' |||1"

  # Symlinks / FIFOs
  "symlink||| symlink-to-file1 |||0"
  "broken symlink||| broken-symlink |||0"
  "fifo||| fifo1 |||0"

  # Permission edge cases
  "setuid file||| setuid-file |||0"
  "setgid file||| setgid-file |||0"
  "setgid dir||| setgid-dir |||0"
  "sticky dir||| sticky-dir |||0"

  # Timestamp boundary fixtures (relative-time bucket boundaries)
  "mtime now-1s||| mtime-now-1s |||0"
  "mtime now-119s||| mtime-now-119s |||0"
  "mtime now-120s||| mtime-now-120s |||0"
  "mtime now-3599s||| mtime-now-3599s |||0"
  "mtime now-3600s||| mtime-now-3600s |||0"
  "mtime now-2days||| mtime-now-2days |||0"
  "mtime now-3yr||| mtime-now-3yr |||0"
  "mtime now-35yr||| mtime-now-35yr |||0"
  "mtime now-125yr||| mtime-now-125yr |||0"

  # Additional edge-case directories
  "symlink target space||| case-symlink-target-space |||0"
  "symlink target tab||| case-symlink-target-tab |||0"
  "future-only||| case-future-only |||0"
  "mixed time width||| case-mixed-time-width |||0"
)

# ============================================================================
# RUN TESTS
# ============================================================================
errors=0
passed=0
test_num=0
global_index=0

# Colors (match ls-compare)
color_yellow=$'\033[33m'
color_magenta=$'\033[35m'
color_reset=$'\033[0m'

if [ "$FAIL_ONLY" -eq 0 ]; then
  echo "Testing comparison: ${script_names[*]}"
  echo "=================================="
  echo ""
fi

for test_case in "${test_cases[@]}"; do
  # Parse structured test case: NAME|||ARGV|||NO_NORMALIZE
  trim_ws() {
    local s="$1"
    s="${s#"${s%%[![:space:]]*}"}"
    s="${s%"${s##*[![:space:]]}"}"
    printf '%s' "$s"
  }

  if [[ "$test_case" == *"|||"* ]]; then
    test_name="${test_case%%|||*}"
    rest="${test_case#*|||}"
    test_argv_str="${rest%%|||*}"
    test_no_normalize="${rest#*|||}"
  else
    test_name="$test_case"
    test_argv_str=""
    test_no_normalize="0"
  fi

  test_name="$(trim_ws "$test_name")"
  test_argv_str="$(trim_ws "$test_argv_str")"
  test_no_normalize="$(trim_ws "$test_no_normalize")"

  test_name="${test_name:-default}"
  test_argv_str="${test_argv_str:-}"
  test_no_normalize="${test_no_normalize:-0}"

  # Calculate the actual test number based on absolute position in the suite
  global_index=$((global_index + 1))
  actual_test_num=$global_index

  if [ "$ONLY_MODE" -eq 1 ]; then
    matched=0
    for only in "${ONLY_TESTS[@]}"; do
      # Check if --only value is a number
      if [[ "$only" =~ ^[0-9]+$ ]]; then
        # It's a test number - check if it matches this test's number
        if [ "$only" -eq "$actual_test_num" ]; then
          matched=1
          break
        fi
      else
        # It's a test case name - check if it matches
        if [ "$only" = "$test_name" ]; then
          matched=1
          break
        fi
      fi
    done
    if [ "$matched" -eq 0 ]; then
      continue
    fi
  fi
  if [ "$FAIL_ONLY" -eq 0 ]; then
    test_num_colored="${color_magenta}Test #$actual_test_num${color_reset}"
    display_test_name="${color_yellow}${test_name}${color_reset}"
    echo "$test_num_colored: $display_test_name"
    echo "----------------------------------"
  fi
  
  # Run all scripts and capture outputs
  # IMPORTANT: ARGV is a shell-quoted argv string; expand it safely into an array.
  # Examples:
  #   "-s -h"
  #   "$'a b.txt'"
  #   "file1.txt --no-group" (flags after operands)
  if [ -n "$test_argv_str" ]; then
    # shellcheck disable=SC2086
    eval "tc_argv=($test_argv_str)"
  else
    tc_argv=()
  fi

  outputs=()
  normalized_outputs=()
  ansi_stripped_outputs=()

  strip_ansi_and_controls() {
    # Removes ANSI escape sequences and common control chars from a string.
    # Keeps ordinary whitespace intact.
    local text="$1"

    text=$(printf '%s' "$text" | perl -pe '
      s/\e\[[0-9;?]*[ -\/]*[@-~]//g;          # CSI ... cmd (colors, erase-in-line, etc.)
      s/\e\][^\a]*(\a|\e\\)//g;              # OSC ... BEL or ST
      s/\e[P^_].*?(\e\\)//gs;                # DCS/PM/APC ... ST
      s/\e[()#][0-9A-Za-z]//g;               # Charset selects
      s/\e[\x40-\x5F]//g;                    # 2-char ESC sequences
      s/\x1b\[[0-9;]*K//g;                   # Erase in line
      s/\r//g;                               # CR
    ')

    text=$(printf '%s' "$text" | tr -d '\v')
    printf '%s' "$text"
  }

  normalize_output() {
    # Normalization goal: ignore cosmetic spacing differences while preserving semantic differences.
    # - Always strip ANSI before normalization (comparison is about content, not colors).
    # - Squeeze repeated whitespace to a single space.
    # - Trim leading/trailing whitespace.
    # IMPORTANT: This MUST NOT be used for tests where filenames contain spaces/tabs,
    # because it would destroy semantic content.
    local text="$1"

    # Strip ANSI escape sequences.
    while [[ "$text" =~ $'\x1b'\[ ]]; do
      local before="${text%%$'\x1b'\[*}"
      local after="${text#*$'\x1b'\[}"
      after="${after#*m}"
      text="${before}${after}"
    done

    # Normalize whitespace line-by-line.
    printf '%s\n' "$text" \
      | sed -E 's/[[:space:]]+/ /g; s/^ //; s/ $//'
  }

  for script_path in "${script_paths[@]}"; do
    output=$(cd "$TEST_DIR" && LL_CHATGPT_FAST=1 "$script_path" "${tc_argv[@]}" 2>&1)
    outputs+=("$output")
    ansi_stripped_outputs+=("$(strip_ansi_and_controls "$output")")
    if [ "$test_no_normalize" -eq 1 ]; then
      normalized_outputs+=("")
    else
      normalized_outputs+=("$(normalize_output "$output")")
    fi
  done

  # Check if all outputs are identical (raw)
  all_match=true
  first_output="${outputs[0]}"
  for i in $(seq 1 $((${#outputs[@]} - 1))); do
    if [ "${outputs[$i]}" != "$first_output" ]; then
      all_match=false
      break
    fi
  done

  # Check if all outputs are identical after full normalization (when enabled)
  all_match_normalized=false
  if [ "$test_no_normalize" -eq 0 ]; then
    all_match_normalized=true
    first_norm="${normalized_outputs[0]}"
    for i in $(seq 1 $((${#normalized_outputs[@]} - 1))); do
      if [ "${normalized_outputs[$i]}" != "$first_norm" ]; then
        all_match_normalized=false
        break
      fi
    done
  fi

  # Check if all outputs are identical after ANSI-stripping (always computed, fixes NO_NORMALIZE tests)
  all_match_ansi_stripped=true
  first_ansi_stripped="${ansi_stripped_outputs[0]}"
  for i in $(seq 1 $((${#ansi_stripped_outputs[@]} - 1))); do
    if [ "${ansi_stripped_outputs[$i]}" != "$first_ansi_stripped" ]; then
      all_match_ansi_stripped=false
      break
    fi
  done
  
  # Function to print side-by-side comparison
  print_side_by_side() {
    # Function to strip ANSI color codes for length calculation
    strip_colors() {
      local text="$1"

      # If we are showing ANSI visibly, do not strip anything.
      if [ "${SHOW_ANSI}" -eq 1 ]; then
        echo "$text"
        return 0
      fi

      # Remove ANSI escape sequences.
      while [[ "$text" =~ $'\x1b'\[ ]]; do
        local before="${text%%$'\x1b'\[*}"
        local after="${text#*$'\x1b'\[}"
        after="${after#*m}"
        text="${before}${after}"
      done
      echo "$text"
    }
    
    make_ansi_visible() {
      # Render control chars (including ESC) as visible escape sequences, without line-wrapping.
      # This avoids `sed -n 'l'` behavior that inserts backslash-newline continuations and trailing `$`.
      # NOTE: Input is a single line (caller reads line-by-line).
      perl -pe 's/\e/\\033/g; s/\t/\\t/g; s/\r/\\r/g; s/\f/\\f/g; s/\v/\\v/g' <<<"$1"
    }
    
    # Convert each output to array of lines
    declare -a output_lines
    for i in $(seq 0 $((${#outputs[@]} - 1))); do
      # Split output into lines
      temp_file=$(mktemp)
      echo "${outputs[$i]}" > "$temp_file"
      output_lines[i]="$temp_file"
    done
    
    # Find maximum number of lines
    max_lines=0
    for i in $(seq 0 $((${#outputs[@]} - 1))); do
      line_count=$(wc -l < "${output_lines[$i]}")
      if [ "$line_count" -gt "$max_lines" ]; then
        max_lines=$line_count
      fi
    done
    
    # Find maximum line length for each output (for proper padding)
    declare -a max_lens
    for i in $(seq 0 $((${#outputs[@]} - 1))); do
      max_lens[i]=0
      while IFS= read -r line; do
        if [ "${SHOW_ANSI}" -eq 1 ]; then
          line_for_len=$(make_ansi_visible "$line")
        else
          line_for_len=$(strip_colors "$line")
        fi
        line_len=${#line_for_len}
        if [ "$line_len" -gt "${max_lens[i]}" ]; then
          max_lens[i]=$line_len
        fi
      done < "${output_lines[$i]}"
    done
    
    # Print side-by-side with proper padding
    for line_num in $(seq 1 "$max_lines"); do
      result_line=""
      
      # Process each output column
      for i in $(seq 0 $((${#outputs[@]} - 1))); do
        line=$(sed -n "${line_num}p" "${output_lines[$i]}")
        if [ "${SHOW_ANSI}" -eq 1 ] && [ -n "$line" ]; then
          line=$(make_ansi_visible "$line")
        fi
        if [ -z "$line" ]; then
          line=""
        fi
        
        # Calculate padding needed for this line (based on length without colors)
        # If SHOW_ANSI is enabled, line is already processed by make_ansi_visible,
        # so we need to strip the visible ANSI sequences (\033) for length calculation
        if [ "${SHOW_ANSI}" -eq 1 ]; then
          # For visible ANSI, we need to account for the \033 sequences in the length
          # make_ansi_visible converts \e to \033, so we need to count the actual visible characters
          # We'll use the line as-is since make_ansi_visible already converted escape sequences
          line_for_len=$(echo "$line" | perl -pe 's/\\033\[[0-9;?]*[ -\/]*[@-~]//g; s/\\033//g')
        else
          line_for_len=$(strip_colors "$line")
        fi
        line_len=${#line_for_len}
        padding_len=$((max_lens[i] - line_len))
        if [ "$padding_len" -gt 0 ]; then
          padding=$(printf "%*s" "$padding_len" "")
          line="${line}${padding}"
        fi
        
        # Add separator before each column (except first)
        if [ "$i" -gt 0 ]; then
          result_line="${result_line} |"
        fi
        result_line="${result_line} ${line}"
      done
      
      echo "  $result_line"
    done
    
    # Cleanup temp files
    for temp_file in "${output_lines[@]}"; do
      rm -f "$temp_file"
    done
  }

  # Function to print vertical/stacked comparison
  print_vertical() {
    # ANSI color codes
    local color_red=$'\033[31m'
    local color_reset=$'\033[0m'
    
    # Function to make ANSI characters visible (same as in print_side_by_side)
    make_ansi_visible() {
      # Render control chars (including ESC) as visible escape sequences, without line-wrapping.
      # This avoids `sed -n 'l'` behavior that inserts backslash-newline continuations and trailing `$`.
      # NOTE: Input is a single line (caller reads line-by-line).
      perl -pe 's/\e/\\033/g; s/\t/\\t/g; s/\r/\\r/g; s/\f/\\f/g; s/\v/\\v/g' <<<"$1"
    }
    
    # Build parameter string for display
    param_str=""
    if [ ${#tc_argv[@]} -gt 0 ]; then
      param_str=" ${tc_argv[*]}"
    fi
    
    # Print each script output
    for i in $(seq 0 $((${#outputs[@]} - 1))); do
      if [ "$i" -gt 0 ]; then
        echo ""
      fi
      if [ "$i" -lt ${#script_names[@]} ]; then
        # Print script command in red (excluding the colon)
        echo "  ${color_red}${script_names[$i]}${param_str}${color_reset}:"
      else
        echo "  ${color_red}Script #$((i + 1))${param_str}${color_reset}:"
      fi
      # Apply make_ansi_visible if SHOW_ANSI is enabled
      if [ "${SHOW_ANSI}" -eq 1 ]; then
        while IFS= read -r line; do
          make_ansi_visible "$line"
        done <<<"${outputs[$i]}"
      else
        echo "${outputs[$i]}"
      fi
    done
  }

  if [ "$all_match" = true ]; then
    if [ "$FAIL_ONLY" -eq 0 ]; then
      if [ "$SIDE_BY_SIDE" -eq 1 ]; then
        echo "PASS - All outputs match exactly"
        echo "  Side-by-side comparison:"
        print_side_by_side
      else
        # Vertical format: show outputs directly without "PASS" message
        print_vertical
      fi
    fi
    ((passed++))
  elif [ "$all_match_normalized" = true ]; then
    if [ "$FAIL_ONLY" -eq 0 ]; then
      if [ "$SIDE_BY_SIDE" -eq 1 ]; then
        echo "PASS (normalized) - Outputs differ only by whitespace/ANSI formatting"
        echo "  Side-by-side comparison:"
        print_side_by_side
      else
        echo "PASS (normalized) - Outputs differ only by whitespace/ANSI formatting"
        print_vertical
      fi
    fi
    ((passed++))
  elif [ "$all_match_ansi_stripped" = true ]; then
    if [ "$FAIL_ONLY" -eq 0 ]; then
      if [ "$SIDE_BY_SIDE" -eq 1 ]; then
        echo "PASS (normalized) - Outputs differ only by whitespace/ANSI formatting"
        echo "  Side-by-side comparison:"
        print_side_by_side
      else
        echo "PASS (normalized) - Outputs differ only by whitespace/ANSI formatting"
        print_vertical
      fi
    fi
    ((passed++))
  else
    if [ "$FAIL_ONLY" -eq 0 ]; then
      if [ "$SIDE_BY_SIDE" -eq 1 ]; then
        echo "FAIL - Outputs differ"
        echo "  Side-by-side comparison:"
        print_side_by_side
      else
        echo "FAIL - Outputs differ"
        # Vertical format: show outputs directly
        print_vertical
      fi
    else
      test_num_colored="${color_magenta}Test #$actual_test_num${color_reset}"
      display_test_name="${color_yellow}${test_name}${color_reset}"
      echo "$test_num_colored: $display_test_name"
      echo "----------------------------------"
      echo "FAIL - Outputs differ"
      if [ "$SIDE_BY_SIDE" -eq 1 ]; then
        echo "  Side-by-side comparison:"
        print_side_by_side
      else
        print_vertical
      fi
    fi
    ((errors++))
  fi
  
  # Add blank line between tests:
  # - Normal mode: always separate tests.
  # - --fail-only: only separate failing tests (avoid printing blank lines for skipped passes).
  if [ "$FAIL_ONLY" -eq 0 ]; then
    echo ""
  else
    if [ "$all_match" = false ] && [ "$all_match_normalized" = false ]; then
      echo ""
    fi
  fi
done

if [ "$FAIL_ONLY" -eq 0 ]; then
  echo ""
  echo "=================================="
fi
echo "Results: $passed passed, $errors failed"

# ============================================================================
# CLEANUP
# ============================================================================

cd /tmp || exit 1
if [ "$KEEP_DIR" -eq 0 ]; then
  rm -rf "$TEST_DIR"
else
  echo "Test directory kept: $TEST_DIR"
fi

# Restore LL_NOW_EPOCH to avoid leaking state to parent shells when sourced.
if [ "${_ORIG_LL_NOW_EPOCH_SET:-0}" -eq 1 ]; then
  export LL_NOW_EPOCH
  LL_NOW_EPOCH="$_ORIG_LL_NOW_EPOCH_VALUE"
else
  unset LL_NOW_EPOCH 2>/dev/null || true
fi

exit $errors
