#!/bin/bash
# scripts/dev/ll-compare
# Test script to compare ll script outputs
# Tests various parameter combinations
# Usage: test-ll-compare.sh <script1> <script2> [script3 ...]

# ============================================================================
# NOTE: Additional content/fixture tests to add later (not implemented here)
# ============================================================================
# - Filenames:
#   - Spaces: "a b.txt"
#   - Leading space: " file"
#   - Tab: $'a\tb'
#   - Unicode: "İçerik-ğüşöç.txt"
#   - Very long name (200+ chars)
#   - Newline in name (will break line-based parsing): $'a\nb'
# - File types:
#   - Symlink and broken symlink ("name -> target")
#   - FIFO, socket, block/char device (permission type chars p,s,b,c)
# - Permissions:
#   - setuid/setgid/sticky (s,S,t,T)
#   - ACL indicator '+' in perms
# - Timestamps:
#   - Very recent (sec/min), hours, days, months, years
#   - Future mtime (negative relative delta)
# - Scale/perf:
#   - Large dir (10k+ entries)
#   - Slow FS (NFS/SMB)
# - Environment:
#   - TTY vs pipe, different TERM/LANG
#   - GNU ls vs BSD ls compatibility checks

PROJECT_ROOT="$(cd "$(dirname "$0")/../.." && pwd)"
BIN_DIR="$PROJECT_ROOT/scripts/bin"

export LC_ALL=C
export TZ=UTC

# ============================================================================
# PARSE COMMAND LINE ARGUMENTS
# ============================================================================

# Optional flags:
#   --show-ansi : make ANSI/control chars visible in side-by-side diff output.
#   --fail-only : only print failing tests (still prints final summary).
# Flags can be provided in any order, and can be combined.
ONLY_TESTS=()
ONLY_MODE=0
SHOW_ANSI=0
FAIL_ONLY=0
while [ $# -gt 0 ]; do
  case "${1:-}" in
    --show-ansi)
      SHOW_ANSI=1
      shift
      ;;
    --fail-only)
      FAIL_ONLY=1
      shift
      ;;
    --only)
      # Filter to only run specific test cases. Value must match the test_case string.
      if [ $# -lt 2 ] || [ -z "${2:-}" ]; then
        echo "Error: --only requires a value" >&2
        exit 2
      fi
      ONLY_MODE=1
      ONLY_TESTS+=("$2")
      shift 2
      ;;
    --only=*)
      # Support --only="-s -h" style.
      ONLY_MODE=1
      ONLY_TESTS+=("${1#--only=}")
      shift
      ;;
    *)
      break
      ;;
  esac
done

if [ $# -lt 2 ]; then
  echo "Usage: $0 [--show-ansi] [--fail-only] [--only <TEST>] [--only=<TEST>] <script1> <script2> [script3 ...]" >&2
  echo "Example: $0 ll ll-chatgpt" >&2
  echo "Example: $0 --fail-only ll ll-chatgpt" >&2
  echo "Example: $0 --show-ansi --fail-only ll ll-chatgpt ll2" >&2
  echo "Example: $0 --fail-only --only \"-s -h\" ll ll-chatgpt" >&2
  exit 1
fi

# Store script names and validate they exist
script_names=()
script_paths=()
for script_name in "$@"; do
  script_path="$BIN_DIR/$script_name"
  if [ ! -f "$script_path" ] || [ ! -x "$script_path" ]; then
    echo "Error: Script '$script_name' not found or not executable in $BIN_DIR" >&2
    exit 1
  fi
  script_names+=("$script_name")
  script_paths+=("$script_path")
done

# ============================================================================
# SETUP TEST ENVIRONMENT
# ============================================================================
TEST_DIR="/tmp/ll-test-$$"
mkdir -p "$TEST_DIR"
cd "$TEST_DIR" || exit 1

# Create test files (baseline)
touch file1.txt file2.txt
mkdir dir1 dir2
echo "test" > file3.txt
chmod 755 file1.txt
chmod 644 file2.txt

# Additional filename fixtures
# NOTE: These are intentionally tricky for whitespace-based parsers.
# We disable normalization for tests that use these.
touch "a b.txt"
touch " file-leading-space.txt"
# Tab in filename
printf '' > $'a\tb.txt'
# Unicode filename
printf '' > $'İçerik-ğüşöç.txt'

# Symlink fixtures
ln -s file1.txt symlink-to-file1
ln -s does-not-exist broken-symlink

# FIFO fixture (may fail on some restricted FS; ignore errors)
mkfifo fifo1 2>/dev/null || true

# Permission edge cases
printf '' > setuid-file
chmod 755 setuid-file
chmod u+s setuid-file 2>/dev/null || true

mkdir -p setgid-dir sticky-dir
chmod 2755 setgid-dir 2>/dev/null || true
chmod 1777 sticky-dir 2>/dev/null || true

# Timestamp fixtures: deterministic + boundary coverage
# We freeze "now" via LL_NOW_EPOCH below, then set file mtimes relative to it.

# Make baseline mtimes deterministic (Jan 1, 2020 00:00:00 local time).
touch -t 202001010000.00 file1.txt file2.txt file3.txt dir1 dir2 \
  "a b.txt" " file-leading-space.txt" $'a\tb.txt' $'İçerik-ğüşöç.txt' \
  symlink-to-file1 broken-symlink setuid-file setgid-dir sticky-dir || true

# Make relative-time computations deterministic between scripts by freezing “now”.
# If the caller already set LL_NOW_EPOCH, respect it.
_ORIG_LL_NOW_EPOCH_SET=0
_ORIG_LL_NOW_EPOCH_VALUE=""
if [ "${LL_NOW_EPOCH+x}" = "x" ]; then
  _ORIG_LL_NOW_EPOCH_SET=1
  _ORIG_LL_NOW_EPOCH_VALUE="$LL_NOW_EPOCH"
else
  export LL_NOW_EPOCH
  LL_NOW_EPOCH=1577836800
fi

# Helper: convert an epoch (seconds) into a touch -t timestamp (local time).
# macOS: date -r <epoch>
# GNU:   date -d @<epoch>
epoch_to_touch_ts() {
  local epoch="${1:?epoch required}"
  if date -r "$epoch" +%Y%m%d%H%M.%S >/dev/null 2>&1; then
    date -r "$epoch" +%Y%m%d%H%M.%S
    return 0
  fi
  if date -d "@${epoch}" +%Y%m%d%H%M.%S >/dev/null 2>&1; then
    date -d "@${epoch}" +%Y%m%d%H%M.%S
    return 0
  fi
  return 1
}

# Create timestamp boundary fixtures relative to LL_NOW_EPOCH.
# These are used to validate bucket transitions (sec/min/hour/day) deterministically.
create_mtime_fixture() {
  local name="${1:?name required}"
  local delta="${2:?delta seconds required}"
  local target_epoch=$((LL_NOW_EPOCH - delta))
  local ts
  ts=$(epoch_to_touch_ts "$target_epoch") || return 0
  printf '' > "$name"
  touch -t "$ts" "$name" 2>/dev/null || true
}

create_mtime_fixture "mtime-now-1s" 1
create_mtime_fixture "mtime-now-119s" 119
create_mtime_fixture "mtime-now-120s" 120
create_mtime_fixture "mtime-now-3599s" 3599
create_mtime_fixture "mtime-now-3600s" 3600
create_mtime_fixture "mtime-now-2days" 172800

# Future mtime fixture (negative delta behavior). Use a fixed far-future date.
printf '' > future-mtime
# Jan 1, 2030 00:00:00
 touch -t 203001010000.00 future-mtime 2>/dev/null || true

# ============================================================================
# TEST CASES
# ============================================================================
# Format: NAME|||ARGV|||NO_NORMALIZE
# - NAME: label shown in output.
# - ARGV: a shell-quoted argv string. It is expanded with: eval "tc_argv=(...)".
# - NO_NORMALIZE: "1" to disable normalization for this test (useful for filenames with
#   spaces/tabs where whitespace squeezing would be destructive).

test_cases=(
  "default||| |||0"

  # Directory listing behavior
  "-d||| -d |||0"
  "--directory||| --directory |||0"
  "-d .||| -d . |||0"

  # Owner/group toggles
  "-g||| -g |||0"
  "-G||| -G |||0"
  "-o||| -o |||0"
  "--no-group||| --no-group |||0"
  "-g -G||| -g -G |||0"

  # Size column (allocated blocks)
  "-s||| -s |||0"
  "--size||| --size |||0"

  # Human readable size variants
  "-h||| -h |||0"
  "--human-readable||| --human-readable |||0"
  "--si||| --si |||0"

  # Numeric uid/gid
  "-n||| -n |||0"
  "--numeric-uid-gid||| --numeric-uid-gid |||0"

  # Cross-combinations (core)
  "-s -h||| -s -h |||0"
  "-s --si||| -s --si |||0"
  "-n -h||| -n -h |||0"
  "-n --si||| -n --si |||0"
  "-s -g||| -s -g |||0"
  "-s -h -g -G||| -s -h -g -G |||0"

  # Option ordering: flags after operands (your ll-chatgpt scanner is supposed to support this)
  "file then --no-group||| file1.txt --no-group |||0"
  "file then -G||| file1.txt -G |||0"
  "--no-group then file||| --no-group file1.txt |||0"

  # Targeted path arguments
  "-h file1.txt||| -h file1.txt |||0"
  "--no-group file2.txt||| --no-group file2.txt |||0"

  # Filenames with spaces/tabs/unicode (normalization disabled)
  "space filename||| $'a b.txt' |||1"
  "leading-space filename||| $' file-leading-space.txt' |||1"
  "tab filename||| $'a\tb.txt' |||1"
  "unicode filename||| $'İçerik-ğüşöç.txt' |||1"

  # Symlinks / FIFOs
  "symlink||| symlink-to-file1 |||0"
  "broken symlink||| broken-symlink |||0"
  "fifo||| fifo1 |||0"

  # Permission edge cases
  "setuid file||| setuid-file |||0"
  "setgid dir||| setgid-dir |||0"
  "sticky dir||| sticky-dir |||0"

  # Timestamp boundary fixtures (relative-time bucket boundaries)
  "mtime now-1s||| mtime-now-1s |||0"
  "mtime now-119s||| mtime-now-119s |||0"
  "mtime now-120s||| mtime-now-120s |||0"
  "mtime now-3599s||| mtime-now-3599s |||0"
  "mtime now-3600s||| mtime-now-3600s |||0"
  "mtime now-2days||| mtime-now-2days |||0"
  "future mtime||| future-mtime |||0"
)

# ============================================================================
# RUN TESTS
# ============================================================================
errors=0
passed=0
test_num=0

if [ "$FAIL_ONLY" -eq 0 ]; then
  echo "Testing comparison: ${script_names[*]}"
  echo "=================================="
  echo ""
fi

for test_case in "${test_cases[@]}"; do
  # Parse structured test case: NAME|||ARGV|||NO_NORMALIZE
  trim_ws() {
    local s="$1"
    s="${s#"${s%%[![:space:]]*}"}"
    s="${s%"${s##*[![:space:]]}"}"
    printf '%s' "$s"
  }

  if [[ "$test_case" == *"|||"* ]]; then
    test_name="${test_case%%|||*}"
    rest="${test_case#*|||}"
    test_argv_str="${rest%%|||*}"
    test_no_normalize="${rest#*|||}"
  else
    test_name="$test_case"
    test_argv_str=""
    test_no_normalize="0"
  fi

  test_name="$(trim_ws "$test_name")"
  test_argv_str="$(trim_ws "$test_argv_str")"
  test_no_normalize="$(trim_ws "$test_no_normalize")"

  test_name="${test_name:-default}"
  test_argv_str="${test_argv_str:-}"
  test_no_normalize="${test_no_normalize:-0}"

  if [ "$ONLY_MODE" -eq 1 ]; then
    matched=0
    for only in "${ONLY_TESTS[@]}"; do
      if [ "$only" = "$test_name" ]; then
        matched=1
        break
      fi
    done
    if [ "$matched" -eq 0 ]; then
      continue
    fi
  fi
  ((test_num++))
  if [ "$FAIL_ONLY" -eq 0 ]; then
    echo "Test #$test_num: $test_name"
    echo "----------------------------------"
  fi
  
  # Run all scripts and capture outputs
  # IMPORTANT: ARGV is a shell-quoted argv string; expand it safely into an array.
  # Examples:
  #   "-s -h"
  #   "$'a b.txt'"
  #   "file1.txt --no-group" (flags after operands)
  if [ -n "$test_argv_str" ]; then
    # shellcheck disable=SC2086
    eval "tc_argv=($test_argv_str)"
  else
    tc_argv=()
  fi

  outputs=()
  normalized_outputs=()

  normalize_output() {
    # Normalization goal: ignore cosmetic spacing differences while preserving semantic differences.
    # - Always strip ANSI before normalization (comparison is about content, not colors).
    # - Squeeze repeated whitespace to a single space.
    # - Trim leading/trailing whitespace.
    # IMPORTANT: This MUST NOT be used for tests where filenames contain spaces/tabs,
    # because it would destroy semantic content.
    local text="$1"

    # Strip ANSI escape sequences.
    while [[ "$text" =~ $'\x1b'\[ ]]; do
      local before="${text%%$'\x1b'\[*}"
      local after="${text#*$'\x1b'\[}"
      after="${after#*m}"
      text="${before}${after}"
    done

    # Normalize whitespace line-by-line.
    printf '%s\n' "$text" \
      | sed -E 's/[[:space:]]+/ /g; s/^ //; s/ $//'
  }

  for script_path in "${script_paths[@]}"; do
    output=$(cd "$TEST_DIR" && LL_CHATGPT_FAST=1 "$script_path" "${tc_argv[@]}" 2>&1)
    outputs+=("$output")
    if [ "$test_no_normalize" -eq 1 ]; then
      normalized_outputs+=("__NO_NORMALIZE__")
    else
      normalized_outputs+=("$(normalize_output "$output")")
    fi
  done

  # Check if all outputs are identical (raw)
  all_match=true
  first_output="${outputs[0]}"
  for i in $(seq 1 $((${#outputs[@]} - 1))); do
    if [ "${outputs[$i]}" != "$first_output" ]; then
      all_match=false
      break
    fi
  done

  # Check if all outputs are identical after normalization (when enabled)
  all_match_normalized=false
  if [ "$test_no_normalize" -eq 0 ]; then
    all_match_normalized=true
    first_norm="${normalized_outputs[0]}"
    for i in $(seq 1 $((${#normalized_outputs[@]} - 1))); do
      if [ "${normalized_outputs[$i]}" != "$first_norm" ]; then
        all_match_normalized=false
        break
      fi
    done
  fi
  
  if [ "$all_match" = true ]; then
    if [ "$FAIL_ONLY" -eq 0 ]; then
      echo "PASS - All outputs match"
    fi
    ((passed++))
  elif [ "$all_match_normalized" = true ]; then
    if [ "$FAIL_ONLY" -eq 0 ]; then
      echo "PASS (normalized) - Outputs differ only by whitespace/ANSI formatting"
    fi
    ((passed++))
  else
    if [ "$FAIL_ONLY" -eq 0 ]; then
      echo "FAIL - Outputs differ"
    else
      echo "Test #$test_num: $test_name"
      echo "----------------------------------"
      echo "FAIL - Outputs differ"
    fi
    ((errors++))
    
    # Display side-by-side comparison with proper padding
    echo "  Side-by-side comparison:"
    
    # Function to strip ANSI color codes for length calculation
    strip_colors() {
      local text="$1"

      # If we are showing ANSI visibly, do not strip anything.
      if [ "${SHOW_ANSI}" -eq 1 ]; then
        echo "$text"
        return 0
      fi

      # Remove ANSI escape sequences.
      while [[ "$text" =~ $'\x1b'\[ ]]; do
        local before="${text%%$'\x1b'\[*}"
        local after="${text#*$'\x1b'\[}"
        after="${after#*m}"
        text="${before}${after}"
      done
      echo "$text"
    }
    
    make_ansi_visible() {
      # Render control chars (including ESC) as visible escape sequences, without line-wrapping.
      # This avoids `sed -n 'l'` behavior that inserts backslash-newline continuations and trailing `$`.
      # NOTE: Input is a single line (caller reads line-by-line).
      perl -pe 's/\e/\\033/g; s/\t/\\t/g; s/\r/\\r/g; s/\f/\\f/g; s/\v/\\v/g' <<<"$1"
    }
    
    # Convert each output to array of lines
    declare -a output_lines
    for i in $(seq 0 $((${#outputs[@]} - 1))); do
      # Split output into lines
      temp_file=$(mktemp)
      echo "${outputs[$i]}" > "$temp_file"
      output_lines[i]="$temp_file"
    done
    
    # Find maximum number of lines
    max_lines=0
    for i in $(seq 0 $((${#outputs[@]} - 1))); do
      line_count=$(wc -l < "${output_lines[$i]}")
      if [ "$line_count" -gt "$max_lines" ]; then
        max_lines=$line_count
      fi
    done
    
    # Find maximum line length for each output (for proper padding)
    declare -a max_lens
    for i in $(seq 0 $((${#outputs[@]} - 1))); do
      max_lens[i]=0
      while IFS= read -r line; do
        if [ "${SHOW_ANSI}" -eq 1 ]; then
          line_for_len=$(make_ansi_visible "$line")
        else
          line_for_len=$(strip_colors "$line")
        fi
        line_len=${#line_for_len}
        if [ "$line_len" -gt "${max_lens[i]}" ]; then
          max_lens[i]=$line_len
        fi
      done < "${output_lines[$i]}"
    done
    
    # Print side-by-side with proper padding
    for line_num in $(seq 1 "$max_lines"); do
      result_line=""
      
      # Process each output column
      for i in $(seq 0 $((${#outputs[@]} - 1))); do
        line=$(sed -n "${line_num}p" "${output_lines[$i]}")
        if [ "${SHOW_ANSI}" -eq 1 ] && [ -n "$line" ]; then
          line=$(make_ansi_visible "$line")
        fi
        if [ -z "$line" ]; then
          line=""
        fi
        
        # Calculate padding needed for this line (based on length without colors)
        line_for_len=$(strip_colors "$line")
        line_len=${#line_for_len}
        padding_len=$((max_lens[i] - line_len))
        if [ "$padding_len" -gt 0 ]; then
          padding=$(printf "%*s" "$padding_len" "")
          line="${line}${padding}"
        fi
        
        # Add separator before each column (except first)
        if [ "$i" -gt 0 ]; then
          result_line="${result_line} |"
        fi
        result_line="${result_line} ${line}"
      done
      
      echo "  $result_line"
    done
    
    # Cleanup temp files
    for temp_file in "${output_lines[@]}"; do
      rm -f "$temp_file"
    done
  fi
  
  # Add blank line between tests
  echo ""
done

if [ "$FAIL_ONLY" -eq 0 ]; then
  echo ""
  echo "=================================="
fi
echo "Results: $passed passed, $errors failed"

# ============================================================================
# CLEANUP
# ============================================================================

cd /tmp || exit 1
rm -rf "$TEST_DIR"

# Restore LL_NOW_EPOCH to avoid leaking state to parent shells when sourced.
if [ "${_ORIG_LL_NOW_EPOCH_SET:-0}" -eq 1 ]; then
  export LL_NOW_EPOCH
  LL_NOW_EPOCH="$_ORIG_LL_NOW_EPOCH_VALUE"
else
  unset LL_NOW_EPOCH 2>/dev/null || true
fi

exit $errors
