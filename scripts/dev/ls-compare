  "--human-readable"
  "--si"
  "-n"
  "--numeric-uid-gid"
  "-s -h"
  "-s --si"
  "-n -h"
  "-n --si"
  "-s -g"
  "-s -h -g -G"
  "file1.txt --no-group"
  "file1.txt -G"
  "--no-group file1.txt"
  "-h file1.txt"
  "--no-group file2.txt"
  "-- \"a b.txt\""
  "-- \" file-leading-space.txt\""
  "-- \$'a\\tb.txt'"
  "-- \"İçerik-ğüşöç.txt\""
  "-- symlink-to-file1"
  "-- broken-symlink"
  "-- fifo1"
