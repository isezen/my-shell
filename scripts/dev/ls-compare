#!/bin/bash
# scripts/dev/ls-compare
# Test script to compare ls -l --color --time-style=+"%s" output with ll script outputs
# Tests various parameter combinations
# Usage: ls-compare.sh [options] <script1> [script2 ...]

# ============================================================================
# NOTE: Additional content/fixture tests to add later (not implemented here)
# ============================================================================
# - Filenames:
#   - Spaces: "a b.txt"
#   - Leading space: " file"
#   - Tab: $'a\tb'
#   - Unicode: "İçerik-ğüşöç.txt"
#   - Very long name (200+ chars)
#   - Newline in name (will break line-based parsing): $'a\nb'
# - File types:
#   - Symlink and broken symlink ("name -> target")
#   - FIFO, socket, block/char device (permission type chars p,s,b,c)
# - Permissions:
#   - setuid/setgid/sticky (s,S,t,T)
#   - ACL indicator '+' in perms
# - Timestamps:
#   - Very recent (sec/min), hours, days, months, years
#   - Future mtime (negative relative delta)
# - Scale/perf:
#   - Large dir (10k+ entries)
#   - Slow FS (NFS/SMB)
# - Environment:
#   - TTY vs pipe, different TERM/LANG
#   - GNU ls vs BSD ls compatibility checks

PROJECT_ROOT="$(cd "$(dirname "$0")/../.." && pwd)"
BIN_DIR="$PROJECT_ROOT/scripts/bin"
LS_BIN="${LS_COMPARE_LS:-${LL_CHATGPT_LS:-}}"

if [ -n "$LS_BIN" ]; then
  if ! "$LS_BIN" --color -l --time-style=+"%s" . >/dev/null 2>&1; then
    echo "Error: LS_COMPARE_LS must support --time-style=+%s" >&2
    exit 1
  fi
else
  if ls --color -l --time-style=+"%s" . >/dev/null 2>&1; then
    LS_BIN="ls"
  elif command -v gls >/dev/null 2>&1; then
    LS_BIN="$(command -v gls)"
  elif [ -x /opt/local/libexec/gnubin/ls ]; then
    LS_BIN="/opt/local/libexec/gnubin/ls"
  else
    echo "Error: GNU ls with --time-style=+%s is required for ls-compare." >&2
    exit 1
  fi
fi

# ============================================================================
# PARSE COMMAND LINE ARGUMENTS
# ============================================================================

# Optional flags:
#   --show-ansi : make ANSI/control chars visible in side-by-side diff output.
#   --fail-only : only print failing tests (still prints final summary).
#   --keep-dir  : do not delete test directory after tests complete.
#   --side-by-side : display outputs side-by-side (default: vertical/stacked format).
#   --help      : show help message and exit.
# Flags can be provided in any order, and can be combined.
ONLY_TESTS=()
ONLY_MODE=0
SHOW_ANSI=0
FAIL_ONLY=0
KEEP_DIR=0
SIDE_BY_SIDE=0
while [ $# -gt 0 ]; do
  case "${1:-}" in
    --help|-h)
      cat <<EOF
Usage: $0 [OPTIONS] [script1] [script2 ...]

Compare ls -l --color --time-style=+"%s" output with ll script outputs.
If no scripts are provided, only ls output is shown for test cases.

OPTIONS:
  --help, -h              Show this help message and exit
  
  --show-ansi             Make ANSI/control characters visible in side-by-side
                          diff output (useful for debugging color/formatting issues)
  
  --fail-only             Only print failing tests (still prints final summary)
  
  --keep-dir              Do not delete test directory after tests complete
                          (useful for debugging - test directory path is shown at start)
  
  --side-by-side          Display outputs side-by-side format
                          (default: vertical/stacked format where each output is
                          shown below the previous one)
  
  --only <TEST>           Run only specific test case(s). Can be specified multiple times.
                          Value can be either:
                          - Test case name (must match exactly)
                          - Test number (e.g., 22 for Test #22)
                          Example: --only "default" --only "-d" --only 22
  
  --only=<TEST>           Same as --only but using equals syntax.
                          Example: --only="-d" --only="--directory" --only=22

EXAMPLES:
  # Show ls output for all test cases
  $0
  
  # Compare ll-chatgpt with ls output
  $0 ll-chatgpt
  
  # Compare multiple scripts
  $0 ll ll-chatgpt
  
  # Show only failing tests in side-by-side format
  $0 --fail-only --side-by-side ll-chatgpt
  
  # Run only specific test cases (by name or number)
  $0 --only "default" --only "-d" --only 22 ll-chatgpt
  
  # Keep test directory for inspection
  $0 --keep-dir ll-chatgpt

OUTPUT FORMATS:
  Default (vertical/stacked):
    Test #1: default
    ----------------------------------
      ls -l --color --time-style=+"%s":
      [ls output]
      
      ll-chatgpt:
      [script output]
  
  With --side-by-side:
    Test #1: default
    ----------------------------------
      Side-by-side comparison:
      [ls output] | [script output]

EOF
      exit 0
      ;;
    --show-ansi)
      SHOW_ANSI=1
      shift
      ;;
    --fail-only)
      FAIL_ONLY=1
      shift
      ;;
    --keep-dir)
      KEEP_DIR=1
      shift
      ;;
    --side-by-side)
      SIDE_BY_SIDE=1
      shift
      ;;
    --only)
      # Filter to only run specific test cases. Value must match the test_case string.
      if [ $# -lt 2 ] || [ -z "${2:-}" ]; then
        echo "Error: --only requires a value" >&2
        exit 2
      fi
      ONLY_MODE=1
      ONLY_TESTS+=("$2")
      shift 2
      ;;
    --only=*)
      # Support --only="-s -h" style.
      ONLY_MODE=1
      ONLY_TESTS+=("${1#--only=}")
      shift
      ;;
    *)
      break
      ;;
  esac
done

# Script names are optional - if none provided, just show ls -l output for test cases
script_names=()
script_paths=()
if [ $# -ge 1 ]; then
  # Store script names and validate they exist
  for script_name in "$@"; do
    script_path="$BIN_DIR/$script_name"
    if [ ! -f "$script_path" ] || [ ! -x "$script_path" ]; then
      echo "Error: Script '$script_name' not found or not executable in $BIN_DIR" >&2
      exit 1
    fi
    script_names+=("$script_name")
    script_paths+=("$script_path")
  done
fi

# ============================================================================
# SETUP TEST ENVIRONMENT
# ============================================================================
TEST_DIR="/tmp/ls-compare-test-$$"
mkdir -p "$TEST_DIR"
echo "Test directory: $TEST_DIR"
cd "$TEST_DIR" || exit 1

# Create test files
touch file1.txt file2.txt
mkdir dir1
chmod 755 file1.txt
chmod 644 file2.txt

# Extra filename edge cases
# - Space in name
printf "space" > "a b.txt"
# - Leading space
printf "lead" > " file-leading-space.txt"
# - Tab in name
printf "tab" > $'a\tb.txt'
# - Unicode
printf "utf" > "İçerik-ğüşöç.txt"
# - Very long name (210 chars + .txt)
_long_name="$(printf 'a%.0s' {1..210}).txt"
printf "long" > "$_long_name"

# Extra file types
# - Symlink and broken symlink
ln -s "file1.txt" "symlink-to-file1" 2>/dev/null || true
ln -s "does-not-exist" "broken-symlink" 2>/dev/null || true
# - FIFO (named pipe)
mkfifo "fifo1" 2>/dev/null || true

# Permissions edge cases
# - setuid/setgid (may be ignored by some FS / CI environments)
cp "file1.txt" "setuid-file" 2>/dev/null || true
chmod 4755 "setuid-file" 2>/dev/null || true
cp "file1.txt" "setgid-file" 2>/dev/null || true
chmod 2755 "setgid-file" 2>/dev/null || true
# - setgid directory
mkdir -p "setgid-dir" 2>/dev/null || true
chmod 2755 "setgid-dir" 2>/dev/null || true
# - sticky directory
mkdir -p "sticky-dir" 2>/dev/null || true
chmod 1777 "sticky-dir" 2>/dev/null || true

# Make mtimes deterministic so relative-time output doesn't differ by 1-2 seconds
# between sequential script runs.
# Use a fixed point in time (Jan 1, 2020 00:00:00 local time).

touch -t 202001010000.00 \
  file1.txt file2.txt dir1 \
  "a b.txt" " file-leading-space.txt" $'a\tb.txt' "İçerik-ğüşöç.txt" \
  "$_long_name" symlink-to-file1 broken-symlink \
  fifo1 setuid-file setgid-file setgid-dir sticky-dir

# Make relative-time computations deterministic between scripts by freezing "now".
# If the caller already set LL_NOW_EPOCH, respect it.
_ORIG_LL_NOW_EPOCH_SET=0
_ORIG_LL_NOW_EPOCH_VALUE=""
if [ "${LL_NOW_EPOCH+x}" = "x" ]; then
  _ORIG_LL_NOW_EPOCH_SET=1
  _ORIG_LL_NOW_EPOCH_VALUE="$LL_NOW_EPOCH"
else
  export LL_NOW_EPOCH
  LL_NOW_EPOCH=$(date +%s)
fi

# Additional edge-case fixtures (keep default dir stable).
GNU_DATE="date"
GNU_TOUCH="touch"
if [ -x /opt/local/libexec/gnubin/date ]; then
  GNU_DATE="/opt/local/libexec/gnubin/date"
fi
if [ -x /opt/local/libexec/gnubin/touch ]; then
  GNU_TOUCH="/opt/local/libexec/gnubin/touch"
fi
if ! "$GNU_DATE" -d "@0" "+%Y-%m-%d %H:%M:%S" >/dev/null 2>&1; then
  echo "Error: GNU date with -d is required for edge-case fixtures." >&2
  exit 1
fi
if ! "$GNU_TOUCH" -d "@0" "$TEST_DIR/.touch-test" >/dev/null 2>&1; then
  echo "Error: GNU touch with -d is required for edge-case fixtures." >&2
  exit 1
