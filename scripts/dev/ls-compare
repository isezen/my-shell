  "--si"
  "-n"
  "--numeric-uid-gid"
  "-s -h"
  "-s --si"
  "-n -h"
  "-n --si"
  "-s -g"
  "-s -h -g -G"
  "file then --no-group"
  "file then -G"
  "--no-group then file"
  "-h file1.txt"
  "--no-group file2.txt"
  "-- a b.txt"
  "--  file-leading-space.txt"
  "-- a\\tb.txt"
