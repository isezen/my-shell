_mon_str=$("$GNU_DATE" -d "@$_mon_epoch" '+%Y-%m-%d %H:%M:%S')
_yr3_str=$("$GNU_DATE" -d "@$_yr3_epoch" '+%Y-%m-%d %H:%M:%S')
_yr35_str=$("$GNU_DATE" -d "@$_yr35_epoch" '+%Y-%m-%d %H:%M:%S')
_yr125_str=$("$GNU_DATE" -d "@$_yr125_epoch" '+%Y-%m-%d %H:%M:%S')
_yr1000_str=$("$GNU_DATE" -d "@$_yr1000_epoch" '+%Y-%m-%d %H:%M:%S')
