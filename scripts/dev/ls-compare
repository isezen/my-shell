"$GNU_TOUCH" -d "$_hrs_str" "case-mixed-time-width/hrs.txt"
"$GNU_TOUCH" -d "$_day_str" "case-mixed-time-width/day.txt"
"$GNU_TOUCH" -d "$_mon_str" "case-mixed-time-width/mon.txt"
