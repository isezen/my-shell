#!/bin/bash
# scripts/dev/ls-compare
# Test script to compare ls -l output with ll script implementations
# Usage: ls-compare [OPTIONS] <ll_linux|ll_macos>

set -euo pipefail

export LC_ALL=C
export TZ=UTC

PROJECT_ROOT="$(cd "$(dirname "$0")/../.." && pwd)"
BIN_DIR="$PROJECT_ROOT/scripts/bin"

# ============================================================================
# PARSE COMMAND LINE ARGUMENTS
# ============================================================================

SHOW_ANSI=0
STRIP_ANSI=0
FAIL_ONLY=0
KEEP_DIR=0
SIDE_BY_SIDE=0
ONLY_TESTS=()
ONLY_MODE=0

# shellcheck disable=SC2034  # Variables set for future use
while [ $# -gt 0 ]; do
  case "${1:-}" in
    --show-ansi) SHOW_ANSI=1; shift ;;
    --strip-ansi) STRIP_ANSI=1; shift ;;
    --fail-only) FAIL_ONLY=1; shift ;;
    --keep-dir) KEEP_DIR=1; shift ;;
    --side-by-side) SIDE_BY_SIDE=1; shift ;;
    --only) ONLY_MODE=1; ONLY_TESTS+=("$2"); shift 2 ;;
    --only=*) ONLY_MODE=1; ONLY_TESTS+=("${1#--only=}"); shift ;;
    --help|-h) 
      cat <<'EOF'
Usage: ls-compare [OPTIONS] <ll_linux|ll_macos>

Compare ls -l output with ll implementation.

OPTIONS:
  --help, -h              Show this help message and exit
  --show-ansi             Make ANSI/control characters visible in diff output
  --strip-ansi            Strip ANSI codes for comparison (debugging only)
  --fail-only             Only print failing tests (still shows summary)
  --keep-dir              Do not delete test directory after tests complete
  --side-by-side          Display outputs side-by-side format
  --only <TEST>           Run only specific test case(s)

EXAMPLES:
  ls-compare ll_linux
  ls-compare --fail-only ll_macos
  ls-compare --side-by-side ll_linux
EOF
      exit 0
      ;;
    -*) echo "Unknown option: $1" >&2; exit 1 ;;
    *) break ;;
  esac
done

if [ $# -ne 1 ]; then
  echo "Error: exactly one script argument required (ll_linux or ll_macos)" >&2
  exit 1
fi

SCRIPT_NAME="$1"
case "$SCRIPT_NAME" in
  ll_linux)
    # GNU ls with --time-style
    if command -v gls >/dev/null 2>&1; then
      LS_BIN="$(command -v gls)"
    elif ls --color -l --time-style="+%s" . >/dev/null 2>&1; then
      LS_BIN="ls"
    elif [ -x /opt/local/libexec/gnubin/ls ]; then
      LS_BIN="/opt/local/libexec/gnubin/ls"
    else
      echo "Error: GNU ls required for ll_linux mode" >&2
      exit 1
    fi
    LS_FLAGS=("--color=always" "-l" "--time-style=+%s")
    ;;
  ll_macos)
    # BSD ls without --time-style
    LS_BIN="/bin/ls"
    LS_FLAGS=("-G" "-l")
    ;;
  *)
    echo "Error: script must be ll_linux or ll_macos" >&2
    exit 1
    ;;
esac

# ============================================================================
# SETUP TEST ENVIRONMENT
# ============================================================================

TEST_DIR="/tmp/ls-compare-test-$$"
mkdir -p "$TEST_DIR"
echo "Test directory: $TEST_DIR"
cd "$TEST_DIR" || exit 1

# Create test files
touch file1.txt file2.txt
mkdir dir1
chmod 755 file1.txt
chmod 644 file2.txt

# Extra filename edge cases
printf '' > "a b.txt"
printf '' > " file-leading-space.txt"
printf '' > $'a\tb.txt'
printf '' > "İçerik-ğüşöç.txt"
# Very long name (0 bytes as per requirement)
_long_name="$(printf 'a%.0s' {1..210}).txt"
printf '' > "$_long_name"

# Extra file types
ln -s "file1.txt" "symlink-to-file1" 2>/dev/null || true
ln -s "does-not-exist" "broken-symlink" 2>/dev/null || true
mkfifo "fifo1" 2>/dev/null || true

# Permissions edge cases
cp "file1.txt" "setuid-file" 2>/dev/null || true
chmod 4755 "setuid-file" 2>/dev/null || true
cp "file1.txt" "setgid-file" 2>/dev/null || true
chmod 2755 "setgid-file" 2>/dev/null || true
mkdir -p "setgid-dir" 2>/dev/null || true
chmod 2755 "setgid-dir" 2>/dev/null || true
mkdir -p "sticky-dir" 2>/dev/null || true
chmod 1777 "sticky-dir" 2>/dev/null || true

# Make mtimes deterministic (Jan 1, 2020 00:00:00 local time)
touch -t 202001010000.00 \
  file1.txt file2.txt dir1 \
  "a b.txt" " file-leading-space.txt" $'a\tb.txt' "İçerik-ğüşöç.txt" \
  "$_long_name" symlink-to-file1 broken-symlink \
  fifo1 setuid-file setgid-file setgid-dir sticky-dir 2>/dev/null || true

# Set LL_NOW_EPOCH if not already set
if [ -z "${LL_NOW_EPOCH:-}" ]; then
  export LL_NOW_EPOCH=1577836800
fi

# Helper: convert an epoch (seconds) into a touch -t timestamp
epoch_to_touch_ts() {
  local epoch="${1:?epoch required}"
  if date -r "$epoch" +%Y%m%d%H%M.%S >/dev/null 2>&1; then
    date -r "$epoch" +%Y%m%d%H%M.%S
    return 0
  fi
  if date -d "@${epoch}" +%Y%m%d%H%M.%S >/dev/null 2>&1; then
    date -d "@${epoch}" +%Y%m%d%H%M.%S
    return 0
  fi
  return 1
}

# Create timestamp boundary fixtures relative to LL_NOW_EPOCH
create_mtime_fixture() {
  local name="${1:?name required}"
  local delta="${2:?delta seconds required}"
  local target_epoch=$((LL_NOW_EPOCH - delta))
  local ts
  ts=$(epoch_to_touch_ts "$target_epoch") || return 0
  printf '' > "$name"
  touch -t "$ts" "$name" 2>/dev/null || true
}

create_future_mtime_fixture() {
  local name="${1:?name required}"
  local delta="${2:?delta seconds required}"
  local target_epoch=$((LL_NOW_EPOCH + delta))
  local ts
  ts=$(epoch_to_touch_ts "$target_epoch") || return 0
  printf '' > "$name"
  touch -t "$ts" "$name" 2>/dev/null || true
}

create_mtime_fixture "mtime-now-1s" 1
create_mtime_fixture "mtime-now-119s" 119
create_mtime_fixture "mtime-now-120s" 120
create_mtime_fixture "mtime-now-3599s" 3599
create_mtime_fixture "mtime-now-3600s" 3600
create_mtime_fixture "mtime-now-2days" 172800
create_future_mtime_fixture "mtime-now-3yr" $((3 * 31536000))
create_future_mtime_fixture "mtime-now-35yr" $((35 * 31536000))
create_future_mtime_fixture "mtime-now-125yr" $((125 * 31536000))

# Symlink target with space
mkdir -p "case-symlink-target-space"
printf '' > "case-symlink-target-space/target file.txt"
ln -s "target file.txt" "case-symlink-target-space/link name.txt" 2>/dev/null || true
touch -t 202001010000.00 "case-symlink-target-space/target file.txt" 2>/dev/null || true
touch -h -t 202001010000.00 "case-symlink-target-space/link name.txt" 2>/dev/null || true

# Symlink target with tab
mkdir -p "case-symlink-target-tab"
_tab_target=$'t\ta'
_tab_link=$'l\ti'
printf '' > "case-symlink-target-tab/$_tab_target"
ln -s "$_tab_target" "case-symlink-target-tab/$_tab_link" 2>/dev/null || true
touch -t 202001010000.00 "case-symlink-target-tab/$_tab_target" 2>/dev/null || true
touch -h -t 202001010000.00 "case-symlink-target-tab/$_tab_link" 2>/dev/null || true

# Future-only listing
mkdir -p "case-future-only"
printf '' > "case-future-only/f1.txt"
printf '' > "case-future-only/f2.txt"
_f1_epoch=$((LL_NOW_EPOCH + 2 * 24 * 3600))
_f2_epoch=$((LL_NOW_EPOCH + 12 * 24 * 3600))
_f1_ts=$(epoch_to_touch_ts "$_f1_epoch") || _f1_ts=""
_f2_ts=$(epoch_to_touch_ts "$_f2_epoch") || _f2_ts=""
if [ -n "$_f1_ts" ]; then
  touch -t "$_f1_ts" "case-future-only/f1.txt" 2>/dev/null || true
fi
if [ -n "$_f2_ts" ]; then
  touch -t "$_f2_ts" "case-future-only/f2.txt" 2>/dev/null || true
fi

# Mixed units and time widths
mkdir -p "case-mixed-time-width"
printf '' > "case-mixed-time-width/sec.txt"
printf '' > "case-mixed-time-width/hrs.txt"
printf '' > "case-mixed-time-width/day.txt"
printf '' > "case-mixed-time-width/mon.txt"
printf '' > "case-mixed-time-width/future-3yr.txt"
printf '' > "case-mixed-time-width/future-35yr.txt"
printf '' > "case-mixed-time-width/future-125yr.txt"
printf '' > "case-mixed-time-width/future-1000yr.txt"
_sec_epoch=$((LL_NOW_EPOCH - 5))
_hrs_epoch=$((LL_NOW_EPOCH - 3 * 3600))
_day_epoch=$((LL_NOW_EPOCH - 12 * 24 * 3600))
_mon_epoch=$((LL_NOW_EPOCH - 120 * 24 * 3600))
_yr3_epoch=$((LL_NOW_EPOCH + 3 * 31536000))
_yr35_epoch=$((LL_NOW_EPOCH + 35 * 31536000))
_yr125_epoch=$((LL_NOW_EPOCH + 125 * 31536000))
_yr1000_epoch=$((LL_NOW_EPOCH + 1000 * 31536000))
_sec_ts=$(epoch_to_touch_ts "$_sec_epoch") || _sec_ts=""
_hrs_ts=$(epoch_to_touch_ts "$_hrs_epoch") || _hrs_ts=""
_day_ts=$(epoch_to_touch_ts "$_day_epoch") || _day_ts=""
_mon_ts=$(epoch_to_touch_ts "$_mon_epoch") || _mon_ts=""
_yr3_ts=$(epoch_to_touch_ts "$_yr3_epoch") || _yr3_ts=""
_yr35_ts=$(epoch_to_touch_ts "$_yr35_epoch") || _yr35_ts=""
_yr125_ts=$(epoch_to_touch_ts "$_yr125_epoch") || _yr125_ts=""
_yr1000_ts=$(epoch_to_touch_ts "$_yr1000_epoch") || _yr1000_ts=""
if [ -n "$_sec_ts" ]; then
  touch -t "$_sec_ts" "case-mixed-time-width/sec.txt" 2>/dev/null || true
fi
if [ -n "$_hrs_ts" ]; then
  touch -t "$_hrs_ts" "case-mixed-time-width/hrs.txt" 2>/dev/null || true
fi
if [ -n "$_day_ts" ]; then
  touch -t "$_day_ts" "case-mixed-time-width/day.txt" 2>/dev/null || true
fi
if [ -n "$_mon_ts" ]; then
  touch -t "$_mon_ts" "case-mixed-time-width/mon.txt" 2>/dev/null || true
fi
if [ -n "$_yr3_ts" ]; then
  touch -t "$_yr3_ts" "case-mixed-time-width/future-3yr.txt" 2>/dev/null || true
fi
if [ -n "$_yr35_ts" ]; then
  touch -t "$_yr35_ts" "case-mixed-time-width/future-35yr.txt" 2>/dev/null || true
fi
if [ -n "$_yr125_ts" ]; then
  touch -t "$_yr125_ts" "case-mixed-time-width/future-125yr.txt" 2>/dev/null || true
fi
if [ -n "$_yr1000_ts" ]; then
  touch -t "$_yr1000_ts" "case-mixed-time-width/future-1000yr.txt" 2>/dev/null || true
fi

# ============================================================================
# TEST CASES
# ============================================================================

test_case_names=(
  "default"
  "-d"
  "--directory"
  "-d ."
  "-g"
  "-G"
  "-o"
  "--no-group"
  "-g -G"
  "-s"
  "--size"
  "-h"
