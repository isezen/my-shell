strip_ansi_and_controls() {
  # Removes ANSI escape sequences and common control chars from a string.
  # Keeps ordinary whitespace intact.
  local text="$1"

  text=$(printf '%s' "$text" | perl -pe '
    s/\e\[[0-9;?]*[ -\/]*[@-~]//g;          # CSI ... cmd (colors, erase-in-line, etc.)
    s/\e\][^\a]*(\a|\e\\)//g;              # OSC ... BEL or ST
    s/\e[P^_].*?(\e\\)//gs;                # DCS/PM/APC ... ST
    s/\e[()#][0-9A-Za-z]//g;               # Charset selects
    s/\e[\x40-\x5F]//g;                    # 2-char ESC sequences
    s/\x1b\[[0-9;]*K//g;                   # Erase in line
    s/\r//g;                               # CR
  ')

  text=$(printf '%s' "$text" | tr -d '\v')
  printf '%s' "$text"
}

drop_ls_totals() {
  perl -ne 'print unless /^\s*(toplam|total)\b/i'
}

canonicalize_ls_output() {
  # Convert: ls -l --time-style=+"%s" output -> canonical ll-like text.
  # Canonical form: single-space separated fields up to relative time,
  # then keep the remainder of the line verbatim (preserves leading-space filenames).
  local raw="$1"

  raw="$(strip_ansi_and_controls "$raw")"

  printf '%s\n' "$raw" \
    | drop_ls_totals \
    | perl "$PROJECT_ROOT/scripts/dev/ls-compare-canon-ls.pl"
}

# Canonicalize ll/ll-chatgpt outputs into the same canonical form as canonicalize_ls_output():
# - strip ANSI/control sequences
# - drop total/toplam header lines
# - normalize only the token-prefix (mode/links/owner/group/size/time)
# - keep the tail verbatim to preserve tricky filenames (spaces, tabs, unicode) and symlink arrows
canonicalize_script_output() {
  local raw="$1"

  raw="$(strip_ansi_and_controls "$raw")"

  printf '%s\n' "$raw" \
    | drop_ls_totals \
    | perl "$PROJECT_ROOT/scripts/dev/ls-compare-canon-script.pl"
}

validate_ll_output() {
  local raw="$1"
  local future_line=""
  local -a future_candidates=(
    "mtime-now-3yr"
    "mtime-now-35yr"
    "mtime-now-125yr"
    "future-3yr.txt"
    "future-35yr.txt"
    "future-125yr.txt"
    "future-1000yr.txt"
  )

  for candidate in "${future_candidates[@]}"; do
    future_line="$(printf '%s\n' "$raw" | grep -F "$candidate" | head -n 1)"
    if [ -n "$future_line" ]; then
      break
    fi
  done
  if [ -z "$future_line" ]; then
    return 0
  fi

  printf '%s' "$future_line" | perl -ne 'exit 0 if /\e\[38;5;39m/; exit 1;'
}

# ============================================================================
# Side-by-side comparison function
# ============================================================================
print_side_by_side() {
  # Function to strip ANSI color codes for length calculation
  strip_colors() {
    local text="$1"

    # If we are showing ANSI visibly, do not strip anything.
    if [ "${SHOW_ANSI}" -eq 1 ]; then
      echo "$text"
      return 0
    fi

    # Strip ANSI escape sequences robustly (CSI/OSC/etc.).
    printf '%s' "$text" | perl -pe '
      s/\e\[[0-9;?]*[ -\/]*[@-~]//g;          # CSI ... cmd
      s/\e\][^\a]*(\a|\e\\)//g;              # OSC ... BEL or ST
      s/\e[P^_].*?(\e\\)//gs;                # DCS/PM/APC ... ST
      s/\e[()#][0-9A-Za-z]//g;                 # Charset selects
      s/\e[\x40-\x5F]//g;                     # 2-char ESC sequences
      s/\e\[K//g;                               # Erase in line (some emitters)
    '
  }

  make_ansi_visible() {
    # Render control chars (including ESC) as visible escape sequences, without line-wrapping.
    # This avoids `sed -n 'l'` behavior that inserts backslash-newline continuations and trailing `$`.
    # NOTE: Input is a single line (caller reads line-by-line).
    perl -pe 's/\e/\\033/g; s/\t/\\t/g; s/\r/\\r/g; s/\f/\\f/g; s/\v/\\v/g' <<<"$1"
  }

  # Convert each output to temp file for line-by-line processing
  # If SHOW_ANSI is enabled, use raw outputs (with ANSI codes), otherwise use canonicalized outputs
  declare -a output_files
  declare -a source_outputs
  if [ "${SHOW_ANSI}" -eq 1 ]; then
    source_outputs=("${outputs_raw[@]}")
  else
    source_outputs=("${outputs[@]}")
  fi
  
  output_files[0]=$(mktemp)
  echo "${source_outputs[0]}" > "${output_files[0]}"
  for i in $(seq 1 $((${#source_outputs[@]} - 1))); do
    output_files[i]=$(mktemp)
    echo "${source_outputs[i]}" > "${output_files[i]}"
  done

  # Find maximum number of lines
  max_lines=0
  for i in $(seq 0 $((${#source_outputs[@]} - 1))); do
    line_count=$(wc -l < "${output_files[$i]}")
    if [ "$line_count" -gt "$max_lines" ]; then
      max_lines=$line_count
    fi
  done

  # Find maximum line length for each output (for proper padding)
  declare -a max_lens
  for i in $(seq 0 $((${#source_outputs[@]} - 1))); do
    max_lens[i]=0
    while IFS= read -r line; do
      if [ "${SHOW_ANSI}" -eq 1 ]; then
        line_for_len=$(make_ansi_visible "$line")
      else
        line_for_len=$(strip_colors "$line")
      fi
      line_len=${#line_for_len}
      if [ "$line_len" -gt "${max_lens[i]}" ]; then
        max_lens[i]=$line_len
      fi
    done < "${output_files[$i]}"
  done

  # Print side-by-side with proper padding
  for line_num in $(seq 1 "$max_lines"); do
    result_line=""

    # Process each output column
    for i in $(seq 0 $((${#source_outputs[@]} - 1))); do
      line=$(sed -n "${line_num}p" "${output_files[$i]}")
      if [ "${SHOW_ANSI}" -eq 1 ] && [ -n "$line" ]; then
        line=$(make_ansi_visible "$line")
      fi
      if [ -z "$line" ]; then
        line=""
      fi

      # Calculate padding needed for this line (based on length without colors)
      # If SHOW_ANSI is enabled, line is already processed by make_ansi_visible,
      # so we need to strip the visible ANSI sequences (\033) for length calculation
      if [ "${SHOW_ANSI}" -eq 1 ]; then
        # For visible ANSI, we need to account for the \033 sequences in the length
        # make_ansi_visible converts \e to \033, so we need to count the actual visible characters
        # We'll use the line as-is since make_ansi_visible already converted escape sequences
        line_for_len=$(echo "$line" | perl -pe 's/\\033\[[0-9;?]*[ -\/]*[@-~]//g; s/\\033//g')
      else
        line_for_len=$(strip_colors "$line")
      fi
      line_len=${#line_for_len}
      padding_len=$((max_lens[i] - line_len))
      if [ "$padding_len" -gt 0 ]; then
        padding=$(printf "%*s" "$padding_len" "")
        line="${line}${padding}"
      fi

      # Add separator before each column (except first)
      if [ "$i" -gt 0 ]; then
        result_line="${result_line} |"
      fi
      result_line="${result_line} ${line}"
    done

    echo "  $result_line"
  done

  # Cleanup temp files
  for temp_file in "${output_files[@]}"; do
    rm -f "$temp_file"
  done
}

# ============================================================================
# Vertical/stacked comparison function
# ============================================================================
print_vertical() {
  # Print outputs in vertical/stacked format:
  # 1. ls -l output first (with test case parameters if any)
  # 2. Then each script output below it (with test case parameters if any)
  
  # ANSI color codes
  local color_red=$'\033[31m'
  local color_reset=$'\033[0m'
  
  # Function to make ANSI characters visible (same as in print_side_by_side)
  make_ansi_visible() {
    # Render control chars (including ESC) as visible escape sequences, without line-wrapping.
    # This avoids `sed -n 'l'` behavior that inserts backslash-newline continuations and trailing `$`.
    # NOTE: Input is a single line (caller reads line-by-line).
    perl -pe 's/\e/\\033/g; s/\t/\\t/g; s/\r/\\r/g; s/\f/\\f/g; s/\v/\\v/g' <<<"$1"
  }
  
  # Build parameter string for display
  param_str=""
  if [ ${#tc_argv_clean[@]} -gt 0 ]; then
    param_str=" ${tc_argv_clean[*]}"
  fi
  
  # Print ls command in red (excluding the colon)
  echo "  ${color_red}ls -l --color --time-style=+\"%s\"${param_str}${color_reset}:"
  # Apply make_ansi_visible if SHOW_ANSI is enabled
  if [ "${SHOW_ANSI}" -eq 1 ]; then
    while IFS= read -r line; do
      make_ansi_visible "$line"
    done <<<"${outputs_raw[0]}"
  else
    echo "${outputs_raw[0]}"
  fi
  
  # Print each script output
  # outputs_raw[0] = ls output
  # outputs_raw[1] = first script (script_names[0])
  # outputs_raw[2] = second script (script_names[1]), etc.
  for i in $(seq 1 $((${#outputs_raw[@]} - 1))); do
    script_idx=$((i - 1))
    echo ""
    if [ "$script_idx" -lt ${#script_names[@]} ]; then
      # Print script command in red (excluding the colon)
      echo "  ${color_red}${script_names[$script_idx]}${param_str}${color_reset}:"
    else
      echo "  ${color_red}Script #$i${param_str}${color_reset}:"
    fi
    # Apply make_ansi_visible if SHOW_ANSI is enabled
    if [ "${SHOW_ANSI}" -eq 1 ]; then
      while IFS= read -r line; do
        make_ansi_visible "$line"
      done <<<"${outputs_raw[$i]}"
    else
      echo "${outputs_raw[$i]}"
    fi
  done
}

for idx in "${!test_case_names[@]}"; do
  test_name="${test_case_names[$idx]}"
  test_argv_snippet="${test_case_argv[$idx]}"
  
  # Calculate the actual test number (idx + 1, since arrays are 0-indexed)
  actual_test_num=$((idx + 1))

  if [ "$ONLY_MODE" -eq 1 ]; then
    matched=0
    for only in "${ONLY_TESTS[@]}"; do
      # Check if --only value is a number
      if [[ "$only" =~ ^[0-9]+$ ]]; then
        # It's a test number - check if it matches this test's number
        if [ "$only" -eq "$actual_test_num" ]; then
          matched=1
          break
        fi
      else
        # It's a test case name - check if it matches
        if [ "$only" = "$test_name" ]; then
          matched=1
          break
        fi
      fi
    done
    if [ "$matched" -eq 0 ]; then
      continue
    fi
  fi

  # Use the actual test number (not a sequential counter)
  test_num=$actual_test_num
  
  # Build argv array from bash snippet (supports quoted filenames)
  tc_argv=()
  if [ -n "$test_argv_snippet" ]; then
    # shellcheck disable=SC2086
    eval "tc_argv=($test_argv_snippet)"
  fi

  # Some scripts under test may forward args to `ls` in a way that breaks when `--` is present.
  # For our fixtures, `--` is only used to safely express filenames with spaces/tabs/unicode.
  # Strip a *leading* `--` so we don't accidentally turn our injected `-l` / `--time-style` into operands.
  tc_argv_clean=("${tc_argv[@]}")
  if [ "${#tc_argv_clean[@]}" -gt 0 ] && [ "${tc_argv_clean[0]}" = "--" ]; then
    tc_argv_clean=("${tc_argv_clean[@]:1}")
    # Also clean test_name: remove leading "-- " if present (since -- is not part of actual command)
    if [[ "$test_name" =~ ^--[[:space:]]+(.*)$ ]]; then
      test_name="${BASH_REMATCH[1]}"
    fi
  fi
  
  if [ "$FAIL_ONLY" -eq 0 ] || [ ${#script_paths[@]} -eq 0 ]; then
    # Color codes
    color_yellow=$'\033[33m'
    color_magenta=$'\033[35m'
    color_reset=$'\033[0m'
    
    # Test number in magenta
    test_num_colored="${color_magenta}Test #$test_num${color_reset}"
    
    # Colorize the entire test name (everything after "Test #X:") in yellow
    display_test_name="${color_yellow}${test_name}${color_reset}"
    
    echo "$test_num_colored: $display_test_name"
    echo "----------------------------------"
  fi

  # Detect formatting-affecting flags so we can canonicalize ls output to match ll-chatgpt.
  HAS_BLOCKS=0
  HAS_HUMAN=0
  for a in "${tc_argv_clean[@]}"; do
    case "$a" in
      -s|--size)
        HAS_BLOCKS=1
        ;;
      -h|--human-readable|--si)
        HAS_HUMAN=1
        ;;
    esac
  done

  export LS_COMPARE_HAS_BLOCKS LS_COMPARE_HAS_HUMAN
  LS_COMPARE_HAS_BLOCKS="$HAS_BLOCKS"
  LS_COMPARE_HAS_HUMAN="$HAS_HUMAN"

  # Run ls -l with the same operands as scripts, then canonicalize ls output into ll-like format.
  # IMPORTANT: options MUST come before any `--` sentinel in tc_argv, otherwise ls will
  # treat `-l` and `--time-style=...` as filenames and print errors like:
  #   ls: '-l' ... No such file or directory
  # To avoid that, we always place ls options first and then append tc_argv.
  ls_cmd=("$LS_BIN" --color -l --time-style=+"%s")

  # ls doesn't accept options after operands; normalize argv for ls only.
  ls_opts=()
  ls_operands=()
  for a in "${tc_argv_clean[@]}"; do
    case "$a" in
      -d|--directory|-g|-G|-o|--no-group|-s|--size|-h|--human-readable|--si|-n|--numeric-uid-gid)
        ls_opts+=("$a")
        ;;
      *)
        ls_operands+=("$a")
        ;;
    esac
  done
  ls_argv=("${ls_opts[@]}" "${ls_operands[@]}")

  ls_stdout_file=$(mktemp)
  ls_stderr_file=$(mktemp)
  (cd "$TEST_DIR" && "${ls_cmd[@]}" "${ls_argv[@]}" >"$ls_stdout_file" 2>"$ls_stderr_file")
  ls_status=$?
  ls_stdout_raw="$(cat "$ls_stdout_file")"
  ls_stderr_raw="$(cat "$ls_stderr_file")"
  rm -f "$ls_stdout_file" "$ls_stderr_file"

  # Export env for canonicalizers
  export LS_COMPARE_USER
  export LS_COMPARE_NOW_EPOCH
  LS_COMPARE_USER="$(id -un 2>/dev/null || true)"
  LS_COMPARE_NOW_EPOCH="${LL_NOW_EPOCH:-$(date +%s)}"

  # If no scripts provided, just show ls stdout
  if [ ${#script_paths[@]} -eq 0 ]; then
    echo "$ls_stdout_raw"
    ((passed++))
  else
    # Run all scripts and capture outputs
    outputs_out=()
    outputs_err=()
    outputs_out_raw=()
    outputs_err_raw=()
    script_statuses=()
    validation_failed=0
    validation_msg=""
    status_failed=0
    status_msg=""
    stdout_match=true
    stderr_match=true

    # Column 0 is the ls baseline
    outputs_out_raw+=("$ls_stdout_raw")
    outputs_err_raw+=("$ls_stderr_raw")
    outputs_out+=("$(canonicalize_ls_output "$ls_stdout_raw")")
    outputs_err+=("$(canonicalize_ls_output "$ls_stderr_raw")")
    if [ "$ls_status" -ne 0 ]; then
      status_failed=1
      status_msg="ls exit $ls_status"
    fi

    for i in "${!script_paths[@]}"; do
      script_path="${script_paths[$i]}"
      script_name="${script_names[$i]}"
      script_stdout_file=$(mktemp)
      script_stderr_file=$(mktemp)
      (cd "$TEST_DIR" && "$script_path" "${tc_argv_clean[@]}" >"$script_stdout_file" 2>"$script_stderr_file")
      script_status=$?
      output_stdout_raw="$(cat "$script_stdout_file")"
      output_stderr_raw="$(cat "$script_stderr_file")"
      rm -f "$script_stdout_file" "$script_stderr_file"
      script_statuses+=("$script_status")
      outputs_out_raw+=("$output_stdout_raw")
      outputs_err_raw+=("$output_stderr_raw")
      outputs_out+=("$(canonicalize_script_output "$output_stdout_raw")")
      outputs_err+=("$(canonicalize_script_output "$output_stderr_raw")")
      if [ "$script_name" = "ll" ] || [ "$script_name" = "ll_linux" ]; then
        if ! validate_ll_output "$output_stdout_raw"; then
          validation_failed=1
          validation_msg="future time color missing"
        fi
      fi
      if [ "$script_status" -ne 0 ]; then
        status_failed=1
        if [ -n "$status_msg" ]; then
          status_msg="${status_msg}; ${script_name} exit ${script_status}"
        else
          status_msg="${script_name} exit ${script_status}"
        fi
      fi
    done

    # Check if stdout/stderr outputs match baseline exactly after canonicalization.
    all_match=true
    baseline_out="${outputs_out[0]}"
    for i in $(seq 1 $((${#outputs_out[@]} - 1))); do
      candidate_out="${outputs_out[$i]}"
      if [ "$candidate_out" != "$baseline_out" ]; then
        stdout_match=false
        break
      fi
    done
    baseline_err="${outputs_err[0]}"
    for i in $(seq 1 $((${#outputs_err[@]} - 1))); do
      candidate_err="${outputs_err[$i]}"
      if [ "$candidate_err" != "$baseline_err" ]; then
        stderr_match=false
        break
      fi
    done

    # Raw output comparison to detect normalized passes (whitespace/ANSI-only diffs).
    raw_stdout_match=true
    baseline_out_raw="${outputs_out_raw[0]}"
    for i in $(seq 1 $((${#outputs_out_raw[@]} - 1))); do
      candidate_out_raw="${outputs_out_raw[$i]}"
      if [ "$candidate_out_raw" != "$baseline_out_raw" ]; then
        raw_stdout_match=false
        break
      fi
    done
    raw_stderr_match=true
    baseline_err_raw="${outputs_err_raw[0]}"
    for i in $(seq 1 $((${#outputs_err_raw[@]} - 1))); do
      candidate_err_raw="${outputs_err_raw[$i]}"
      if [ "$candidate_err_raw" != "$baseline_err_raw" ]; then
        raw_stderr_match=false
        break
      fi
    done
    
    if [ "$validation_failed" -eq 1 ] || [ "$status_failed" -eq 1 ] || [ "$stdout_match" = false ] || [ "$stderr_match" = false ]; then
      all_match=false
    fi

    normalized_only=false
    if [ "$all_match" = true ] && [ "$raw_stdout_match" = false -o "$raw_stderr_match" = false ]; then
      normalized_only=true
    fi

    if [ "$all_match" = true ]; then
      if [ "$FAIL_ONLY" -eq 0 ]; then
        if [ "$SIDE_BY_SIDE" -eq 1 ]; then
          if [ "$normalized_only" = true ]; then
            echo "PASS (normalized) - Outputs differ only by whitespace/ANSI formatting"
          else
            echo "PASS - All outputs match exactly"
          fi
          echo "  Side-by-side comparison:"
          outputs=("${outputs_out[@]}")
          outputs_raw=("${outputs_out_raw[@]}")
          print_side_by_side
        else
          if [ "$normalized_only" = true ]; then
            echo "PASS (normalized) - Outputs differ only by whitespace/ANSI formatting"
          fi
          # Vertical format: show outputs directly without "PASS" message for exact match
          outputs_raw=("${outputs_out_raw[@]}")
          print_vertical
        fi
      fi
      ((passed++))
    else
      if [ "$FAIL_ONLY" -eq 0 ]; then
        if [ "$SIDE_BY_SIDE" -eq 1 ]; then
          fail_reasons=()
          if [ "$status_failed" -eq 1 ]; then
            fail_reasons+=("Non-zero exit status (${status_msg})")
          fi
          if [ "$validation_failed" -eq 1 ]; then
            fail_reasons+=("Formatting validation failed (${validation_msg})")
          fi
          if [ "$stdout_match" = false ]; then
            fail_reasons+=("STDOUT differs")
          fi
          if [ "$stderr_match" = false ]; then
            fail_reasons+=("STDERR differs")
          fi
          if [ "${#fail_reasons[@]}" -gt 0 ]; then
            IFS='; ' printf 'FAIL - %s\n' "${fail_reasons[*]}"
            unset IFS
          else
            echo "FAIL - Outputs differ"
          fi
          show_stdout=0
          show_stderr=0
          if [ "$stdout_match" = false ]; then
            show_stdout=1
          fi
          if [ "$stderr_match" = false ]; then
            show_stderr=1
          fi
          if [ "$show_stdout" -eq 0 ] && [ "$show_stderr" -eq 0 ]; then
            show_stdout=1
            show_stderr=1
          fi
          if [ "$show_stdout" -eq 1 ]; then
            echo "  STDOUT:"
            outputs=("${outputs_out[@]}")
            outputs_raw=("${outputs_out_raw[@]}")
            print_side_by_side
          fi
          if [ "$show_stderr" -eq 1 ]; then
            echo "  STDERR:"
            outputs=("${outputs_err[@]}")
            outputs_raw=("${outputs_err_raw[@]}")
            print_side_by_side
          fi
        else
          fail_reasons=()
          if [ "$status_failed" -eq 1 ]; then
            fail_reasons+=("Non-zero exit status (${status_msg})")
          fi
          if [ "$validation_failed" -eq 1 ]; then
            fail_reasons+=("Formatting validation failed (${validation_msg})")
          fi
          if [ "$stdout_match" = false ]; then
            fail_reasons+=("STDOUT differs")
          fi
          if [ "$stderr_match" = false ]; then
            fail_reasons+=("STDERR differs")
          fi
          if [ "${#fail_reasons[@]}" -gt 0 ]; then
            IFS='; ' printf 'FAIL - %s\n' "${fail_reasons[*]}"
            unset IFS
          else
            echo "FAIL - Outputs differ"
          fi
          show_stdout=0
          show_stderr=0
          if [ "$stdout_match" = false ]; then
            show_stdout=1
          fi
          if [ "$stderr_match" = false ]; then
            show_stderr=1
          fi
          if [ "$show_stdout" -eq 0 ] && [ "$show_stderr" -eq 0 ]; then
            show_stdout=1
            show_stderr=1
          fi
          if [ "$show_stdout" -eq 1 ]; then
            echo "  STDOUT:"
            outputs_raw=("${outputs_out_raw[@]}")
            print_vertical
          fi
          if [ "$show_stderr" -eq 1 ]; then
            echo "  STDERR:"
            outputs_raw=("${outputs_err_raw[@]}")
            print_vertical
          fi
        fi
      else
        echo "Test #$test_num: $test_name"
        echo "----------------------------------"
        fail_reasons=()
        if [ "$status_failed" -eq 1 ]; then
          fail_reasons+=("Non-zero exit status (${status_msg})")
        fi
        if [ "$validation_failed" -eq 1 ]; then
          fail_reasons+=("Formatting validation failed (${validation_msg})")
        fi
        if [ "$stdout_match" = false ]; then
          fail_reasons+=("STDOUT differs")
        fi
        if [ "$stderr_match" = false ]; then
          fail_reasons+=("STDERR differs")
        fi
        if [ "${#fail_reasons[@]}" -gt 0 ]; then
          IFS='; ' printf 'FAIL - %s\n' "${fail_reasons[*]}"
          unset IFS
        else
          echo "FAIL - Outputs differ"
        fi
        show_stdout=0
        show_stderr=0
        if [ "$stdout_match" = false ]; then
          show_stdout=1
        fi
        if [ "$stderr_match" = false ]; then
          show_stderr=1
        fi
        if [ "$show_stdout" -eq 0 ] && [ "$show_stderr" -eq 0 ]; then
          show_stdout=1
          show_stderr=1
        fi
        if [ "$SIDE_BY_SIDE" -eq 1 ]; then
          if [ "$show_stdout" -eq 1 ]; then
            echo "  STDOUT:"
            outputs=("${outputs_out[@]}")
            outputs_raw=("${outputs_out_raw[@]}")
            print_side_by_side
          fi
          if [ "$show_stderr" -eq 1 ]; then
            echo "  STDERR:"
            outputs=("${outputs_err[@]}")
            outputs_raw=("${outputs_err_raw[@]}")
            print_side_by_side
          fi
        else
          if [ "$show_stdout" -eq 1 ]; then
            echo "  STDOUT:"
            outputs_raw=("${outputs_out_raw[@]}")
            print_vertical
          fi
          if [ "$show_stderr" -eq 1 ]; then
            echo "  STDERR:"
            outputs_raw=("${outputs_err_raw[@]}")
            print_vertical
          fi
        fi
      fi
      ((errors++))
    fi
  fi
  
  # Add blank line between tests:
  # - Normal mode: always separate tests.
  # - --fail-only: only separate failing tests (avoid printing blank lines for skipped passes).
  # - If no scripts provided: always separate tests (we're just showing ls output).
  if [ "$FAIL_ONLY" -eq 0 ] || [ ${#script_paths[@]} -eq 0 ]; then
    echo ""
  else
    if [ "$all_match" = false ]; then
      echo ""
    fi
  fi
done

if [ "$FAIL_ONLY" -eq 0 ]; then
  echo ""
  echo "=================================="
fi
echo "Results: $passed passed, $errors failed"

# ============================================================================
# CLEANUP
