  "-- setgid-file"
  "-- setgid-dir"
  "-- sticky-dir"
  "mtime-now-1s"
  "mtime-now-119s"
  "mtime-now-120s"
  "mtime-now-3599s"
  "mtime-now-3600s"
  "mtime-now-2days"
  "mtime-now-3yr"
  "mtime-now-35yr"
  "mtime-now-125yr"
  "case-symlink-target-space"
  "case-symlink-target-tab"
  "case-future-only"
  "case-mixed-time-width"
)

if [ "${#test_case_names[@]}" -ne "${#test_case_argv[@]}" ]; then
  echo "Internal error: test_case_names and test_case_argv length mismatch" >&2
  exit 2
fi

# ============================================================================
# UTILITY FUNCTIONS
# ============================================================================

strip_ansi_and_controls() {
  local text="$1"
  text=$(printf '%s' "$text" | perl -pe '
    s/\e\[[0-9;?]*[ -\/]*[@-~]//g;
    s/\e\][^\a]*(\a|\e\\)//g;
    s/\e[P^_].*?(\e\\)//gs;
    s/\e[()#][0-9A-Za-z]//g;
    s/\e[\x40-\x5F]//g;
    s/\x1b\[[0-9;]*K//g;
    s/\r//g;
  ')
  text=$(printf '%s' "$text" | tr -d '\v')
  printf '%s' "$text"
}

# Set environment variables for canonicalization based on flags
set_compare_env() {
  local arg

  LS_COMPARE_HAS_BLOCKS=0
  LS_COMPARE_HAS_HUMAN=0

  for arg in "$@"; do
    case "$arg" in
      -s|--size)
        LS_COMPARE_HAS_BLOCKS=1
        ;;
      -h|--human-readable|--si)
        LS_COMPARE_HAS_HUMAN=1
        ;;
      *)
        ;;
    esac
  done

  export LS_COMPARE_HAS_BLOCKS
  export LS_COMPARE_HAS_HUMAN
}

# Canonicalize output for comparison using Perl scripts
# Normalizes both ls and script output into comparable format
canonicalize_output() {
  local output="$1"
  local is_script="${2:-0}"
  
  # Strip ANSI codes first
  output=$(strip_ansi_and_controls "$output")
  
  # Drop total/toplam lines
  output=$(printf '%s\n' "$output" | perl -ne 'print unless /^\s*(toplam|total)\b/i')
  
  # Ensure environment variables are set
  export LS_COMPARE_NOW_EPOCH="${LL_NOW_EPOCH:-$(date +%s)}"
  export LS_COMPARE_USER="${USER}"
  
  # Use appropriate canonicalization script
  if [ "$is_script" -eq 1 ]; then
    # Canonicalize script output (ll_linux, ll_macos)
    printf '%s\n' "$output" | perl "${PROJECT_ROOT}/scripts/dev/ls-compare-canon-script.pl"
  else
    # Canonicalize ls output (gls, /bin/ls)
    printf '%s\n' "$output" | perl "${PROJECT_ROOT}/scripts/dev/ls-compare-canon-ls.pl"
  fi
}

# Compare canonicalized outputs
print_comparison() {
  # Compare ls output with script output using canonicalization
  # This allows format differences (times, usernames) to be normalized before comparison
  local ls_output="$1"
  local script_output="$2"

  local ls_canon
  local script_canon
  
  # Canonicalize both outputs
  ls_canon=$(canonicalize_output "$ls_output" 0)
  script_canon=$(canonicalize_output "$script_output" 1)

  # Compare canonicalized outputs
  if [ "$ls_canon" = "$script_canon" ]; then
    return 0
  fi
  return 1
}

print_header() {
  local color_magenta=$'\033[35m'
  local color_yellow=$'\033[33m'
  local color_reset=$'\033[0m'

  local test_num_colored="${color_magenta}Test #${actual_test_num}${color_reset}"
  local display_test_name="${color_yellow}${test_name}${color_reset}"

  echo "${test_num_colored}: ${display_test_name}"
  echo "----------------------------------"
}

# ============================================================================
# RUN TESTS
# ============================================================================

errors=0
passed=0

if [ "$FAIL_ONLY" -eq 0 ]; then
  echo "Testing ls vs ll implementation"
  echo "=================================="
  echo ""
fi

for idx in "${!test_case_names[@]}"; do
  test_name="${test_case_names[$idx]}"
  test_argv_snippet="${test_case_argv[$idx]}"
  
  actual_test_num=$((idx + 1))

  if [ "$ONLY_MODE" -eq 1 ]; then
    matched=0
    for only in "${ONLY_TESTS[@]}"; do
      if [[ "$only" =~ ^[0-9]+$ ]]; then
        if [ "$only" -eq "$actual_test_num" ]; then
          matched=1
          break
        fi
      else
        if [ "$only" = "$test_name" ]; then
          matched=1
          break
        fi
      fi
    done
    if [ "$matched" -eq 0 ]; then
      continue
    fi
  fi

  # Build argv array from bash snippet
  tc_argv=()
  if [ -n "$test_argv_snippet" ]; then
    # shellcheck disable=SC2086
    eval "tc_argv=($test_argv_snippet)"
  fi

  # Strip leading -- from argv for display (it's only for safe parsing)
  tc_argv_clean=()
  for i in "${!tc_argv[@]}"; do
    arg="${tc_argv[$i]}"
    # Skip the first "--" if present
    if [ "$i" -eq 0 ] && [ "$arg" = "--" ]; then
      continue
    fi
    tc_argv_clean+=("$arg")
  done

  # Separate options from operands (ls needs options before operands)
  ls_opts=()
  ls_operands=()
  skip_test=0
  outcome=""
  skip_reason=""
  
  if [ "${#tc_argv_clean[@]}" -gt 0 ]; then
    for a in "${tc_argv_clean[@]}"; do
      case "$a" in
        -d|--directory|-g|-G|-o|--no-group|-s|--size|-h|--human-readable|--si|-n|--numeric-uid-gid)
          # For ll_macos mode, map GNU flags to BSD equivalents or skip
          if [ "$SCRIPT_NAME" = "ll_macos" ]; then
            case "$a" in
              --directory) ls_opts+=("-d") ;;
              --no-group) ls_opts+=("-o") ;;
              --human-readable) ls_opts+=("-h") ;;
              --numeric-uid-gid) ls_opts+=("-n") ;;
              --size) ls_opts+=("-s") ;;
              --si)
                # Policy B1: skip ll_macos tests with --si (unsupported on BSD ls)
                skip_test=1
                skip_reason="--si unsupported on BSD ls"
                ;;
              *)
                # Short flags pass through unchanged
                ls_opts+=("$a")
                ;;
            esac
          else
            # Linux: pass flags unchanged
            ls_opts+=("$a")
          fi
          ;;
        *)
          ls_operands+=("$a")
          ;;
      esac
    done
  fi

  # Skip test if unsupported on this platform
  if [ "$skip_test" -eq 1 ]; then
    outcome="SKIP"
    if [ -z "$skip_reason" ]; then
      skip_reason="--si unsupported on BSD ls"
    fi

    should_print=0
    if [ "$FAIL_ONLY" -eq 0 ]; then
      should_print=1
    elif [ "$outcome" = "FAIL" ] || [ "$outcome" = "SKIP" ]; then
      should_print=1
    fi

    if [ "$should_print" -eq 1 ]; then
      print_header
      echo "SKIP ($skip_reason)"
      echo ""
    fi
    continue
  fi

  # Build final command arrays for execution (exactly as will be run)
  # Initialize arrays if empty to avoid unbound variable errors
  ls_cmd_array=("$LS_BIN" "${LS_FLAGS[@]}")
  if [ "${#ls_opts[@]}" -gt 0 ]; then
    ls_cmd_array+=("${ls_opts[@]}")
  fi
  if [ "${#ls_operands[@]}" -gt 0 ]; then
    ls_cmd_array+=("${ls_operands[@]}")
  fi
  script_cmd_array=("$SCRIPT_NAME")
  if [ "${#tc_argv[@]}" -gt 0 ]; then
    script_cmd_array+=("${tc_argv[@]}")
  fi
  
  # Build command display strings (exact arrays joined by single space)
  ls_cmd_display="${ls_cmd_array[*]}"
  script_cmd_display="${script_cmd_array[*]}"

  # Run ls with exact command array
  ls_stdout_file=$(mktemp)
  ls_stderr_file=$(mktemp)
  (cd "$TEST_DIR" && "${ls_cmd_array[@]}" >"$ls_stdout_file" 2>"$ls_stderr_file" || true)
  ls_stdout="$(cat "$ls_stdout_file")"
  ls_stderr="$(cat "$ls_stderr_file")"
  rm -f "$ls_stdout_file" "$ls_stderr_file"
  
  # If no stdout but there's stderr, this is likely an error - use empty stdout
  if [ -z "$ls_stdout" ] && [ -n "$ls_stderr" ]; then
    ls_stdout="[ERROR] $ls_stderr"
  fi

  # Run ll implementation
  script_path="$BIN_DIR/$SCRIPT_NAME"
  if [ ! -f "$script_path" ] || [ ! -x "$script_path" ]; then
    echo "Error: Script '$script_path' not found or not executable" >&2
    exit 1
  fi
  
  script_stdout_file=$(mktemp)
  if [ "${#tc_argv[@]}" -gt 0 ]; then
    (cd "$TEST_DIR" && LL_NOW_EPOCH="$LL_NOW_EPOCH" "$script_path" "${tc_argv[@]}" >"$script_stdout_file" 2>/dev/null || true)
  else
    (cd "$TEST_DIR" && LL_NOW_EPOCH="$LL_NOW_EPOCH" "$script_path" >"$script_stdout_file" 2>/dev/null || true)
  fi
  script_stdout="$(cat "$script_stdout_file")"
  rm -f "$script_stdout_file"

  # Set environment variables for canonicalization based on test flags
  if [ "${#tc_argv_clean[@]}" -gt 0 ]; then
    set_compare_env "${tc_argv_clean[@]}"
  else
    set_compare_env
  fi

  # Compare outputs
  if print_comparison "$ls_stdout" "$script_stdout"; then
    outcome="PASS"
  else
    outcome="FAIL"
  fi

  # Determine if we should print this test's output
  should_print=0
  if [ "$FAIL_ONLY" -eq 0 ]; then
    should_print=1
  elif [ "$outcome" = "FAIL" ] || [ "$outcome" = "SKIP" ]; then
    should_print=1
  fi

  if [ "$should_print" -eq 1 ]; then
    print_header
    echo "$outcome"
    echo "  ls command: $ls_cmd_display"
    echo "  ls output ($(echo -n "$ls_stdout" | wc -c) bytes):"
    if [ -z "$ls_stdout" ]; then
      echo "    (empty)"
    else
      # shellcheck disable=SC2001
      echo "$ls_stdout" | sed 's/^/    /'
    fi
    echo "  script command: $script_cmd_display"
    echo "  script output ($(echo -n "$script_stdout" | wc -c) bytes):"
    if [ -z "$script_stdout" ]; then
      echo "    (empty)"
    else
      # shellcheck disable=SC2001
      echo "$script_stdout" | sed 's/^/    /'
    fi
  fi

  if [ "$outcome" = "PASS" ]; then
    ((passed++))
  elif [ "$outcome" = "FAIL" ]; then
    ((errors++))
  fi

  if [ "$should_print" -eq 1 ]; then
    echo ""
  fi
done

if [ "$FAIL_ONLY" -eq 0 ]; then
  echo ""
  echo "=================================="
fi
echo "Results: $passed passed, $errors failed"

# ============================================================================
# CLEANUP
# ============================================================================

cd /tmp || exit 1
if [ "$KEEP_DIR" -eq 0 ]; then
  rm -rf "$TEST_DIR"
else
  echo "Test directory kept: $TEST_DIR"
fi

exit "$errors"
