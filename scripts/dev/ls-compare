  "-- symlink-to-file1"
  "-- broken-symlink"
  "-- fifo1"
  "-- setuid-file"
  "-- setgid-file"
  "-- setgid-dir"
  "-- sticky-dir"
  "mtime now-1s"
  "mtime now-119s"
  "mtime now-120s"
  "mtime now-3599s"
  "mtime now-3600s"
  "mtime now-2days"
  "mtime now-3yr"
  "mtime now-35yr"
  "mtime now-125yr"
  "symlink target space"
