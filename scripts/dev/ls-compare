printf "" > "case-mixed-time-width/future-35yr.txt"
printf "" > "case-mixed-time-width/future-125yr.txt"
printf "" > "case-mixed-time-width/future-1000yr.txt"
_sec_epoch=$((_now_epoch - 5))
_hrs_epoch=$((_now_epoch - 3 * 3600))
_day_epoch=$((_now_epoch - 12 * 24 * 3600))
_mon_epoch=$((_now_epoch - 120 * 24 * 3600))
_yr3_epoch=$((_now_epoch + 3 * 31536000))
_yr35_epoch=$((_now_epoch + 35 * 31536000))
_yr125_epoch=$((_now_epoch + 125 * 31536000))
