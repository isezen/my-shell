# ShellCheck configuration for my-shell project

# SC2139: Aliases intentionally expand variables when defined
# This is intentional behavior for dynamic alias creation
disable=SC2139

# SC2262/SC2263: Alias definition and usage in same parsing unit
# Some aliases are intentionally defined and checked in the same function
disable=SC2262,SC2263

# SC2032: Alias can't be invoked via xargs
# This is a known limitation, documented in code
disable=SC2032

# SC2317: Unreachable code
# Some code paths are intentionally unreachable (error handling)
disable=SC2317

# SC2015: A && B || C is not if-then-else
# We intentionally use `(cmd) || true` as a best-effort fallback in ll-compare
# and ls-compare — awk failures must not kill the pipeline. Local shellcheck
# 0.11.0 does not flag this; older Ubuntu-packaged shellcheck does.
disable=SC2015
